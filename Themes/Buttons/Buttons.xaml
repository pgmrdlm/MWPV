<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =========================
         Gradients (Primary: Blue → #CCCCFF → Blue)
         ========================= -->
    <LinearGradientBrush x:Key="Grad.Primary.Normal" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="Blue"     Offset="0"/>
        <GradientStop Color="#CCCCFF"  Offset="0.5"/>
        <GradientStop Color="Blue"     Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Grad.Primary.Hover" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0000CC"  Offset="0"/>
        <GradientStop Color="#DDDDFF"  Offset="0.5"/>
        <GradientStop Color="#0000CC"  Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Grad.Primary.Pressed" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#000099"  Offset="0"/>
        <GradientStop Color="#BBBBFF"  Offset="0.5"/>
        <GradientStop Color="#000099"  Offset="1"/>
    </LinearGradientBrush>

    <!-- Secondary neutral gradient -->
    <LinearGradientBrush x:Key="Grad.Secondary.Normal" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#C8CED8" Offset="0.00"/>
        <GradientStop Color="#FFFFFF" Offset="0.48"/>
        <GradientStop Color="#FFFFFF" Offset="0.52"/>
        <GradientStop Color="#C8CED8" Offset="1.00"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Grad.Secondary.Hover" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#B9C1CC" Offset="0.00"/>
        <GradientStop Color="#FFFFFF" Offset="0.48"/>
        <GradientStop Color="#FFFFFF" Offset="0.52"/>
        <GradientStop Color="#B9C1CC" Offset="1.00"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Grad.Secondary.Pressed" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#A8B1BE" Offset="0.00"/>
        <GradientStop Color="#F2F5F9" Offset="0.48"/>
        <GradientStop Color="#F2F5F9" Offset="0.52"/>
        <GradientStop Color="#A8B1BE" Offset="1.00"/>
    </LinearGradientBrush>

    <!-- Focus ring -->
    <SolidColorBrush x:Key="Btn.FocusRing" Color="#5B9BD5"/>

    <Style x:Key="Btn.FocusVisualStyle" TargetType="Control">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Control">
                    <Rectangle Margin="2"
                               Stroke="{StaticResource Btn.FocusRing}"
                               StrokeThickness="1"
                               StrokeDashArray="1 1"
                               SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================
         Base template (fixed size, per your defaults)
         ========================= -->
    <Style x:Key="GradientButtonBase" TargetType="Button">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding"   Value="True"/>
        <Setter Property="Width"               Value="130"/>
        <Setter Property="Height"              Value="20"/>
        <Setter Property="Margin"              Value="2"/>
        <Setter Property="Padding"             Value="8,2"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="FocusVisualStyle"    Value="{StaticResource Btn.FocusVisualStyle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="PART_Border"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="2"
                                          RecognizesAccessKey="True"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_Border" Property="Opacity" Value="0.55"/>
                        </Trigger>
                        <Trigger Property="IsDefaulted" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsCancel" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================
         Concrete styles
         ========================= -->
    <!-- Primary (black text, blue gradient) -->
    <Style x:Key="PrimaryGradientButton" TargetType="Button" BasedOn="{StaticResource GradientButtonBase}">
        <Setter Property="Foreground"  Value="Black"/>
        <Setter Property="Background"  Value="{StaticResource Grad.Primary.Normal}"/>
        <Setter Property="BorderBrush" Value="DarkBlue"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Grad.Primary.Hover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource Grad.Primary.Pressed}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Secondary (neutral) -->
    <Style x:Key="SecondaryGradientButton" TargetType="Button" BasedOn="{StaticResource GradientButtonBase}">
        <Setter Property="Foreground"  Value="#202124"/>
        <Setter Property="Background"  Value="{StaticResource Grad.Secondary.Normal}"/>
        <Setter Property="BorderBrush" Value="#9EA7B3"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Grad.Secondary.Hover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource Grad.Secondary.Pressed}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Title bar glyph buttons (min/max/close) -->
    <Style x:Key="TitleButton" TargetType="Button">
        <Setter Property="Width"            Value="36"/>
        <Setter Property="Height"           Value="28"/>
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Padding"          Value="0"/>
        <Setter Property="Foreground"       Value="White"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Hit" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Hit" Property="Background" Value="#27FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Hit" Property="Background" Value="#40FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Hit" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================
         Aliases (used throughout the app)
         ========================= -->
    <!-- Panel aliases -->
    <Style x:Key="AddCategoryButton" TargetType="Button"
           BasedOn="{StaticResource PrimaryGradientButton}"/>
    <Style x:Key="AddCategoryItemButton" TargetType="Button"
           BasedOn="{StaticResource PrimaryGradientButton}"/>

    <!-- SetupPasswordAndKeyFile aliases -->
    <Style x:Key="DialogPrimary" TargetType="Button"
           BasedOn="{StaticResource PrimaryGradientButton}"/>
    <Style x:Key="DialogSecondary" TargetType="Button"
           BasedOn="{StaticResource SecondaryGradientButton}"/>

</ResourceDictionary>
