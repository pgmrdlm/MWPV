<!-- Themes/Buttons/Buttons.xaml -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =========================
         Shared Brushes & Colors
         ========================= -->

    <!-- Primary (green – for action buttons like Add/Submit) -->
    <LinearGradientBrush x:Key="PrimaryNormalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#008A00" Offset="0"/>
        <GradientStop Color="#BFFFCF" Offset="0.5"/>
        <GradientStop Color="#008A00" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PrimaryHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#00C800" Offset="0"/>
        <GradientStop Color="#D9FFD9" Offset="0.5"/>
        <GradientStop Color="#00C800" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PrimaryPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#006400" Offset="0"/>
        <GradientStop Color="#A0E8A0" Offset="0.5"/>
        <GradientStop Color="#006400" Offset="1"/>
    </LinearGradientBrush>

    <!-- Secondary (neutral gray) -->
    <LinearGradientBrush x:Key="SecondaryNormalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E3E3E3" Offset="0"/>
        <GradientStop Color="#FFFFFF" Offset="0.5"/>
        <GradientStop Color="#E3E3E3" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SecondaryHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#B0B0B0" Offset="0"/>
        <GradientStop Color="#F0F0F0" Offset="0.5"/>
        <GradientStop Color="#B0B0B0" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SecondaryPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#C8C8C8" Offset="0"/>
        <GradientStop Color="#ECECEC" Offset="0.5"/>
        <GradientStop Color="#C8C8C8" Offset="1"/>
    </LinearGradientBrush>

    <!-- Danger (red) -->
    <LinearGradientBrush x:Key="DangerNormalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#D60000" Offset="0"/>
        <GradientStop Color="#FFCCCC" Offset="0.5"/>
        <GradientStop Color="#D60000" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="DangerHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF1A1A" Offset="0"/>
        <GradientStop Color="#FFD9D9" Offset="0.5"/>
        <GradientStop Color="#FF1A1A" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="DangerPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#A80000" Offset="0"/>
        <GradientStop Color="#FFB3B3" Offset="0.5"/>
        <GradientStop Color="#A80000" Offset="1"/>
    </LinearGradientBrush>

    <!-- Nav / Category (blue – used by CategoryPill) -->
    <LinearGradientBrush x:Key="NavNormalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#2B6CFF" Offset="0"/>
        <GradientStop Color="#BBD1FF" Offset="0.5"/>
        <GradientStop Color="#2B6CFF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="NavHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#4A82FF" Offset="0"/>
        <GradientStop Color="#D5E0FF" Offset="0.5"/>
        <GradientStop Color="#4A82FF" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="NavPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1949B3" Offset="0"/>
        <GradientStop Color="#A9BFFF" Offset="0.5"/>
        <GradientStop Color="#1949B3" Offset="1"/>
    </LinearGradientBrush>

    <!-- Disabled + focus -->
    <LinearGradientBrush x:Key="DisabledBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#C9C9C9" Offset="0"/>
        <GradientStop Color="#E2E2E2" Offset="0.5"/>
        <GradientStop Color="#C9C9C9" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="DisabledForeground" Color="#7A7A7A"/>
    <SolidColorBrush x:Key="FocusBorder" Color="#3B82F6"/>

    <!-- =========================
         Base Rounded Template
         ========================= -->
    <Style x:Key="RoundedButtonBase" TargetType="Button">
        <Setter Property="Width" Value="130"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14"
                            SnapsToDevicePixels="True">
                        <ContentPresenter RecognizesAccessKey="True"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#1F000000"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#2F000000"/>
                            <Setter Property="Padding" Value="10,7"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource FocusBorder}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="{StaticResource DisabledBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource DisabledForeground}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="#33000000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================
         Dialog Buttons
         ========================= -->
    <Style x:Key="DialogPrimary" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
        <Setter Property="Background" Value="{StaticResource PrimaryNormalBrush}"/>
        <Setter Property="BorderBrush" Value="#20000000"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryPressedBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource DisabledBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource DisabledForeground}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DialogSecondary" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
        <Setter Property="Background" Value="{StaticResource SecondaryNormalBrush}"/>
        <Setter Property="BorderBrush" Value="#20000000"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SecondaryHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource SecondaryPressedBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource DisabledBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource DisabledForeground}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DialogDanger" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
        <Setter Property="Background" Value="{StaticResource DangerNormalBrush}"/>
        <Setter Property="BorderBrush" Value="#40000000"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource DangerHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource DangerPressedBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource DisabledBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource DisabledForeground}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================
         Category Pill (for DataGrid category buttons)
         ========================= -->
    <Style x:Key="CategoryPill" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
        <Setter Property="Background" Value="{StaticResource NavNormalBrush}"/>
        <Setter Property="BorderBrush" Value="#20000000"/>
        <Setter Property="Foreground" Value="Black"/>
        <!-- changed from White -->
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource NavHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource NavPressedBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource DisabledBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource DisabledForeground}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================
         Title Bar Glyph Button
         ========================= -->
    <Style x:Key="TitleButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#30FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#50FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="Transparent"/>
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
