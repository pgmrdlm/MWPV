<UserControl x:Class="MWPV.View.UserControls.CatagoryGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="640"
             Background="Transparent">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Collapsible add-panel (shown/hidden from code-behind) -->
        <Border x:Name="AddPanel"
                Grid.Row="0"
                Visibility="Collapsed"
                Margin="0,0,0,8"
                Padding="16"
                CornerRadius="{StaticResource DialogCornerRadius}"
                Background="{StaticResource DialogBackgroundBrush}">
            <StackPanel>
                <TextBlock Text="Hello World"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>
                <Button x:Name="btnSubmitAddCategory"
                        Content="Submit"
                        Click="SubmitAddCategory_Click"
                        Style="{StaticResource DialogPrimary}"
                        MinWidth="240"/>
            </StackPanel>
        </Border>

        <!-- Scrollable grid of category pills (buttons are added from code-behind) -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="Transparent">
            <!-- The negative left margin offsets the left PillMargin so the first column aligns flush -->
            <UniformGrid x:Name="ButtonsHost"
                         Columns="3"
                         Margin="-6,0,0,0"/>
        </ScrollViewer>
    </Grid>
</UserControl>