<UserControl x:Class="MWPV.View.UserControls.CategoryGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MWPV.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Only the converter is needed locally now -->
        <local:StringNullOrEmptyToVisibilityConverter x:Key="StringEmptyToVisibility" />
    </UserControl.Resources>

    <Grid>
        <!-- Category button grid (defaults visible) -->
        <DataGrid ItemsSource="{Binding BoundCatagories}"
                  AutoGenerateColumns="False"
                  Name="CategoryDataGrid"
                  CanUserAddRows="False"
                  GridLinesVisibility="None"
                  HeadersVisibility="None"
                  BorderThickness="0"
                  Background="Transparent"
                  RowBackground="Transparent"
                  HorizontalAlignment="Stretch"
                  ColumnWidth="*"
                  SelectionMode="Single"
                  SelectionUnit="Cell"
                  AlternatingRowBackground="{x:Null}">

            <DataGrid.Resources>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Black"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="OverridesDefaultStyle" Value="True"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="{TemplateBinding Background}">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <!-- Category 1 -->
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding strCategory1}"
                                    Click="Button1_Click"
                                    Style="{StaticResource CategoryPill}"
                                    Visibility="{Binding strCategory1, Converter={StaticResource StringEmptyToVisibility}}"
                                    ToolTipService.ShowDuration="8000"
                                    ToolTipService.InitialShowDelay="200"
                                    ToolTipService.Placement="Right">
                                <Button.ToolTip>
                                    <!-- Use global ToolTip style; just bind text -->
                                    <TextBlock Text="{Binding strCategoryToolTip1}"
                                               Width="200"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="Black"/>
                                </Button.ToolTip>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Category 2 -->
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding strCategory2}"
                                    Click="Button2_Click"
                                    Style="{StaticResource CategoryPill}"
                                    Visibility="{Binding strCategory2, Converter={StaticResource StringEmptyToVisibility}}"
                                    ToolTipService.ShowDuration="8000"
                                    ToolTipService.InitialShowDelay="200"
                                    ToolTipService.Placement="Right">
                                <Button.ToolTip>
                                    <TextBlock Text="{Binding strCategoryToolTip2}"
                                               Width="200"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="Black"/>
                                </Button.ToolTip>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Category 3 -->
                <DataGridTemplateColumn>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding strCategory3}"
                                    Click="Button3_Click"
                                    Style="{StaticResource CategoryPill}"
                                    Visibility="{Binding strCategory3, Converter={StaticResource StringEmptyToVisibility}}"
                                    ToolTipService.ShowDuration="8000"
                                    ToolTipService.InitialShowDelay="200"
                                    ToolTipService.Placement="Right">
                                <Button.ToolTip>
                                    <TextBlock Text="{Binding strCategoryToolTip3}"
                                               Width="200"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="Black"/>
                                </Button.ToolTip>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Inline Hello World (hidden by default; does not alter your 3 columns) -->
        <Border x:Name="HelloWorldInline"
                Visibility="Collapsed"
                Background="#FFF7F7FF"
                BorderBrush="#22000000"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <StackPanel>
                <TextBlock Text="Hello World"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <Button Content="Submit"
                        Style="{StaticResource DialogPrimary}"/>
                <!-- No Click handler yet by design -->
            </StackPanel>
        </Border>
    </Grid>
</UserControl>