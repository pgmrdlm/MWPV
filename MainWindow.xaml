<Window x:Class="MWPV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MWPV"
        xmlns:userControls="clr-namespace:MWPV.View.UserControls"
        mc:Ignorable="d"
        Title="MWPV - My Windows Password Vault">
    
    <Grid  Background="Bisque">
        
        <Grid.RowDefinitions>
            <!--Menu Bar-->
            <RowDefinition Height="20"/>
            <!--Pannel-->
            <RowDefinition Height="Auto"/>
            <!--Status-->
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        
        <userControls:MenuBar 
            Grid.Row="0"
        />
        <userControls:Panel 
            x:Name="Panel" 
            Grid.Row="1"
        />
        
        <!-- Footer 
        <Rectangle Grid.Row="2" Fill="green" />-->
        
    </Grid>
</Window>
