<Application x:Class="MWPV.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ========= Merge app-wide theme resources ========= -->
            <ResourceDictionary.MergedDictionaries>
                <!-- Same-assembly resource dictionary -->
                <ResourceDictionary Source="Themes/Buttons/Buttons.xaml" />
                <!-- If Buttons.xaml moves to another assembly, use:
                <ResourceDictionary Source="pack://application:,,,/MWPV;component/Themes/Buttons/Buttons.xaml" />
                -->
            </ResourceDictionary.MergedDictionaries>

            <!-- ========= Common brushes / tokens ========= -->
            <SolidColorBrush x:Key="BrandMaroon" Color="#8B0000" />
            <SolidColorBrush x:Key="DialogBackgroundBrush" Color="Bisque" />
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="Transparent" />
            <CornerRadius   x:Key="DialogCornerRadius">8</CornerRadius>

            <!-- ========= Safe app-wide defaults ========= -->
            <!-- Windows: crisp rendering everywhere -->
            <Style TargetType="{x:Type Window}">
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding"   Value="True" />
                <Setter Property="TextOptions.TextRenderingMode"  Value="ClearType" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <!-- Text: consistent readability -->
            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="TextOptions.TextRenderingMode"  Value="ClearType" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <!-- ToolTips: subtle & readable -->
            <Style TargetType="{x:Type ToolTip}">
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Padding" Value="8,6" />
            </Style>

            <!-- DataGrid: transparent, tidy rows, virtualization on -->
            <Style TargetType="{x:Type DataGrid}">
                <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="GridLinesVisibility" Value="None" />
                <Setter Property="HeadersVisibility" Value="Column" />
                <Setter Property="RowHeaderWidth" Value="0" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="EnableRowVirtualization" Value="True" />
                <Setter Property="EnableColumnVirtualization" Value="True" />
                <Setter Property="AlternationCount" Value="0" />
                <Setter Property="RowHeight" Value="28" />
                <Setter Property="MinRowHeight" Value="24" />
            </Style>

            <!-- If you want a default button look globally, uncomment:
            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource DialogSecondary}" />
            -->
        </ResourceDictionary>
    </Application.Resources>
</Application>
