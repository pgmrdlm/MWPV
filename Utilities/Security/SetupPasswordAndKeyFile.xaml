<Window x:Class="Utilities.Security.SetupPasswordAndKeyFile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="http://schemas.microsoft.com/netfx/2007/xaml/presentation"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Height="300"
        Width="600">

    <!-- Custom chrome -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <!-- Visible frame -->
    <Border BorderBrush="DarkSlateGray"
            BorderThickness="3"
            Background="White"
            Padding="0"
            SnapsToDevicePixels="True">

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <!-- Title -->
                <RowDefinition Height="30"/>
                <!-- Password -->
                <RowDefinition x:Name="VerifyPasswordRow" Height="30"/>
                <!-- Verify -->
                <RowDefinition Height="30"/>
                <!-- Key file -->
                <RowDefinition Height="30"/>
                <!-- Buttons -->
                <RowDefinition Height="*"/>
                <!-- Error -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Background="#810000"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Padding="10,0,8,0">
                <DockPanel LastChildFill="True">
                    <!-- Uses Window.Icon if you set one -->
                    <Image Width="16" Height="16"
                           Margin="0,0,8,0"
                           Source="{Binding Icon, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <TextBlock VerticalAlignment="Center"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Text="Create Key file and Password for MWPV"/>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch">
                        <!-- Minimize -->
                        <Button Width="36" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                ToolTip="Minimize"
                                Click="MinButton_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="White"
                                       Text="&#xE921;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                        <!-- Max/Restore -->
                        <Button Width="36" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                ToolTip="Maximize/Restore"
                                Click="MaxRestoreButton_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock x:Name="TbMaxGlyph"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="White"
                                       Text="&#xE922;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                        <!-- Close -->
                        <Button Width="36" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                ToolTip="Close"
                                Click="CloseButton_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="White"
                                       Text="&#xE8BB;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content background -->
            <Border Grid.Row="1"
                    Grid.RowSpan="5"
                    Grid.ColumnSpan="2"
                    Background="Bisque"/>

            <!-- Create Password -->
            <Label Content="Enter Password"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   FontSize="12"
                   Foreground="Black"
                   Grid.Row="1"
                   Grid.Column="0"/>

            <PasswordBox x:Name="pbPassword"
                         Grid.Column="1"
                         Margin="10,0,0,0"
                         VerticalAlignment="Center"
                         Height="20"
                         Width="200"
                         Background="White"
                         Foreground="Black"
                         Grid.Row="1"
                         PasswordChar="*"/>

            <!-- Verify Password -->
            <Label Content="Verify Password"
                   x:Name="lblVerifyPassword"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   FontSize="12"
                   Foreground="Black"
                   Grid.Row="2"
                   Grid.Column="0"/>

            <PasswordBox x:Name="pbVerifyPassword"
                         Grid.Column="1"
                         Margin="10,0,0,0"
                         VerticalAlignment="Center"
                         Height="20"
                         Width="200"
                         Background="White"
                         Foreground="Black"
                         Grid.Row="2"
                         PasswordChar="*"/>

            <!-- Key file selection -->
            <Button Content="Create Key File"
                    x:Name="btnCreateKeyFile"
                    Click="btnCreateKeyFile_Click"
                    Height="20"
                    Width="130"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Grid.Column="0"
                    Grid.Row="3">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#810000" Offset="0"/>
                        <GradientStop Color="#CCCCFF" Offset="0.5"/>
                        <GradientStop Color="#810000" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <TextBox x:Name="tbKeyFile"
                     Grid.Column="1"
                     Grid.Row="3"
                     Margin="10,0,0,0"
                     VerticalAlignment="Center"
                     Height="20"
                     Width="200"
                     IsReadOnly="True"
                     Background="White"
                     Foreground="Black"/>

            <!-- Submit -->
            <Button Content="Submit"
                    x:Name="btnSubmit"
                    Click="btnSubmit_Click"
                    Height="20"
                    Width="130"
                    Grid.Column="0"
                    Grid.Row="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#810000" Offset="0"/>
                        <GradientStop Color="#CCCCFF" Offset="0.5"/>
                        <GradientStop Color="#810000" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FB;" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <!-- Cancel -->
            <Button Content="Cancel"
                    x:Name="btnCancel"
                    Click="btnCancel_Click"
                    Height="20"
                    Width="130"
                    Grid.Column="1"
                    Grid.Row="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#810000" Offset="0"/>
                        <GradientStop Color="#CCCCFF" Offset="0.5"/>
                        <GradientStop Color="#810000" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding}"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>

            <!-- Error message -->
            <TextBox x:Name="tbErrorMessage"
                     Grid.Column="0"
                     Grid.ColumnSpan="2"
                     Grid.Row="5"
                     Visibility="Collapsed"
                     Margin="10,0,0,0"
                     VerticalAlignment="Top"
                     Height="100"
                     Width="400"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     TextAlignment="Center"
                     VerticalContentAlignment="Top"
                     Background="Transparent"
                     Foreground="Red"/>
        </Grid>
    </Border>
</Window>
