<Window x:Class="Utilities.Security.SetupPasswordAndKeyFile"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               WindowStyle="None"
               ResizeMode="NoResize"
               AllowsTransparency="True"
               Background="White"
               WindowStartupLocation="CenterScreen"
               Height="300"
               Width="600">
    <Border BorderBrush="DarkSlateGray"
            BorderThickness="3"
            Background="White"
            Padding="0"
            SnapsToDevicePixels="True">
        <Grid  Background="Bisque"
            Margin="0">
            <Grid.RowDefinitions>
                <!-- Heading Row-->
                <RowDefinition Height="25"/>
                <!-- Pssword enter/creation row -->
                <RowDefinition Height="30"/>
                <!-- Verify Password row -->
                <RowDefinition x:Name="VerifyPasswordRow" Height="30"/>
                <!-- Key file selection row -->
                <RowDefinition Height="30"/>
                <!-- Button Row-->
                <RowDefinition Height="30"/>
                <!-- Error Message Row-->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!--Heading-->
            <Label Content="Create Key file and Password for MWPV"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Grid.ColumnSpan="2"
                   Visibility="Visible"
                   FontWeight="Bold"
                   FontSize="12"
                   Foreground="Black"
                   Grid.Row="0">
            </Label>

            <!--Create Password Label Row-->
            <Label Content="Enter Password"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Visible"
                FontWeight="Bold"
                FontSize="12"
                Foreground="Black"
                Grid.Row="1"
                Grid.Column="0">
            </Label>
            <!--Enter user selected password-->
            <PasswordBox x:Name="pbPassword"
                Grid.Column="1"
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Height="20"
                Width="200"
                Background="White"
                Foreground="Black"
                Grid.Row="1"
                PasswordChar="*"/>
            <Label Content="Verify Password"
                Name="lblVerifyPassword"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Visible"
                FontWeight="Bold"
                FontSize="12"
                Foreground="Black"
                Grid.Row="2"
                Grid.Column="0">
            </Label>

            <PasswordBox x:Name="pbVerifyPassword"
                Grid.Column="1"
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Height="20"
                Width="200"
                Background="White"
                Foreground="Black"
                Grid.Row="2"
                PasswordChar="*"/>
            <!--Key file name and location-->
            <Button Content="Create Key File"
                x:Name="btnCreaateKeyFile"
                Click="btnCreateKeyFile_Click"
                Height="20"
                Width="130"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Grid.Column="0"
                Grid.Row="3">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#810000" Offset="0"/>
                        <GradientStop Color="#CCCCFF" Offset="0.5"/>
                        <GradientStop Color="#810000" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
            <TextBox x:Name="tbKeyFile"
                Grid.Column="1"
                Grid.Row="3"
                Margin="10,0,0,0"
                VerticalAlignment="Center"
                Height="20"
                Width="200"
                IsReadOnly="True"
                Background="White"
                Foreground="Black"/>
            <!--Button to Submit or cancel entries-->
            <Button Content="Submit"
                x:Name="btnSubmit"
                Click="btnSubmit_Click"
                Height="20" 
                Width="130" 
                Grid.Column="0"   
                Grid.Row="4"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color= "#810000" Offset="0"/>
                        <GradientStop Color="#CCCCFF" Offset="0.5"/>
                        <GradientStop Color="#810000" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="Cancel"
                    x:Name="btnCancel"
                    Click="btnCancel_Click"
                    Height="20" 
                    Width="130" 
                    Grid.Column="1"                 
                    Grid.Row="4"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color= "#810000" Offset="0"/>
                        <GradientStop Color="#CCCCFF" Offset="0.5"/>
                        <GradientStop Color="#810000" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
            <TextBox x:Name="tbErrorMessage"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Grid.Row="5"
                Visibility="Collapsed"
                Margin="10,0,0,0"
                VerticalAlignment="Top"
                Height="100"
                Width="400"
                IsReadOnly="True"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto"
                TextAlignment="Center"
                VerticalContentAlignment="Top"
                Background="Transparent"
                Foreground="Red"/>

        </Grid>
    </Border>
</Window>

