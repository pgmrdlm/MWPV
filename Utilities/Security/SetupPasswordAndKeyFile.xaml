<Window x:Class="Utilities.Security.SetupPasswordAndKeyFile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Height="320"
        Width="640"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <!-- Make MWPV button/theme resources available here -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Cross-assembly pack URI to MWPV/Themes/Buttons/Buttons.xaml -->
                <ResourceDictionary Source="pack://application:,,,/MWPV;component/Themes/Buttons/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="DarkSlateGray"
            BorderThickness="3"
            Background="White"
            Padding="0"
            SnapsToDevicePixels="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="#810000"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Padding="10,0,8,0">
                <DockPanel LastChildFill="True">
                    <Image Width="16" Height="16"
                           Margin="0,0,8,0"
                           Source="{Binding Icon, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <TextBlock VerticalAlignment="Center"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Text="Create Key file and Password for MWPV"/>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                Margin="8,0,0,0">
                        <!-- Minimize -->
                        <Button Style="{StaticResource TitleButton}"
                                ToolTip="Minimize"
                                Click="MinButton_Click"
                                Margin="0,0,4,0">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="White"
                                       Text="&#xE921;"/>
                        </Button>

                        <!-- Max/Restore -->
                        <Button Style="{StaticResource TitleButton}"
                                ToolTip="Maximize/Restore"
                                Click="MaxRestoreButton_Click"
                                Margin="0,0,4,0">
                            <TextBlock x:Name="TbMaxGlyph"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="White"
                                       Text="&#xE922;"/>
                        </Button>

                        <!-- Close -->
                        <Button Style="{StaticResource TitleButton}"
                                ToolTip="Close"
                                Click="CloseButton_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="White"
                                       Text="&#xE8BB;"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1"
                    Background="Bisque"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- password -->
                        <RowDefinition Height="12"/>
                        <RowDefinition x:Name="VerifyPasswordRow" Height="Auto"/>
                        <!-- verify -->
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <!-- key file -->
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <!-- submit/cancel -->
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <!-- error -->
                        <RowDefinition Height="*"/>
                        <!-- filler -->
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <!-- labels / key-file button -->
                        <ColumnDefinition Width="12"/>
                        <!-- gutter -->
                        <ColumnDefinition Width="*"/>
                        <!-- text boxes -->
                    </Grid.ColumnDefinitions>

                    <!-- Enter Password -->
                    <Label Grid.Row="0" Grid.Column="0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,10,0"
                           Content="_Enter Password"
                           Target="{Binding ElementName=pbPassword}"/>
                    <PasswordBox x:Name="pbPassword"
                                 Grid.Row="0" Grid.Column="2"
                                 Height="30"
                                 VerticalAlignment="Center"
                                 Background="White"
                                 Foreground="Black"
                                 PasswordChar="*"
                                 Padding="6,2"/>

                    <!-- Verify Password -->
                    <Label x:Name="lblVerifyPassword"
                           Grid.Row="2" Grid.Column="0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,10,0"
                           Content="_Verify Password"
                           Target="{Binding ElementName=pbVerifyPassword}"/>
                    <PasswordBox x:Name="pbVerifyPassword"
                                 Grid.Row="2" Grid.Column="2"
                                 Height="30"
                                 VerticalAlignment="Center"
                                 Background="White"
                                 Foreground="Black"
                                 PasswordChar="*"
                                 Padding="6,2"/>

                    <!-- Key file selection -->
                    <Button x:Name="btnCreateKeyFile"
                            Grid.Row="4" Grid.Column="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource DialogPrimary}"
                            Click="btnCreateKeyFile_Click"
                            ToolTip="Create/Choose the encrypted key archive"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" Margin="0,0,8,0"/>
                            <TextBlock Text="Select Key File"/>
                        </StackPanel>
                    </Button>

                    <TextBox x:Name="tbKeyFile"
                             Grid.Row="4" Grid.Column="2"
                             Height="30"
                             VerticalAlignment="Center"
                             IsReadOnly="True"
                             Background="White"
                             Foreground="Black"
                             Padding="6,2"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Disabled"
                             ToolTip="{Binding Text, ElementName=tbKeyFile}"/>

                    <!-- Submit / Cancel -->
                    <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button x:Name="btnSubmit"
                                Style="{StaticResource DialogPrimary}"
                                Click="btnSubmit_Click"
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FB;" Margin="0,0,8,0"/>
                                <TextBlock Text="Submit"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnCancel"
                                Style="{StaticResource DialogSecondary}"
                                Click="btnCancel_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" Margin="0,0,8,0"/>
                                <TextBlock Text="Cancel"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Error message -->
                    <TextBox x:Name="tbErrorMessage"
                             Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3"
                             Visibility="Collapsed"
                             Height="100"
                             Margin="0,6,0,0"
                             VerticalAlignment="Top"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             TextAlignment="Center"
                             VerticalContentAlignment="Top"
                             IsReadOnly="True"
                             Background="#10FF0000"
                             Foreground="Red"
                             BorderThickness="0"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
