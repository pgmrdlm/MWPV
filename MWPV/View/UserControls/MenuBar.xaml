<UserControl x:Class="MWPV.View.UserControls.MenuBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Height="20" d:DesignWidth="800">
    <Grid>
        <Menu Background="#810000"
              Foreground="White">
            <MenuItem Header="File">
                <MenuItem Header="Exit"
                          Margin="0"
                          Background="DarkBlue"
                          Name="mnuFileExit"/>
            </MenuItem>

            <MenuItem Header="Tools">
                <MenuItem Header="Backup Password DB"
                          Background="DarkBlue"
                          Name="mnuToolsBackup"/>
                <MenuItem Header="Restore Password DB"
                          Background="DarkBlue"
                          Name="mnuToolsRestore"/>
                <MenuItem Header="Reset DB Encryption"
                          Background="DarkBlue"
                          Name="mnuToolsReset"/>

                <!-- New: View Logs -->
                <Separator/>
                <MenuItem Header="View Logs..."
                          Background="DarkBlue"
                          Name="mnuToolsViewLogs"
                          Click="mnuToolsViewLogs_Click"/>
            </MenuItem>

            <MenuItem Header="Help"/>
        </Menu>
    </Grid>
</UserControl>
