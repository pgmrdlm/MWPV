<UserControl x:Class="MWPV.View.UserControls.Popup.PopupDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="900"
             Focusable="True">

    <!--
        PURPOSE
        - Generic modal overlay popup that blocks the app until handled.
        - Uses existing button styles: DialogPrimary (green) and DialogSecondary.
        - Severity:
            0 = Warning (yellow icon)
            1 = Abort   (red icon)
        - Supports:
            - Accept/Cancel (warning)
            - Abort-only (crash/terminate style)
        - Short message: stays compact.
        - Long message: grows up to max and scrolls.
    -->

    <UserControl.Resources>

        <!-- Icon colors -->
        <SolidColorBrush x:Key="PopupWarnBrush" Color="#F59E0B"/>
        <!-- yellow -->
        <SolidColorBrush x:Key="PopupAbortBrush" Color="#DC2626"/>
        <!-- red -->

        <!-- Overlay + card -->
        <SolidColorBrush x:Key="PopupOverlayBrush" Color="#80000000"/>
        <!-- 50% black -->
        <SolidColorBrush x:Key="PopupCardBackground" Color="White"/>

        <!-- Title / content -->
        <Style x:Key="PopupTitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="PopupBodyText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

    </UserControl.Resources>

    <!-- Full-screen overlay (host puts this on top of everything) -->
    <Grid Background="{StaticResource PopupOverlayBrush}"
          Focusable="True">

        <!-- Center card -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource PopupCardBackground}"
                BorderBrush="{DynamicResource ShadowStroke}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16"
                MinWidth="420"
                MaxWidth="820"
                MinHeight="180">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- header -->
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <!-- message -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <!-- buttons -->
                </Grid.RowDefinitions>

                <!-- ================= HEADER ================= -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Severity icon (Warning vs Abort) -->
                    <Grid Grid.Column="0"
                          Width="36"
                          Height="36"
                          VerticalAlignment="Top">

                        <!-- Warning icon -->
                        <Viewbox x:Name="IconWarn"
                                 Visibility="Collapsed">
                            <Canvas Width="24" Height="24">
                                <!-- Triangle -->
                                <Path Fill="{StaticResource PopupWarnBrush}"
                                      Data="M12,2 L22,20 H2 Z"/>
                                <!-- Exclamation -->
                                <Rectangle Fill="Black"
                                           Width="2.2" Height="9"
                                           Canvas.Left="10.9" Canvas.Top="8"/>
                                <Ellipse Fill="Black"
                                         Width="2.4" Height="2.4"
                                         Canvas.Left="10.8" Canvas.Top="18"/>
                            </Canvas>
                        </Viewbox>

                        <!-- Abort icon -->
                        <Viewbox x:Name="IconAbort"
                                 Visibility="Collapsed">
                            <Canvas Width="24" Height="24">
                                <Ellipse Fill="{StaticResource PopupAbortBrush}"
                                         Width="22" Height="22"
                                         Canvas.Left="1" Canvas.Top="1"/>
                                <!-- X -->
                                <Path Stroke="White" StrokeThickness="2.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M7,7 L17,17"/>
                                <Path Stroke="White" StrokeThickness="2.4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M17,7 L7,17"/>
                            </Canvas>
                        </Viewbox>

                    </Grid>

                    <TextBlock Grid.Column="2"
                               Text="{Binding TitleText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Style="{StaticResource PopupTitleText}"/>
                </Grid>

                <!-- ================= MESSAGE (scrollable) ================= -->
                <Border Grid.Row="2"
                        Background="#08FFFFFF"
                        BorderBrush="{DynamicResource ShadowStroke}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10">

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  MaxHeight="320">

                        <TextBlock Text="{Binding MessageText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   Style="{StaticResource PopupBodyText}"/>
                    </ScrollViewer>

                </Border>

                <!-- ================= BUTTONS ================= -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Secondary (Cancel) -->
                    <Button x:Name="btnSecondary"
                            Grid.Column="1"
                            Style="{StaticResource DialogSecondary}"
                            MinWidth="120"
                            Click="btnSecondary_Click">
                        <TextBlock Text="{Binding SecondaryButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </Button>

                    <!-- Primary (Accept / Abort) -->
                    <Button x:Name="btnPrimary"
                            Grid.Column="3"
                            Style="{StaticResource DialogPrimary}"
                            MinWidth="120"
                            Click="btnPrimary_Click">
                        <TextBlock Text="{Binding PrimaryButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </Button>
                </Grid>

            </Grid>
        </Border>

    </Grid>
</UserControl>
