<UserControl x:Class="MWPV.View.UserControls.Logs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- toolbar -->
            <RowDefinition Height="*"/>
            <!-- table -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: actions -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="btnRefresh" Content="Refresh" Padding="16,4" Margin="0,0,8,0"
                        Click="Refresh_Click"/>
                <Button x:Name="btnClose" Content="Close" Padding="16,4"
                        Click="Close_Click"/>
            </StackPanel>

            <!-- Center: title -->
            <TextBlock Grid.Column="1"
                       Text="Logs (recent)"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- Right: auto-refresh (no direct handlers; code-behind wires these) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="chkAuto" Content="Auto-refresh" Margin="0,0,6,0"/>
                <TextBlock Text="every" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="cmbSeconds" Width="60" SelectedIndex="1" Margin="0,0,6,0">
                    <ComboBoxItem>5</ComboBoxItem>
                    <ComboBoxItem>10</ComboBoxItem>
                    <ComboBoxItem>30</ComboBoxItem>
                </ComboBox>
                <TextBlock Text="sec" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Data table -->
        <DataGrid x:Name="dgLogs"
                  Grid.Row="1"
                  Margin="8,0,8,8"
                  ItemsSource="{Binding}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  Background="Bisque"
                  BorderThickness="0"
                  RowHeaderWidth="0"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowHeight="28"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True"
                  ScrollViewer.VerticalScrollBarVisibility="Visible"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"         Binding="{Binding Id}"         Width="80"/>
                <DataGridTextColumn Header="CreatedUtc" Binding="{Binding CreatedUtc}" Width="220"/>
                <DataGridTextColumn Header="Level"      Binding="{Binding Level}"      Width="110"/>
                <DataGridTextColumn Header="Source"     Binding="{Binding Source}"     Width="170"/>
                <DataGridTextColumn Header="EventCode"  Binding="{Binding EventCode}"  Width="170"/>
                <DataGridTemplateColumn Header="Details" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="View"
                                    Padding="12,2"
                                    Focusable="False"
                                    Click="ViewLog_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
