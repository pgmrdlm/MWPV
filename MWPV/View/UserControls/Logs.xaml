<UserControl x:Class="MWPV.View.UserControls.Logs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="btnRefresh" Content="Refresh" Width="90" Margin="0,0,8,0"/>
            <Button x:Name="btnClose" Content="Close" Width="90"/>
            <TextBlock Text="  " />
            <TextBlock Text="Logs (recent)" VerticalAlignment="Center" FontWeight="Bold" />
        </StackPanel>

        <DataGrid x:Name="dgLogs"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  MouseDoubleClick="dgLogs_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="70"/>
                <DataGridTextColumn Header="CreatedUtc" Binding="{Binding CreatedUtc}" Width="250"/>
                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="90"/>
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="180"/>
                <DataGridTextColumn Header="EventCode" Binding="{Binding EventCode}" Width="200"/>
                <DataGridTemplateColumn Header="Details" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="View" Width="80" Click="ViewLog_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
