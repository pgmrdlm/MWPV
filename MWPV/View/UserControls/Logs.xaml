<UserControl x:Class="MWPV.View.UserControls.Logs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:MWPV.View.UserControls">
    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="12,6">
            <!-- Columns: Close | gap | label | gap | combo | fill -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Close (silver/secondary pill) -->
            <Button x:Name="btnClose"
                    Grid.Column="0"
                    Content="Close"
                    Style="{StaticResource DialogSecondary}"
                    Padding="16,4"
                    Click="Close_Click"
                    MinWidth="80" />

            <!-- Filter label -->
            <TextBlock Grid.Column="2"
                       Text="Event Code Selection:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

                <!-- 🔻 Only styles the dropdown items; leaves the closed box as-is -->
                <!-- Closed box with rounded corners -->
                <Border Grid.Column="4"
                    CornerRadius="4"
                    Background="{StaticResource SecondaryNormalBrush}"
                    BorderBrush="#8A8A8A"
                    BorderThickness="1">
                    <ComboBox x:Name="cmbType"
                        Width="190"
                        Background="Transparent"   
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        DisplayMemberPath="Description"
                        SelectedValuePath="Code"
                        SelectionChanged="Type_SelectionChanged">

                        <!-- ⬇ local dropdown styling only -->
                        <ComboBox.Resources>
                            <!-- Title-like colors -->
                            <SolidColorBrush x:Key="DropBg"           Color="#7A0000"/>
                            <SolidColorBrush x:Key="DropBgHover"      Color="#8E1A1A"/>
                            <SolidColorBrush x:Key="DropBgSelected"   Color="#5C0000"/>
                            <SolidColorBrush x:Key="DropHoverText"    Color="#2B6CFF"/>

                            <!-- 2) Round each dropdown item -->
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="{StaticResource DropBg}"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="Padding" Value="10,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBoxItem">
                                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Margin="2,2,2,2">
                                                <ContentPresenter
                                    Margin="8,4"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource DropBgHover}"/>
                                                    <Setter Property="Foreground" Value="{StaticResource DropHoverText}"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource DropBgSelected}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Foreground" Value="#90FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                </Border>




                <!-- Title centered across the whole toolbar -->
            <TextBlock Grid.ColumnSpan="6"
                       Text="Log Display"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="12,0,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: list -->
            <uc:LogListPanel x:Name="ListPanel"
                             Grid.Column="0"
                             PrevRequested="ListPanel_PrevRequested"
                             NextRequested="ListPanel_NextRequested"
                             ViewRequested="ListPanel_ViewRequested"
                             SelectionChangedRouted="ListPanel_SelectionChanged"/>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="#20000000"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Right: details -->
            <uc:LogDetailsPanel x:Name="DetailsPanel"
                                Grid.Column="2"/>
        </Grid>
    </Grid>
</UserControl>
