<UserControl x:Class="MWPV.View.UserControls.Logs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:MWPV.View.UserControls">
  
    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="12,6">
            <!-- Columns: Close | gap | label | gap | combo | fill -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Close (silver/secondary pill) -->
            <Button x:Name="btnClose"
                    Grid.Column="0"
                    Content="Close"
                    Style="{StaticResource DialogSecondary}"
                    Padding="16,4"
                    Click="Close_Click"
                    MinWidth="80" />

            <!-- Filter label -->
            <TextBlock Grid.Column="2"
                       Text="Event Code Selection:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

                <!-- 🔻 Only styles the dropdown items; leaves the closed box as-is -->
            <!-- Closed box with rounded corners you already have -->
            <!-- Closed box with rounded corners -->
            <Border Grid.Column="4"
                CornerRadius="4"
                Background="{StaticResource SecondaryNormalBrush}"
                BorderBrush="#8A8A8A"
                BorderThickness="1">

                <ComboBox x:Name="cmbType"
                    Width="190"
                    Background="Transparent"
                    BorderThickness="0"
                    VerticalAlignment="Center"
                    DisplayMemberPath="Description"
                    SelectedValuePath="Code"
                    SelectionChanged="Type_SelectionChanged"
                    Style="{StaticResource FilterComboStyle}"
                    MaxDropDownHeight="360" />

                <!-- If you need to verify the popup, temporarily add:
         IsDropDownOpen="True"
         …then remove it once you see the list.
    -->
            </Border>



            <!-- Title centered across the whole toolbar -->
            <TextBlock Grid.ColumnSpan="6"
                       Text="Log Display"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="12,0,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: list -->
            <uc:LogListPanel x:Name="ListPanel"
                             Grid.Column="0"
                             PrevRequested="ListPanel_PrevRequested"
                             NextRequested="ListPanel_NextRequested"
                             ViewRequested="ListPanel_ViewRequested"
                             SelectionChangedRouted="ListPanel_SelectionChanged"/>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="#20000000"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Right: details -->
            <uc:LogDetailsPanel x:Name="DetailsPanel"
                                Grid.Column="2"/>
        </Grid>
    </Grid>
</UserControl>
