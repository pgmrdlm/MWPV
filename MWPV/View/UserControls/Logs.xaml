<UserControl x:Class="MWPV.View.UserControls.Logs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:MWPV.View.UserControls">

    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="12,6">
            <!-- Columns: Close | gap | label | gap | combo | fill -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Close (silver/secondary pill) -->
            <Button x:Name="btnClose"
                    Grid.Column="0"
                    Content="Close"
                    Style="{StaticResource DialogSecondary}"
                    Padding="16,4"
                    ToolTip="Close the log viewer."
                    Click="Close_Click"
                    MinWidth="80" />

            <!-- Filter label -->
            <TextBlock Grid.Column="2"
                       Text="Event Code Selection:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <!-- Rounded combo container -->
            <Border Grid.Column="4"
                    CornerRadius="4"
                    Background="{StaticResource SecondaryNormalBrush}"
                    BorderBrush="#8A8A8A"
                    BorderThickness="1">
                <ComboBox x:Name="cmbType"
                          Width="190"
                          Background="Transparent"
                          BorderThickness="0"
                          VerticalAlignment="Center"
                          ToolTip="Filter the log list by event code."
                          DisplayMemberPath="Description"
                          SelectedValuePath="Code"
                          SelectionChanged="Type_SelectionChanged"
                          Style="{StaticResource FilterComboStyle}"
                          MaxDropDownHeight="360"/>
            </Border>

            <Button x:Name="btnPurgeSessionLogs"
                    Grid.Column="6"
                    Content="Purge retained session logs..."
                    Style="{StaticResource DialogPrimary}"
                    Padding="14,4"
                    Click="PurgeSessionLogs_Click"
                    ToolTip="Create a verified backup, then purge expired session start and session end logs."/>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="12,0,12,6">
            <Grid.ColumnDefinitions>
                <!-- was 5* | 6 | 5* (too much right) -->
                <!-- give left a bit more room so EventCode isn't truncated -->
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: list (no Detail button, selection drives details) -->
            <uc:LogListPanel x:Name="ListPanel"
                             Grid.Column="0"
                             PrevRequested="ListPanel_PrevRequested"
                             NextRequested="ListPanel_NextRequested"
                             SelectionChangedRouted="ListPanel_SelectionChanged"/>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="#20000000"
                          ToolTip="Drag to resize the log list and details panes."
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- Right: details -->
            <uc:LogDetailsPanel x:Name="DetailsPanel"
                                Grid.Column="2"/>
        </Grid>
    </Grid>
</UserControl>
