<UserControl x:Class="MWPV.View.UserControls.Logs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <DockPanel Grid.Row="0" Margin="6">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button x:Name="btnClose" Style="{StaticResource DialogSecondary}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" Margin="0,0,8,0"/>
                        <TextBlock Text="Close"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Data grid -->
        <DataGrid x:Name="dgLogs"
                  Grid.Row="1"
                  Margin="6"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"          Binding="{Binding Id}"          Width="80"/>
                <DataGridTextColumn Header="CreatedUtc"  Binding="{Binding CreatedUtc}"  Width="160"/>
                <DataGridTextColumn Header="Level"       Binding="{Binding Level}"       Width="80"/>
                <DataGridTextColumn Header="Source"      Binding="{Binding Source}"      Width="140"/>
                <DataGridTextColumn Header="EventCode"   Binding="{Binding EventCode}"   Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
