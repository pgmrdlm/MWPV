<UserControl x:Class="MWPV.View.UserControls.Panel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:uc="clr-namespace:MWPV.View.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">

    <Grid x:Name="Root">

        <!-- ====================== MAIN SPLIT ====================== -->
        <Grid x:Name="SplitRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="260"/>
                <ColumnDefinition Width="*" MinWidth="420"/>
            </Grid.ColumnDefinitions>

            <!-- ================= LEFT: Categories ================== -->
            <DockPanel Grid.Column="0" LastChildFill="True" Margin="8">

                <!-- Header -->
                <TextBlock DockPanel.Dock="Top"
                           Text="Categories"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- Add Category button -->
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <Button x:Name="btnAddCategory"
                            Content="Add Category"
                            Click="btnAddCategory_Click"
                            Style="{StaticResource DialogPrimary}"/>
                </StackPanel>

                <!-- Category Grid -->
                <uc:CategoryGrid x:Name="CategoryGrid"/>

                <!-- Inline Add Category Host (collapsed by default) -->
                <Border x:Name="AddCategoryHost"
                        Visibility="Collapsed"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Margin="0">
                    <ContentControl x:Name="AddCategoryContent"/>
                </Border>
            </DockPanel>

            <!-- ============== RIGHT: Category Items ================ -->
            <DockPanel Grid.Column="1" LastChildFill="True" Margin="8">

                <!-- Right Header (will become: Category Items — {Selected}) -->
                <TextBlock DockPanel.Dock="Top"
                           x:Name="txtCategoryItemsTitle"
                           Text="Category Items"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- Add Item (shown once a category is selected) -->
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <Button x:Name="btnAddCategoryItem"
                            Content="Add Item"
                            Click="btnAddCategoryItem_Click"
                            Visibility="Collapsed"
                            Style="{StaticResource DialogPrimary}"/>
                </StackPanel>

                <!-- Category Item Grid -->
                <uc:CategoryItemGrid x:Name="CategoryItemGrid"
                                     Margin="0,4,0,0"/>

                <!-- Inline Add Item Host (collapsed by default) -->
                <Border x:Name="AddItemHost"
                        Visibility="Collapsed"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Margin="0">
                    <!-- Real Item Detail UI -->
                    <uc:CategoryItemDetail x:Name="CategoryItemDetailControl"/>
                </Border>
            </DockPanel>
        </Grid>

        <!-- ====================== LOGS OVERLAY ===================== -->
        <Border x:Name="OverlayHost"
                Visibility="Collapsed"
                Panel.ZIndex="1000"
                Background="#00000000">
            <uc:Logs x:Name="LogsOverlay"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"/>
        </Border>

    </Grid>
</UserControl>
