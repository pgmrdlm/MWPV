<UserControl x:Class="MWPV.View.UserControls.Panel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:uc="clr-namespace:MWPV.View.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">

    <Grid x:Name="Root">

        <!-- ====================== MAIN SPLIT ====================== -->
        <Grid x:Name="SplitRoot">
            <Grid.ColumnDefinitions>
                <!-- Left: Categories -->
                <ColumnDefinition Width="*" MinWidth="260"/>
                <!-- Right: Category Items & editor overlay -->
                <ColumnDefinition Width="*" MinWidth="420"/>
            </Grid.ColumnDefinitions>

            <!-- ================= LEFT: Categories ================== -->
            <DockPanel Grid.Column="0"
                       LastChildFill="True"
                       Margin="8">

                <!-- Header -->
                <TextBlock DockPanel.Dock="Top"
                           Text="Categories"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- Add Category button -->
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <Button x:Name="btnAddCategory"
                            Content="Add Category"
                            Click="btnAddCategory_Click"
                            Style="{StaticResource DialogPrimary}"/>
                </StackPanel>

                <!-- Category grid (default view) -->
                <uc:CategoryGrid x:Name="CategoryGrid"/>

                <!-- Inline Add Category host (shown when adding) -->
                <Border x:Name="AddCategoryHost"
                        Visibility="Collapsed"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Margin="0">
                    <ContentControl x:Name="AddCategoryContent"/>
                </Border>
            </DockPanel>

            <!-- ============== RIGHT: Items + EDIT OVERLAY =========== -->
            <Grid Grid.Column="1"
                  x:Name="RightPane"
                  Margin="8">
                <!-- Base right-hand content -->
                <DockPanel x:Name="RightContent"
                           LastChildFill="True">

                    <!-- Header -->
                    <TextBlock DockPanel.Dock="Top"
                               x:Name="txtCategoryItemsTitle"
                               Text="Category Items"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <!-- Add Item button -->
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Button x:Name="btnAddCategoryItem"
                                Content="Add Item"
                                Visibility="Collapsed"
                                Click="btnAddCategoryItem_Click"
                                Style="{StaticResource DialogPrimary}"/>
                    </StackPanel>

                    <!-- Category Item grid -->
                    <uc:CategoryItemGrid x:Name="CategoryItemGrid"
                                         Margin="0,4,0,0"/>
                </DockPanel>

                <!-- Add/Edit Category Item overlay
                     (only covers the RIGHT side now) -->
                <ContentControl x:Name="AddEditItemOverlayHost"
                                Visibility="Collapsed"
                                Panel.ZIndex="200"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
            </Grid>
        </Grid>

        <!-- ====================== LOGS OVERLAY ===================== -->
        <!-- This still covers the whole panel (both columns). -->
        <Border x:Name="OverlayHost"
                Visibility="Collapsed"
                Panel.ZIndex="1000"
                Background="#AA000000">
            <uc:Logs x:Name="LogsOverlay"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"/>
        </Border>
    </Grid>
</UserControl>
