<UserControl x:Class="MWPV.View.UserControls.Panel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:uc="clr-namespace:MWPV.View.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid>
        <!-- 50/50 columns, no splitter -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="220"/>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Categories (FLUSH LEFT) -->
        <DockPanel Grid.Column="0" Margin="0,8,8,8" LastChildFill="True">
            <TextBlock DockPanel.Dock="Top"
                       Text="Categories"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal"
                        Margin="0,0,0,8">
                <Button x:Name="btnAddCategory"
                        Content="Add Category"
                        Click="btnAddCategory_Click"
                        Style="{StaticResource DialogPrimary}"/>
            </StackPanel>

            <!-- Default view: Category grid (visible by default) -->
            <uc:CategoryGrid x:Name="CategoryGrid"/>

            <!-- Inline Add Category host (flush; no padding/border/background) -->
            <Border x:Name="AddCategoryHost"
                    Visibility="Collapsed"
                    Background="Transparent"
                    BorderBrush="{x:Null}"
                    BorderThickness="0"
                    CornerRadius="0"
                    Padding="0"
                    Margin="0">
                <ContentControl x:Name="AddCategoryContent" />
            </Border>
        </DockPanel>

        <!-- Right: Items -->
        <DockPanel Grid.Column="1" Margin="8,8,8,8" LastChildFill="True">
            <TextBlock DockPanel.Dock="Top"
                       Text="Items"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>

            <StackPanel DockPanel.Dock="Top"
                        Orientation="Horizontal"
                        Margin="0,0,0,8">
                <!-- Starts collapsed; you’ll show it when a category is clicked -->
                <Button x:Name="btnAddCategoryItem"
                        Content="Add Item"
                        Style="{StaticResource DialogPrimary}"
                        Visibility="Collapsed"/>
            </StackPanel>

            <ContentControl x:Name="CategoryItemsHost"/>
        </DockPanel>
    </Grid>
</UserControl>
