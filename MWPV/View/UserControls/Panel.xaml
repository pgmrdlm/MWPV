<UserControl x:Class="MWPV.View.UserControls.Panel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:uc="clr-namespace:MWPV.View.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <!-- Base split first; overlay last to sit on top -->
    <Grid x:Name="Root">

        <!-- ===== Base split (DEFAULT VIEW) ===== -->
        <Grid x:Name="SplitRoot">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="260"/>
                <ColumnDefinition Width="*" MinWidth="420"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Categories (Add Category + CategoryGrid + inline host) -->
            <DockPanel Grid.Column="0" LastChildFill="True" Margin="8,8,8,8">
                <TextBlock DockPanel.Dock="Top"
                           Text="Categories"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <Button x:Name="btnAddCategory"
                            Content="Add Category"
                            Click="btnAddCategory_Click"
                            Style="{StaticResource DialogPrimary}"/>
                </StackPanel>

                <!-- Default: visible category grid -->
                <uc:CategoryGrid x:Name="CategoryGrid"/>

                <!-- Inline Add Category host -->
                <Border x:Name="AddCategoryHost"
                        Visibility="Collapsed"
                        Background="Transparent"
                        BorderBrush="{x:Null}"
                        BorderThickness="0"
                        CornerRadius="0"
                        Padding="0"
                        Margin="0">
                    <ContentControl x:Name="AddCategoryContent"/>
                </Border>
            </DockPanel>

            <!-- RIGHT: Items (Add Item button + Items host) -->
            <DockPanel Grid.Column="1" LastChildFill="True" Margin="8,8,8,8">
                <TextBlock DockPanel.Dock="Top"
                           Text="Items"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <!-- Shown after a category is clicked -->
                    <Button x:Name="btnAddCategoryItem"
                            Content="Add Item"
                            Visibility="Collapsed"
                            Style="{StaticResource DialogPrimary}"/>
                </StackPanel>

                <ContentControl x:Name="CategoryItemsHost"/>
            </DockPanel>
        </Grid>

        <!-- ===== FULL LOGS OVERLAY ===== -->
        <Border x:Name="OverlayHost"
                Visibility="Collapsed"
                Panel.ZIndex="1000"
                Background="#00000000">
            <uc:Logs x:Name="LogsOverlay"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"/>
        </Border>

    </Grid>
</UserControl>