<UserControl x:Class="MWPV.View.UserControls.CategoryGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">

    <UserControl.Resources>

        <!-- Hide a button when its Content is null/empty.
             Based on your themed pill so the look stays consistent. -->
        <Style x:Key="HideIfBlankPill"
               TargetType="Button"
               BasedOn="{StaticResource CategoryPill}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <!-- empty string -->
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Content}"
                             Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <!-- null -->
                <Trigger Property="Content" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- If CategoryPill isn’t found for some reason, fall back to your default Button style -->
        <Style x:Key="HideIfBlankPill_Fallback"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Content}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <Trigger Property="Content" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding BoundCategories, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- one “row” of up to 3 category pills -->
                    <Grid Margin="6,8,6,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Col 1 -->
                        <Button Grid.Column="0"
                                Style="{StaticResource HideIfBlankPill}"
                                Content="{Binding strCategory1}"
                                Tag="{Binding intCategoryKey1}"
                                ToolTipService.ToolTip="{Binding strCategoryToolTip1}"
                                Click="OnCategoryButtonClick"/>

                        <!-- Spacer 1 is Grid.Column=1 -->

                        <!-- Col 2 -->
                        <Button Grid.Column="2"
                                Style="{StaticResource HideIfBlankPill}"
                                Content="{Binding strCategory2}"
                                Tag="{Binding intCategoryKey2}"
                                ToolTipService.ToolTip="{Binding strCategoryToolTip2}"
                                Click="OnCategoryButtonClick"/>

                        <!-- Spacer 2 is Grid.Column=3 -->

                        <!-- Col 3 -->
                        <Button Grid.Column="4"
                                Style="{StaticResource HideIfBlankPill}"
                                Content="{Binding strCategory3}"
                                Tag="{Binding intCategoryKey3}"
                                ToolTipService.ToolTip="{Binding strCategoryToolTip3}"
                                Click="OnCategoryButtonClick"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
