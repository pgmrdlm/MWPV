<UserControl x:Class="MWPV.View.UserControls.CategoryGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:MWPV.View.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding BoundCategories, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- one row of up to 3 pills -->
                    <Grid Margin="6,8,6,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- COL 1 -->
                        <local:CategoryCell Grid.Column="0"
                                            CategoryKey="{Binding intCategoryKey1}"
                                            CategoryName="{Binding strCategory1}"
                                            CategoryDescription="{Binding strCategoryToolTip1}"
                                            IsCategoryActive="{Binding IsActive1}"
                                            CategorySelected="OnCategorySelected"
                                            EditRequested="OnCategoryEditRequested"/>

                        <!-- COL 2 -->
                        <local:CategoryCell Grid.Column="2"
                                            CategoryKey="{Binding intCategoryKey2}"
                                            CategoryName="{Binding strCategory2}"
                                            CategoryDescription="{Binding strCategoryToolTip2}"
                                            IsCategoryActive="{Binding IsActive2}"
                                            CategorySelected="OnCategorySelected"
                                            EditRequested="OnCategoryEditRequested"/>

                        <!-- COL 3 -->
                        <local:CategoryCell Grid.Column="4"
                                            CategoryKey="{Binding intCategoryKey3}"
                                            CategoryName="{Binding strCategory3}"
                                            CategoryDescription="{Binding strCategoryToolTip3}"
                                            IsCategoryActive="{Binding IsActive3}"
                                            CategorySelected="OnCategorySelected"
                                            EditRequested="OnCategoryEditRequested"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
