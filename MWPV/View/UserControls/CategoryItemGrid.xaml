<!-- File: View/UserControls/CategoryItemGrid.xaml
     FULL REWRITE

     Purpose:
     - Shows Category Items as 3 “pill” buttons per row (Col1/Col2/Col3).
     - Each pill collapses if its *text content* is null/empty.
     - Visible text is trimmed (ellipsis) and cropped for display.
     - Full value is available via ToolTip on mouse-over.
     - Click bubbles to ItemPill_Click in code-behind.

     Notes:
     - Expects a parent style resource named "ItemPill" to exist (app/theme).
     - ItemsSource binds to BoundCategoryItems on this UserControl (DP/property in code-behind).
-->

<UserControl x:Class="MWPV.View.UserControls.CategoryItemGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:MWPV.View.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="600">

    <UserControl.Resources>

        <!-- Crops display text (converter already in your codebase per CategoryGrid pattern) -->
        <local:CategoryCropConverter x:Key="CategoryCrop" />

        <!-- Collapses the pill if the TextBlock inside Content is null/empty; keeps ItemPill look -->
        <Style x:Key="ItemPillWhenNotEmpty"
               TargetType="Button"
               BasedOn="{StaticResource ItemPill}">
            <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            <Setter Property="Visibility" Value="Visible"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Content.Text}"
                             Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Content.Text}"
                             Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Optional fallback if ItemPill is not present -->
        <Style x:Key="ItemPillWhenNotEmpty_Fallback"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Content.Text}"
                             Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Content.Text}"
                             Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding BoundCategoryItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="6,8,6,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Pill 1 -->
                        <Button Grid.Column="0"
                                Tag="{Binding strCategoryItemKey1}"
                                Click="ItemPill_Click"
                                AutomationProperties.Name="{Binding strCategoryItem1}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ItemPillWhenNotEmpty}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive1}" Value="False">
                                            <Setter Property="Opacity" Value="0.55"/>
                                            <Setter Property="Foreground" Value="#666666"/>
                                            <Setter Property="Background" Value="#E5E5E5"/>
                                            <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Content>
                                <TextBlock Text="{Binding strCategoryItem1, Converter={StaticResource CategoryCrop}, ConverterParameter=17}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           HorizontalAlignment="Center"/>
                            </Button.Content>
                            <Button.ToolTip>
                                <StackPanel>
                                    <TextBlock Text="{Binding strCategoryItem1}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding strCategoryItemToolTip1}"/>
                                </StackPanel>
                            </Button.ToolTip>
                        </Button>

                        <!-- Pill 2 -->
                        <Button Grid.Column="2"
                                Tag="{Binding strCategoryItemKey2}"
                                Click="ItemPill_Click"
                                AutomationProperties.Name="{Binding strCategoryItem2}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ItemPillWhenNotEmpty}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive2}" Value="False">
                                            <Setter Property="Opacity" Value="0.55"/>
                                            <Setter Property="Foreground" Value="#666666"/>
                                            <Setter Property="Background" Value="#E5E5E5"/>
                                            <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Content>
                                <TextBlock Text="{Binding strCategoryItem2, Converter={StaticResource CategoryCrop}, ConverterParameter=17}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           HorizontalAlignment="Center"/>
                            </Button.Content>
                            <Button.ToolTip>
                                <StackPanel>
                                    <TextBlock Text="{Binding strCategoryItem2}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding strCategoryItemToolTip2}"/>
                                </StackPanel>
                            </Button.ToolTip>
                        </Button>

                        <!-- Pill 3 -->
                        <Button Grid.Column="4"
                                Tag="{Binding strCategoryItemKey3}"
                                Click="ItemPill_Click"
                                AutomationProperties.Name="{Binding strCategoryItem3}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ItemPillWhenNotEmpty}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive3}" Value="False">
                                            <Setter Property="Opacity" Value="0.55"/>
                                            <Setter Property="Foreground" Value="#666666"/>
                                            <Setter Property="Background" Value="#E5E5E5"/>
                                            <Setter Property="BorderBrush" Value="#A0A0A0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Content>
                                <TextBlock Text="{Binding strCategoryItem3, Converter={StaticResource CategoryCrop}, ConverterParameter=17}"
                                           TextTrimming="CharacterEllipsis"
                                           TextWrapping="NoWrap"
                                           HorizontalAlignment="Center"/>
                            </Button.Content>
                            <Button.ToolTip>
                                <StackPanel>
                                    <TextBlock Text="{Binding strCategoryItem3}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding strCategoryItemToolTip3}"/>
                                </StackPanel>
                            </Button.ToolTip>
                        </Button>

                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>

</UserControl>
