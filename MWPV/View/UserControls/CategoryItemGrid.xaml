<UserControl x:Class="MWPV.View.UserControls.CategoryItemGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">

    <UserControl.Resources>

        <!-- EXACT COPY of CategoryGrid’s HideIfBlankPill -->
        <Style x:Key="HideIfBlankPill"
               TargetType="Button"
               BasedOn="{StaticResource CategoryPill}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <!-- empty string -->
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Content}"
                             Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <!-- null -->
                <Trigger Property="Content" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- EXACT COPY fallback (if CategoryPill not found) -->
        <Style x:Key="HideIfBlankPill_Fallback"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Content}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <Trigger Property="Content" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <!-- IMPORTANT: use BoundCategoryItems (mirrors BoundCategories pattern) -->
        <ItemsControl ItemsSource="{Binding BoundCategoryItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- one “row” of up to 3 item pills, same grid pattern as CategoryGrid -->
                    <Grid Margin="6,8,6,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Col 1 -->
                        <Button Grid.Column="0"
                                Style="{StaticResource ItemPill}"
                                Content="{Binding strCategoryItem1}"
                                Tag="{Binding strCategoryItemKey1}"
                                ToolTipService.ToolTip="{Binding strCategoryItemToolTip1}"/>

                        <!-- Spacer 1 is Grid.Column=1 -->

                        <!-- Col 2 -->
                        <Button Grid.Column="2"
                                Style="{StaticResource ItemPill}"
                                Content="{Binding strCategoryItem2}"
                                Tag="{Binding strCategoryItemKey2}"
                                ToolTipService.ToolTip="{Binding strCategoryItemToolTip2}"/>

                        <!-- Spacer 2 is Grid.Column=3 -->

                        <!-- Col 3 -->
                        <Button Grid.Column="4"
                                Style="{StaticResource ItemPill}"
                                Content="{Binding strCategoryItem3}"
                                Tag="{Binding strCategoryItemKey3}"
                                ToolTipService.ToolTip="{Binding strCategoryItemToolTip3}"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
