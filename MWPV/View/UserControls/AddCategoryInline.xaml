<UserControl x:Class="MWPV.View.UserControls.AddCategoryInline"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource Brush.Primary}" Padding="12,0,6,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="16"
                           Text="Add New Category"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- FORM -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name -->
                <Label Grid.Row="0" Grid.Column="0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Content="Category Name:"/>
                <TextBox x:Name="tbCategoryName"
                         Grid.Row="0" Grid.Column="2"
                         Height="28"
                         MaxLength="64"
                         Background="White"
                         Foreground="Black"
                         Margin="0"
                         TextChanged="tbCategoryName_TextChanged"/>

                <!-- Live preview -->
                <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="#666" FontStyle="Italic" Text="Preview: " />
                    <TextBlock Text="{Binding ElementName=tbCategoryName, Path=Text}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               MaxWidth="160"
                               Foreground="#666" />
                </StackPanel>

                <!-- Category Type -->
                <Label Grid.Row="4" Grid.Column="0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Content="Category Type:"/>

                <Border Grid.Row="4" Grid.Column="2"
                        CornerRadius="4"
                        Background="Transparent"
                        BorderBrush="#8A8A8A"
                        BorderThickness="1"
                        Height="28">
                    <ComboBox x:Name="cmbCategoryType"
                              Background="Transparent"
                              BorderThickness="0"
                              VerticalAlignment="Center"
                              DisplayMemberPath="Description"
                              SelectedValuePath="Code"
                              Style="{StaticResource FilterComboStyle}"
                              MaxDropDownHeight="360"/>
                </Border>

                <!-- Description -->
                <Label Grid.Row="6" Grid.Column="0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       FontWeight="Bold"
                       Content="Category Description:"/>
                <TextBox x:Name="tbCategoryDescription"
                         Grid.Row="6" Grid.Column="2"
                         Height="220"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MaxLength="512"
                         Background="White"
                         Foreground="Black"
                         TextChanged="tbCategoryDescription_TextChanged"/>
            </Grid>

            <!-- Error line -->
            <TextBlock x:Name="txtErrorMessage"
                       Grid.Row="2"
                       Foreground="Red"
                       FontWeight="Bold"
                       Visibility="Collapsed"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnAddCategory"
                        Style="{StaticResource DialogPrimary}"
                        IsDefault="True"
                        Click="btnAddCategory_Click"
                        Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FB;" Margin="0,0,8,0"/>
                        <TextBlock Text="Submit"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnCancel"
                        Style="{StaticResource DialogSecondary}"
                        IsCancel="True"
                        Click="btnCancel_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" Margin="0,0,8,0"/>
                        <TextBlock Text="Cancel"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
