<UserControl x:Class="MWPV.View.UserControls.AddCategoryInline"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Primary}" Padding="12,0,6,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="txtHeader"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="16"
                           Text="Add New Category"/>
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Form -->
                <RowDefinition Height="10"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Error line -->
                <RowDefinition Height="16"/>
                <!-- Spacer -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
                <RowDefinition Height="*"/>
                <!-- Filler -->
            </Grid.RowDefinitions>

            <!-- FORM -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 0: Name -->
                    <RowDefinition Height="6"/>
                    <!-- 1: spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- 2: Preview -->
                    <RowDefinition Height="10"/>
                    <!-- 3: spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- 4: Description -->
                </Grid.RowDefinitions>

                <!-- Name -->
                <Label Grid.Row="0" Grid.Column="0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Content="Category Name:"/>
                <TextBox x:Name="tbCategoryName"
                         Grid.Row="0" Grid.Column="2"
                         Height="28"
                         MaxLength="64"
                         Background="White"
                         Foreground="Black"
                         Margin="0"
                         TextChanged="tbCategoryName_TextChanged"/>

                <!-- Live preview -->
                <StackPanel Grid.Row="2" Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Foreground="#666"
                               FontStyle="Italic"
                               Text="Preview: " />
                    <TextBlock Text="{Binding ElementName=tbCategoryName, Path=Text}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               MaxWidth="160"
                               Foreground="#666" />
                </StackPanel>

                <!-- Description -->
                <Label Grid.Row="4" Grid.Column="0"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       FontWeight="Bold"
                       Content="Category Description:"/>
                <TextBox x:Name="tbCategoryDescription"
                         Grid.Row="4" Grid.Column="2"
                         Height="220"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MaxLength="512"
                         Background="White"
                         Foreground="Black"
                         TextChanged="tbCategoryDescription_TextChanged"/>
            </Grid>

            <!-- Error line -->
            <TextBlock x:Name="txtErrorMessage"
                       Grid.Row="2"
                       Foreground="Red"
                       FontWeight="Bold"
                       Visibility="Collapsed"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button x:Name="btnAddCategory"
                        Style="{StaticResource DialogPrimary}"
                        IsDefault="True"
                        Click="btnAddCategory_Click"
                        Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE8FB;"
                                   Margin="0,0,8,0"/>
                        <TextBlock x:Name="txtSubmitCaption" Text="Submit"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnDeactivateCategory"
                        Style="{StaticResource DialogDanger}"
                        Click="btnDeactivateCategory_Click"
                        Visibility="Collapsed"
                        Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE74D;"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Deactivate"/>
                    </StackPanel>
                </Button>

                <Button x:Name="btnCancel"
                        Style="{StaticResource DialogSecondary}"
                        IsCancel="True"
                        Click="btnCancel_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE711;"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Cancel"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
