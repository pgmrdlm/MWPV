<UserControl x:Class="MWPV.View.UserControls.CategoryitemEditNew"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="940"
             Focusable="True">

    <!-- Full overlay with branded background -->
    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Primary}"
                Padding="12,0,6,0">
            <TextBlock VerticalAlignment="Center"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Text="Add / Edit Category Item"/>
        </Border>

        <!-- Scrollable Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="160"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Row 0 -->
                <Label Grid.Row="0" Grid.Column="0" Content="Category Item Name" FontWeight="Bold"/>
                <TextBox x:Name="txtItemName" Grid.Row="0" Grid.Column="0" Margin="0,22,0,0" Height="28"
                         Background="White" Foreground="Black"/>

                <Label Grid.Row="0" Grid.Column="2" Content="Password" FontWeight="Bold"/>
                <PasswordBox x:Name="pwdPassword" Grid.Row="0" Grid.Column="2" Margin="0,22,0,0" Height="28"/>

                <Label Grid.Row="0" Grid.Column="4" Content="URL or Absolute Location" FontWeight="Bold"/>
                <TextBox x:Name="txtUrl" Grid.Row="0" Grid.Column="4" Margin="0,22,0,0" Height="28"
                         Background="White" Foreground="Black"/>

                <!-- Row 2 -->
                <Label Grid.Row="2" Grid.Column="0" Content="User Name" FontWeight="Bold"/>
                <TextBox x:Name="txtUsername" Grid.Row="2" Grid.Column="0" Margin="0,22,0,0" Height="28"
                         Background="White" Foreground="Black"/>

                <Label Grid.Row="2" Grid.Column="2" Content="Item Type" FontWeight="Bold"/>
                <Border Grid.Row="2" Grid.Column="2" Margin="0,22,0,0" Height="28"
                        CornerRadius="4" Background="Transparent" BorderBrush="#8A8A8A" BorderThickness="1">
                    <ComboBox x:Name="cboItemType"
                              Background="Transparent"
                              BorderThickness="0"
                              IsEditable="True"
                              Style="{StaticResource FilterComboStyle}"/>
                </Border>

                <Label Grid.Row="2" Grid.Column="4" Content="Email" FontWeight="Bold"/>
                <TextBox x:Name="txtEmail" Grid.Row="2" Grid.Column="4" Margin="0,22,0,0" Height="28"
                         Background="White" Foreground="Black"/>

                <!-- Row 4 -->
                <Label Grid.Row="4" Grid.Column="0" Content="Phone Number" FontWeight="Bold"/>
                <TextBox x:Name="txtPhone" Grid.Row="4" Grid.Column="0" Margin="0,22,0,0" Height="28"
                         Background="White" Foreground="Black"/>

                <Label Grid.Row="4" Grid.Column="2" Content="Security Question" FontWeight="Bold"/>
                <TextBox x:Name="txtSecQuestion" Grid.Row="4" Grid.Column="2" Margin="0,22,0,0" Height="28"
                         Background="White" Foreground="Black"/>

                <Label Grid.Row="4" Grid.Column="4" Content="Security Answer" FontWeight="Bold"/>
                <TextBox x:Name="txtSecAnswer" Grid.Row="4" Grid.Column="4" Margin="0,22,0,0" Height="28"
                         Background="White" Foreground="Black"/>

                <!-- Notes -->
                <Label Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="5"
                       Content="Freeform Notes" FontWeight="Bold"/>
                <TextBox x:Name="txtDescription" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="5"
                         Margin="0,22,0,0"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="White" Foreground="Black"/>

                <!-- Bank Section -->
                <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="5"
                           Text="Bank Cards / Accounts"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- Row 10 -->
                <Label Grid.Row="10" Grid.Column="0" Content="Card Type"/>
                <Border Grid.Row="10" Grid.Column="0" Margin="0,22,0,0" Height="28"
                        CornerRadius="4" Background="Transparent" BorderBrush="#8A8A8A" BorderThickness="1">
                    <ComboBox x:Name="cboCardType"
                              Background="Transparent" BorderThickness="0"
                              Style="{StaticResource FilterComboStyle}"/>
                </Border>

                <Label Grid.Row="10" Grid.Column="2" Content="Expiration Date"/>
                <TextBox x:Name="txtExpDate" Grid.Row="10" Grid.Column="2" Margin="0,22,0,0" Height="28"
                         Background="White" Foreground="Black"/>

                <Label Grid.Row="10" Grid.Column="4" Content="CVS Code"/>
                <TextBox x:Name="txtCvv" Grid.Row="10" Grid.Column="4" Margin="0,22,0,0" Height="28"
                         Background="White" Foreground="Black"/>

                <!-- Row 12 -->
                <Label Grid.Row="12" Grid.Column="0" Content="Account Name"/>
                <Border Grid.Row="12" Grid.Column="0" Margin="0,22,0,0" Height="28"
                        CornerRadius="4" Background="Transparent" BorderBrush="#8A8A8A" BorderThickness="1">
                    <ComboBox x:Name="cboAccountName"
                              Background="Transparent" BorderThickness="0"
                              Style="{StaticResource FilterComboStyle}"/>
                </Border>

                <Label Grid.Row="12" Grid.Column="2" Content="Account Number"/>
                <TextBox x:Name="txtAccountNumber" Grid.Row="12" Grid.Column="2" Margin="0,22,0,0" Height="28"
                         Background="White" Foreground="Black"/>

                <Label Grid.Row="12" Grid.Column="4" Content="PIN"/>
                <TextBox x:Name="txtPin" Grid.Row="12" Grid.Column="4" Margin="0,22,0,0" Height="28"
                         Background="White" Foreground="Black"/>
            </Grid>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnSubmit"
                    Style="{StaticResource DialogPrimary}"
                    Margin="0,0,12,0"
                    Click="btnSubmit_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FB;" Margin="0,0,8,0"/>
                    <TextBlock Text="Submit"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCancel"
                    Style="{StaticResource DialogSecondary}"
                    Click="btnCancel_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" Margin="0,0,8,0"/>
                    <TextBlock Text="Cancel"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
