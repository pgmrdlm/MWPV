<UserControl x:Class="MWPV.View.UserControls.CategoryitemEditNew"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="940"
             Focusable="True">

    <UserControl.Resources>
        <Style x:Key="SmallSquarePrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="4"
                                Background="{DynamicResource PrimaryNormalBrush}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DisabledBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource Brush.Primary}" Padding="12,0,6,0">
            <TextBlock VerticalAlignment="Center" Foreground="White" FontWeight="SemiBold" FontSize="16" Text="Add / Edit Category Item"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="True" PanningMode="VerticalOnly" Focusable="False">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="160"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Row 0 -->
                <Label Grid.Row="0" Grid.Column="0" Content="Category Item Name" FontWeight="Bold"/>
                <TextBox x:Name="txtItemName"
                         Grid.Row="0" Grid.Column="0" Margin="0,22,0,0"
                         Height="28" MinWidth="320" HorizontalAlignment="Left"
                         Background="White" Foreground="Black"/>

                <Label Grid.Row="0" Grid.Column="2" Content="Password" FontWeight="Bold"/>
                <Grid Grid.Row="0" Grid.Column="2" Margin="0,22,0,0" Height="28" MinWidth="280" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <PasswordBox x:Name="pwdPassword" Grid.Column="0" VerticalAlignment="Center" Height="28"/>

                    <Button x:Name="btnGeneratePassword"
                            Grid.Column="1"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Generate password"
                            Click="BtnGeneratePassword_Click">
                        <Viewbox Stretch="Uniform">
                            <Canvas Width="18" Height="18">
                                <Path Fill="Black"
                                      Data="M9,1.6 L10.1,5.3 13.6,4.2 11.6,7.3 15.4,8.4 11.6,9.5 13.6,12.6 10.1,11.5 9,15.2 7.9,11.5 4.4,12.6 6.4,9.5 2.6,8.4 6.4,7.3 4.4,4.2 7.9,5.3 z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button x:Name="btnTogglePasswordReveal"
                            Grid.Column="2"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Show/Hide password"
                            Click="BtnTogglePasswordReveal_Click">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="20" Height="20">
                                <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                      Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2"
                                         Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Ellipse Width="3" Height="3" Fill="Black"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Viewbox>
                    </Button>
                </Grid>

                <Label Grid.Row="0" Grid.Column="4" Content="URL or Absolute Location" FontWeight="Bold"/>
                <TextBox x:Name="txtUrl"
                         Grid.Row="0" Grid.Column="4" Margin="0,22,0,0"
                         Height="28" MinWidth="220"
                         Background="White" Foreground="Black"/>

                <!-- Row 2 -->
                <Label Grid.Row="2" Grid.Column="0" Content="User Name" FontWeight="Bold"/>
                <TextBox x:Name="txtUsername"
                         Grid.Row="2" Grid.Column="0" Margin="0,22,0,0"
                         Height="28" MinWidth="240" HorizontalAlignment="Left"
                         Background="White" Foreground="Black"/>

                <Label Grid.Row="2" Grid.Column="2" Content="Email" FontWeight="Bold"/>
                <TextBox x:Name="txtEmail"
                         Grid.Row="2" Grid.Column="2" Margin="0,22,0,0"
                         Height="28" MinWidth="240" HorizontalAlignment="Left"
                         Background="White" Foreground="Black"/>

                <!-- Row 4 -->
                <Label Grid.Row="4" Grid.Column="0" Content="Phone Number" FontWeight="Bold"/>
                <TextBox x:Name="txtPhone"
                         Grid.Row="4" Grid.Column="0" Margin="0,22,0,0"
                         Height="28" MinWidth="180" HorizontalAlignment="Left"
                         Background="White" Foreground="Black"/>

                <Label Grid.Row="4" Grid.Column="2" Content="Security Question" FontWeight="Bold"/>
                <TextBox x:Name="txtSecQuestion"
                         Grid.Row="4" Grid.Column="2" Margin="0,22,0,0"
                         Height="28" Background="White" Foreground="Black"/>

                <Label Grid.Row="4" Grid.Column="4" Content="Security Answer" FontWeight="Bold"/>
                <TextBox x:Name="txtSecAnswer"
                         Grid.Row="4" Grid.Column="4" Margin="0,22,0,0"
                         Height="28" Width="320" MinWidth="220"
                         HorizontalAlignment="Left"
                         Background="White" Foreground="Black"/>

                <!-- Notes -->
                <Label Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="5" Content="Freeform Notes" FontWeight="Bold"/>
                <TextBox x:Name="txtDescription"
                         Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="5" Margin="0,22,0,0"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Background="White" Foreground="Black"/>

                <!-- Bank -->
                <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="5"
                           Text="Bank Cards / Accounts" FontWeight="SemiBold" Margin="0,0,0,8"/>

                <Label Grid.Row="10" Grid.Column="0" Content="Card Type"/>
                <Border Grid.Row="10" Grid.Column="0" Margin="0,22,0,0" Height="28"
                        CornerRadius="4" Background="Transparent" BorderBrush="#8A8A8A" BorderThickness="1">
                    <ComboBox x:Name="cboCardType" Background="Transparent" BorderThickness="0"
                              Style="{StaticResource FilterComboStyle}"/>
                </Border>

                <Label Grid.Row="10" Grid.Column="2" Content="Expiration Date"/>
                <TextBox x:Name="txtExpDate"
                         Grid.Row="10" Grid.Column="2" Margin="0,22,0,0"
                         Height="28" Background="White" Foreground="Black"/>

                <Label Grid.Row="10" Grid.Column="4" Content="CVS Code"/>
                <TextBox x:Name="txtCvv"
                         Grid.Row="10" Grid.Column="4" Margin="0,22,0,0"
                         Height="28" Background="White" Foreground="Black"/>

                <Label Grid.Row="12" Grid.Column="0" Content="Account Name"/>
                <Border Grid.Row="12" Grid.Column="0" Margin="0,22,0,0" Height="28"
                        CornerRadius="4" Background="Transparent" BorderBrush="#8A8A8A" BorderThickness="1">
                    <ComboBox x:Name="cboAccountName" Background="Transparent" BorderThickness="0"
                              Style="{StaticResource FilterComboStyle}"/>
                </Border>

                <Label Grid.Row="12" Grid.Column="2" Content="Account Number"/>
                <TextBox x:Name="txtAccountNumber"
                         Grid.Row="12" Grid.Column="2" Margin="0,22,0,0"
                         Height="28" Background="White" Foreground="Black"/>

                <Label Grid.Row="12" Grid.Column="4" Content="PIN"/>
                <TextBox x:Name="txtPin"
                         Grid.Row="12" Grid.Column="4" Margin="0,22,0,0"
                         Height="28" Background="White" Foreground="Black"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnSubmit" Style="{StaticResource DialogPrimary}" Margin="0,0,12,0" Click="btnSubmit_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FB;" Margin="0,0,8,0"/>
                    <TextBlock Text="Submit"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCancel" Style="{StaticResource DialogSecondary}" Click="btnCancel_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" Margin="0,0,8,0"/>
                    <TextBlock Text="Cancel"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
