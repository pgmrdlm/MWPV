<UserControl x:Class="MWPV.View.UserControls.CategoryitemEditNew"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1100"
             Background="Transparent">

    <!-- Use your body surface if present -->
    <Grid Background="{DynamicResource Brush.BrandSecondary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top button bar -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.BrandChrome}" Padding="12,6">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="btnSaveAndExit"
                            Style="{StaticResource DialogPrimary}"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74E;" Margin="0,0,8,0"/>
                            <TextBlock Text="Save &amp; Exit"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnClear"
                            Style="{StaticResource DialogSecondary}"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" Margin="0,0,8,0"/>
                            <TextBlock Text="Clear"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnExit"
                            Style="{StaticResource DialogSecondary}"
                            IsCancel="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" Margin="0,0,8,0"/>
                            <TextBlock Text="Exit"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Column 1 -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Category Item Name" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox x:Name="tbCI_Name" Height="28" MaxLength="128" Margin="0,0,0,10"/>

                    <TextBlock Text="User Name" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox x:Name="tbCI_Username" Height="28" MaxLength="128" Margin="0,0,0,10"/>

                    <TextBlock Text="Phone Number" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox x:Name="tbCI_PhoneNumber" Height="28" MaxLength="64" Margin="0,0,0,10"/>

                    <TextBlock Text="Freeform Notes" FontWeight="Bold" Margin="0,6,0,6"/>
                    <TextBox x:Name="tbCI_FreeformNotes"
                             Height="220"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MaxLength="4000"
                             Margin="0,0,0,10"/>
                </StackPanel>

                <!-- Column 2 -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Category Item Description" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox x:Name="tbCI_Description" Height="28" MaxLength="256" Margin="0,0,0,10"/>

                    <TextBlock Text="Password" FontWeight="Bold" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="pbCI_Password" Height="28" Margin="0,0,0,10"/>

                    <TextBlock Text="Security Question" FontWeight="Bold" Margin="0,0,0,6"/>
                    <DockPanel LastChildFill="False" Margin="0,0,0,10">
                        <TextBox x:Name="tbCI_SecurityQuestion" Height="28" MaxLength="256" DockPanel.Dock="Left" Width="Auto" MinWidth="200"/>
                        <Button x:Name="btnAddSecurityQA"
                                Style="{StaticResource DialogSecondary}"
                                Margin="8,0,0,0">
                            <TextBlock Text="+" FontSize="16" VerticalAlignment="Center"/>
                        </Button>
                    </DockPanel>

                    <TextBlock Text="Security Answer" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox x:Name="tbCI_SecurityAnswer" Height="28" MaxLength="256" Margin="0,0,0,10"/>
                </StackPanel>

                <!-- Column 3 -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="URL or Absolute Location" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox x:Name="tbCI_SignInUrl" Height="28" MaxLength="512" Margin="0,0,0,10"/>

                    <TextBlock Text="Email" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox x:Name="tbCI_Email" Height="28" MaxLength="128" Margin="0,0,0,10"/>

                    <Separator Margin="0,10,0,6"/>
                    <TextBlock Text="Bank Cards" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>

                    <TextBlock Text="Card Type" Margin="0,0,0,4"/>
                    <Border CornerRadius="4" Background="Transparent" BorderBrush="#8A8A8A" BorderThickness="1" Height="28" Margin="0,0,0,10">
                        <ComboBox x:Name="cmbCardType"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource FilterComboStyle}"
                                  MaxDropDownHeight="360"/>
                    </Border>

                    <TextBlock Text="Expiration Date" Margin="0,0,0,4"/>
                    <TextBox x:Name="tbCardExpiration" Height="28" MaxLength="10" Margin="0,0,0,10" ToolTip="MM/YY or MM/YYYY"/>

                    <TextBlock Text="CVS Code" Margin="0,0,0,4"/>
                    <TextBox x:Name="tbCardCvs" Height="28" MaxLength="4" Margin="0,0,0,10"/>

                    <TextBlock Text="PIN" Margin="0,0,0,4"/>
                    <DockPanel LastChildFill="False" Margin="0,0,0,10">
                        <TextBox x:Name="tbCardPin" Height="28" MaxLength="12" DockPanel.Dock="Left" Width="Auto" MinWidth="120"/>
                        <Button x:Name="btnAddCard"
                                Style="{StaticResource DialogSecondary}"
                                Margin="8,0,0,0">
                            <TextBlock Text="+" FontSize="16" VerticalAlignment="Center"/>
                        </Button>
                    </DockPanel>

                    <Separator Margin="0,10,0,6"/>
                    <TextBlock Text="Account Numbers" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>

                    <TextBlock Text="Account Name" Margin="0,0,0,4"/>
                    <Border CornerRadius="4" Background="Transparent" BorderBrush="#8A8A8A" BorderThickness="1" Height="28" Margin="0,0,0,10">
                        <ComboBox x:Name="cmbAccountName"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource FilterComboStyle}"
                                  MaxDropDownHeight="360"/>
                    </Border>

                    <TextBlock Text="Account Number" Margin="0,0,0,4"/>
                    <TextBox x:Name="tbAccountNumber" Height="28" MaxLength="64" Margin="0,0,0,10"/>

                    <TextBlock Text="CVS Code" Margin="0,0,0,4"/>
                    <TextBox x:Name="tbAccountCvs" Height="28" MaxLength="8" Margin="0,0,0,10"/>

                    <Button x:Name="btnAddAccount"
                            Style="{StaticResource DialogSecondary}"
                            Margin="0,6,0,0">
                        <TextBlock Text="+ Add Account"/>
                    </Button>
                </StackPanel>

                <!-- Error line -->
                <TextBlock x:Name="txtErrorMessage"
                           Grid.ColumnSpan="5"
                           Margin="0,16,0,0"
                           Foreground="Red"
                           FontWeight="Bold"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
