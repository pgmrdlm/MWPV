<UserControl x:Class="MWPV.View.UserControls.CategoryItemDetail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="980" d:DesignHeight="720">

    <UserControl.Resources>

        <!-- Section/Header + Label styles (use your themed brushes if present) -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,24,0,6"/>
            <!-- if Brush.BrandChrome exists, great; else it falls back at runtime -->
            <Setter Property="Foreground" Value="{StaticResource Brush.BrandChrome}"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,6,12,6"/>
            <!-- themed text color -->
            <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
        </Style>

        <!-- Masked/readonly textbox uses your neutral/secondary surface -->
        <Style x:Key="MaskedBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <!-- prefer SecondaryNormalBrush (LocalBrushes), otherwise brand secondary -->
            <Setter Property="Background" Value="{DynamicResource SecondaryNormalBrush}"/>
            <Setter Property="ToolTip" Value="Encrypted / masked value"/>
        </Style>

        <Style x:Key="PlainBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <!-- Tiny inline square icon button for row actions (local so it never 404s) -->
        <Style x:Key="InlineSquareButton" TargetType="Button">
            <Setter Property="Width"  Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Background"     Value="{DynamicResource SecondaryNormalBrush}"/>
            <Setter Property="BorderBrush"    Value="{DynamicResource ShadowStroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Border x:Name="HoverOverlay"  CornerRadius="4" Background="#40FFFFFF" Opacity="0"/>
                                <Border x:Name="PressedOverlay" CornerRadius="4" Background="#20000000" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.18"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PressedOverlay" Property="Opacity" Value="0.22"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DisabledBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Reusable Copy / View buttons (glyph-only) -->
        <DataTemplate x:Key="ActionButtonsTemplate">
            <StackPanel Orientation="Horizontal">
                <!-- Copy -->
                <Button Style="{StaticResource InlineSquareButton}" ToolTip="Copy">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;"/>
                </Button>
                <!-- View (eye) -->
                <Button Style="{StaticResource InlineSquareButton}" ToolTip="Show">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE890;"/>
                </Button>
            </StackPanel>
        </DataTemplate>

    </UserControl.Resources>

    <!-- Use your body surface if present -->
    <Grid Background="{DynamicResource Brush.BrandSecondary}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ********** REQUIRED FIX: define all rows you reference below ********** -->
                <Grid.RowDefinitions>
                    <!-- 0..27 used below -->
                    <RowDefinition Height="Auto"/>
                    <!-- 0  : Basic header -->
                    <RowDefinition Height="Auto"/>
                    <!-- 1  : Name -->
                    <RowDefinition Height="Auto"/>
                    <!-- 2  : Description -->
                    <RowDefinition Height="Auto"/>
                    <!-- 3  : Sign-in URL -->
                    <RowDefinition Height="Auto"/>
                    <!-- 4  : Username -->
                    <RowDefinition Height="Auto"/>
                    <!-- 5  : (spacer if needed) -->
                    <RowDefinition Height="Auto"/>
                    <!-- 6  : Password header -->
                    <RowDefinition Height="Auto"/>
                    <!-- 7  : Password masked -->
                    <RowDefinition Height="Auto"/>
                    <!-- 8  : Password plain -->
                    <RowDefinition Height="Auto"/>
                    <!-- 9  : (spacer) -->
                    <RowDefinition Height="Auto"/>
                    <!-- 10 : Account Email header -->
                    <RowDefinition Height="Auto"/>
                    <!-- 11 : Email masked -->
                    <RowDefinition Height="Auto"/>
                    <!-- 12 : Email plain -->
                    <RowDefinition Height="Auto"/>
                    <!-- 13 : (spacer) -->
                    <RowDefinition Height="Auto"/>
                    <!-- 14 : Phone header -->
                    <RowDefinition Height="Auto"/>
                    <!-- 15 : Phone masked -->
                    <RowDefinition Height="Auto"/>
                    <!-- 16 : Phone plain -->
                    <RowDefinition Height="Auto"/>
                    <!-- 17 : (spacer) -->
                    <RowDefinition Height="Auto"/>
                    <!-- 18 : Secret Data header -->
                    <RowDefinition Height="Auto"/>
                    <!-- 19 : Secret masked -->
                    <RowDefinition Height="Auto"/>
                    <!-- 20 : Secret plain -->
                    <RowDefinition Height="Auto"/>
                    <!-- 21 : (spacer) -->
                    <RowDefinition Height="Auto"/>
                    <!-- 22 : Security Questions header -->
                    <RowDefinition Height="Auto"/>
                    <!-- 23 : Security Questions repeater -->
                    <RowDefinition Height="Auto"/>
                    <!-- 24 : Add Question button row -->
                    <RowDefinition Height="Auto"/>
                    <!-- 25 : (spacer) -->
                    <RowDefinition Height="Auto"/>
                    <!-- 26 : Bank Cards header -->
                    <RowDefinition Height="Auto"/>
                    <!-- 27 : Bank Cards note -->
                </Grid.RowDefinitions>
                <!-- ********** END REQUIRED FIX ********** -->

                <!-- ======== Header: Basic Info ======== -->
                <TextBlock Grid.ColumnSpan="3" Text="Basic" Style="{StaticResource SectionHeader}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Name" Style="{StaticResource FieldLabel}"/>
                <TextBox   Grid.Row="1" Grid.Column="1"
                           Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Description" Style="{StaticResource FieldLabel}"/>
                <TextBox   Grid.Row="2" Grid.Column="1"
                           Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Sign-in URL" Style="{StaticResource FieldLabel}"/>
                <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding SignInUrl, Mode=TwoWay}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Username" Style="{StaticResource FieldLabel}"/>
                <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding Username, Mode=TwoWay}"/>

                <!-- ======== Password (history-backed) ======== -->
                <TextBlock Grid.Row="6" Grid.ColumnSpan="3" Text="Password" Style="{StaticResource SectionHeader}"/>

                <!-- Masked/encrypted value -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Masking" Style="{StaticResource FieldLabel}"/>
                <TextBox   Grid.Row="7" Grid.Column="1" Style="{StaticResource MaskedBox}"
                           Text="{Binding EncryptedPassword}"/>
                <ContentControl Grid.Row="7" Grid.Column="2" ContentTemplate="{StaticResource ActionButtonsTemplate}"/>

                <!-- Plaintext value (hidden until reveal) -->
                <TextBox Grid.Row="8" Grid.Column="1" Style="{StaticResource PlainBox}"
                         Text="{Binding PlainPassword, Mode=TwoWay}" Visibility="Collapsed"/>

                <!-- ======== Account Email ======== -->
                <TextBlock Grid.Row="10" Grid.ColumnSpan="3" Text="Account Email" Style="{StaticResource SectionHeader}"/>

                <TextBlock Grid.Row="11" Grid.Column="0" Text="Masking" Style="{StaticResource FieldLabel}"/>
                <TextBox   Grid.Row="11" Grid.Column="1" Style="{StaticResource MaskedBox}"
                           Text="{Binding EncryptedAccountEmail}"/>
                <ContentControl Grid.Row="11" Grid.Column="2" ContentTemplate="{StaticResource ActionButtonsTemplate}"/>
                <TextBox   Grid.Row="12" Grid.Column="1" Style="{StaticResource PlainBox}"
                           Text="{Binding PlainAccountEmail, Mode=TwoWay}" Visibility="Collapsed"/>

                <!-- ======== Phone ======== -->
                <TextBlock Grid.Row="14" Grid.ColumnSpan="3" Text="Account Phone" Style="{StaticResource SectionHeader}"/>

                <TextBlock Grid.Row="15" Grid.Column="0" Text="Masking" Style="{StaticResource FieldLabel}"/>
                <TextBox   Grid.Row="15" Grid.Column="1" Style="{StaticResource MaskedBox}"
                           Text="{Binding EncryptedPhone}"/>
                <ContentControl Grid.Row="15" Grid.Column="2" ContentTemplate="{StaticResource ActionButtonsTemplate}"/>
                <TextBox   Grid.Row="16" Grid.Column="1" Style="{StaticResource PlainBox}"
                           Text="{Binding PlainPhone, Mode=TwoWay}" Visibility="Collapsed"/>

                <!-- ======== Secret Data (JSON) ======== -->
                <TextBlock Grid.Row="18" Grid.ColumnSpan="3" Text="Secret Data" Style="{StaticResource SectionHeader}"/>

                <TextBlock Grid.Row="19" Grid.Column="0" Text="Masking" Style="{StaticResource FieldLabel}"/>
                <TextBox   Grid.Row="19" Grid.Column="1" Style="{StaticResource MaskedBox}"
                           AcceptsReturn="True" Height="76"
                           Text="{Binding SecretDataJsonMasked}"/>
                <ContentControl Grid.Row="19" Grid.Column="2" ContentTemplate="{StaticResource ActionButtonsTemplate}"/>
                <TextBox   Grid.Row="20" Grid.Column="1" Style="{StaticResource PlainBox}"
                           AcceptsReturn="True" Height="100"
                           Text="{Binding SecretDataJsonPlain, Mode=TwoWay}" Visibility="Collapsed"/>

                <!-- ======== Security Questions (repeatable pairs) ======== -->
                <TextBlock Grid.Row="22" Grid.ColumnSpan="3" Text="Security Questions" Style="{StaticResource SectionHeader}"/>

                <ItemsControl Grid.Row="23" Grid.ColumnSpan="3" ItemsSource="{Binding SecurityQuestions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,6,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Question (masked + plain) -->
                                <TextBlock Grid.Column="0" Text="Question" Style="{StaticResource FieldLabel}"/>
                                <StackPanel Grid.Column="1">
                                    <TextBox Style="{StaticResource MaskedBox}" Text="{Binding QuestionEncrypted}"/>
                                    <TextBox Style="{StaticResource PlainBox}"   Text="{Binding QuestionPlain, Mode=TwoWay}" Visibility="Collapsed"/>
                                </StackPanel>
                                <ContentControl Grid.Column="2" ContentTemplate="{StaticResource ActionButtonsTemplate}"/>

                                <!-- Answer (masked + plain) -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Answer" Style="{StaticResource FieldLabel}"/>
                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <TextBox Style="{StaticResource MaskedBox}" Text="{Binding AnswerEncrypted}"/>
                                    <TextBox Style="{StaticResource PlainBox}"   Text="{Binding AnswerPlain, Mode=TwoWay}" Visibility="Collapsed"/>
                                </StackPanel>
                                <ContentControl Grid.Row="1" Grid.Column="2" ContentTemplate="{StaticResource ActionButtonsTemplate}"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Grid.Row="24" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Add Question" Padding="10,4"/>
                </StackPanel>

                <!-- ======== Bank Cards / Accounts (future) ======== -->
                <TextBlock Grid.Row="26" Grid.ColumnSpan="3"
                           Text="Bank Cards &amp; Accounts (from SecretData JSON)"
                           Style="{StaticResource SectionHeader}"/>
                <TextBlock Grid.Row="27" Grid.ColumnSpan="3"
                           Text="First pass UI only — cards/accounts will be modeled inside SecretData JSON and rendered here later."
                           Foreground="{StaticResource Brush.Text}"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
