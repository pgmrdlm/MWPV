<UserControl x:Class="MWPV.View.UserControls.CategoryItems.CategoryItemBankAndSecurityPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="900">

    <UserControl.Resources>

        <!-- Small square primary button (same as CategoryItemNew) -->
        <Style x:Key="SmallSquarePrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Background" Value="{DynamicResource PrimaryNormalBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource DisabledBrush}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource DisabledForeground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Bank cards -->
            <RowDefinition Height="Auto" />
            <!-- Accounts -->
            <RowDefinition Height="Auto" />
            <!-- Security Q/A -->
        </Grid.RowDefinitions>

        <!-- ================= BANK CARDS / ACCOUNTS (CARDS) ================= -->
        <GroupBox Grid.Row="0"
                  Header="Bank Cards / Accounts"
                  Margin="0,0,0,6">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- entry line -->
                    <RowDefinition Height="Auto" />
                    <!-- error -->
                    <RowDefinition Height="Auto" />
                    <!-- grid -->
                </Grid.RowDefinitions>

                <!-- Card entry row -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <!-- Card type -->
                        <ColumnDefinition Width="170" />
                        <!-- Card number -->
                        <ColumnDefinition Width="140" />
                        <!-- Expiration -->
                        <ColumnDefinition Width="110" />
                        <!-- CVV -->
                        <ColumnDefinition Width="140" />
                        <!-- PIN -->
                        <ColumnDefinition Width="70"  />
                        <!-- Active -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Add -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Clear -->
                    </Grid.ColumnDefinitions>

                    <!-- Labels -->
                    <TextBlock Grid.Column="0"
                               Text="Card Type"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <TextBlock Grid.Column="1"
                               Text="Card Number"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <TextBlock Grid.Column="2"
                               Text="Expiration Date"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <TextBlock Grid.Column="3"
                               Text="CVV"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <TextBlock Grid.Column="4"
                               Text="Card PIN"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <TextBlock Grid.Column="5"
                               Text="Active"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />

                    <!-- Fields -->
                    <ComboBox x:Name="CardTypeCombo"
                              Grid.Column="0"
                              Margin="0,20,6,0"
                              ItemsSource="{Binding CardTypeItems,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                              DisplayMemberPath="DisplayText"
                              SelectedValuePath="ComboDetailId"
                              SelectedIndex="0"
                              LostFocus="OnBankCardFieldLostFocus" />

                    <TextBox x:Name="CardNumberTextBox"
                             Grid.Column="1"
                             Margin="0,20,6,0"
                             MaxLength="23"
                             LostFocus="OnBankCardFieldLostFocus" />

                    <TextBox x:Name="ExpirationTextBox"
                             Grid.Column="2"
                             Margin="0,20,6,0"
                             ToolTip="MM/YYYY or MM/YY"
                             MaxLength="7"
                             LostFocus="OnBankCardFieldLostFocus" />

                    <!-- CVV with show/hide button -->
                    <Grid Grid.Column="3"
                          Margin="0,20,6,0"
                          Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <PasswordBox x:Name="CvvBox"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         MaxLength="4"
                                         LostFocus="OnBankCardFieldLostFocus"
                                         PasswordChanged="CvvBox_PasswordChanged" />
                            <TextBox x:Name="CvvPlainTextBox"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black" />
                        </Grid>

                        <Button x:Name="BtnToggleCvvReveal"
                                Grid.Column="1"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show/Hide CVV"
                                Click="BtnToggleCvvReveal_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black"
                                          Fill="Transparent"
                                          StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z" />
                                    <Ellipse Width="6"
                                             Height="6"
                                             Stroke="Black"
                                             StrokeThickness="1.2"
                                             Fill="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                    <Ellipse Width="3"
                                             Height="3"
                                             Fill="Black"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                </Grid>
                            </Viewbox>
                        </Button>
                    </Grid>

                    <!-- Card PIN with show/hide button -->
                    <Grid Grid.Column="4"
                          Margin="0,20,6,0"
                          Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <PasswordBox x:Name="PinBox"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         MaxLength="6"
                                         LostFocus="OnBankCardFieldLostFocus"
                                         PasswordChanged="PinBox_PasswordChanged" />
                            <TextBox x:Name="PinPlainTextBox"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black" />
                        </Grid>

                        <Button x:Name="BtnTogglePinReveal"
                                Grid.Column="1"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show/Hide card PIN"
                                Click="BtnTogglePinReveal_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black"
                                          Fill="Transparent"
                                          StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z" />
                                    <Ellipse Width="6"
                                             Height="6"
                                             Stroke="Black"
                                             StrokeThickness="1.2"
                                             Fill="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                    <Ellipse Width="3"
                                             Height="3"
                                             Fill="Black"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                </Grid>
                            </Viewbox>
                        </Button>
                    </Grid>

                    <CheckBox x:Name="ChkCardActive"
                              Grid.Column="5"
                              Margin="0,24,0,0"
                              IsChecked="True"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Top" />

                    <Button x:Name="BtnBankCardAddOrUpdate"
                            Grid.Column="6"
                            Margin="8,18,0,0"
                            Content="Add"
                            Style="{StaticResource DialogPrimary}"
                            Click="OnBankCardAddOrUpdateClick" />

                    <Button x:Name="BtnBankCardClear"
                            Grid.Column="7"
                            Margin="6,18,0,0"
                            Content="Clear"
                            Style="{StaticResource DialogSecondary}"
                            Click="OnBankCardClearClick" />
                </Grid>

                <!-- Card error message -->
                <TextBlock x:Name="BankCardErrorTextBlock"
                           Grid.Row="1"
                           Margin="0,4,0,4"
                           Foreground="Red"
                           FontWeight="Bold"
                           TextWrapping="Wrap" />

                <!-- Card grid -->
                <DataGrid x:Name="BankCardGrid"
                          Grid.Row="2"
                          Margin="0,10,0,0"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding BankCardRows,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FF800000" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Card Type"
                                            Binding="{Binding CardTypeDisplay}"
                                            Width="*" />
                        <DataGridTextColumn Header="Card Number"
                                            Binding="{Binding CardNumberMasked}"
                                            Width="150" />
                        <DataGridTextColumn Header="Expiration"
                                            Binding="{Binding Expiration}"
                                            Width="120" />
                        <DataGridTextColumn Header="CVV"
                                            Binding="{Binding CvvMasked}"
                                            Width="80" />
                        <DataGridTextColumn Header="PIN"
                                            Binding="{Binding PinMasked}"
                                            Width="80" />
                        <DataGridTemplateColumn Header="Active" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsActive}"
                                              IsHitTestVisible="False"
                                              HorizontalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Edit / Delete -->
                        <DataGridTemplateColumn Header="Edit" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SmallSquarePrimaryButton}"
                                            HorizontalAlignment="Center"
                                            Tag="{Binding}"
                                            Click="OnBankCardEditClick">
                                        <TextBlock Text="✎" FontSize="12" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Del" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SmallSquarePrimaryButton}"
                                            HorizontalAlignment="Center"
                                            Tag="{Binding}"
                                            Click="OnBankCardDeleteClick">
                                        <TextBlock Text="✖" FontSize="12" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- ======================= ACCOUNTS ======================= -->
        <GroupBox Grid.Row="1"
                  Header="Accounts"
                  Margin="0,4,0,4">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- entry row -->
                    <RowDefinition Height="Auto" />
                    <!-- error -->
                    <RowDefinition Height="Auto" />
                    <!-- grid -->
                </Grid.RowDefinitions>

                <!-- Account entry row -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <!-- Account name -->
                        <ColumnDefinition Width="220" />
                        <!-- Account number -->
                        <ColumnDefinition Width="140" />
                        <!-- Account PIN -->
                        <ColumnDefinition Width="70"  />
                        <!-- Active -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Add -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Clear -->
                    </Grid.ColumnDefinitions>

                    <!-- Labels -->
                    <TextBlock Grid.Column="0"
                               Text="Account Name"
                               FontWeight="Bold"
                               Margin="0,0,0,2" />
                    <TextBlock Grid.Column="1"
                               Text="Account Number"
                               FontWeight="Bold"
                               Margin="0,0,0,2" />
                    <TextBlock Grid.Column="2"
                               Text="Account PIN (optional)"
                               FontWeight="Bold"
                               Margin="0,0,0,2" />
                    <TextBlock Grid.Column="3"
                               Text="Active"
                               FontWeight="Bold"
                               Margin="0,0,0,2" />

                    <!-- Fields -->
                    <ComboBox x:Name="AccountNameCombo"
                              Grid.Column="0"
                              Margin="0,20,6,0"
                              ItemsSource="{Binding AccountTypeItems,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                              DisplayMemberPath="DisplayText"
                              SelectedValuePath="ComboDetailId"
                              SelectedIndex="0"
                              LostFocus="OnAccountFieldLostFocus" />

                    <TextBox x:Name="AccountNumberTextBox"
                             Grid.Column="1"
                             Margin="0,20,6,0"
                             MaxLength="24"
                             LostFocus="OnAccountFieldLostFocus" />

                    <PasswordBox x:Name="AccountPinBox"
                                 Grid.Column="2"
                                 Margin="0,20,6,0"
                                 MaxLength="6"
                                 LostFocus="OnAccountFieldLostFocus" />

                    <CheckBox x:Name="ChkAccountActive"
                              Grid.Column="3"
                              Margin="0,24,0,0"
                              IsChecked="True"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Top" />

                    <Button x:Name="BtnAccountAddOrUpdate"
                            Grid.Column="4"
                            Margin="8,18,0,0"
                            Content="Add"
                            Style="{StaticResource DialogPrimary}"
                            Click="OnAccountAddOrUpdateClick" />

                    <Button x:Name="BtnAccountClear"
                            Grid.Column="5"
                            Margin="6,18,0,0"
                            Content="Clear"
                            Style="{StaticResource DialogSecondary}"
                            Click="OnAccountClearClick" />
                </Grid>

                <!-- Account error message -->
                <TextBlock x:Name="AccountErrorTextBlock"
                           Grid.Row="1"
                           Margin="0,4,0,4"
                           Foreground="Red"
                           FontWeight="Bold"
                           TextWrapping="Wrap" />

                <!-- Accounts grid -->
                <DataGrid x:Name="AccountGrid"
                          Grid.Row="2"
                          Margin="0,10,0,0"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding AccountRows,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FF800000" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Account Name"
                                            Binding="{Binding AccountTypeDisplay}"
                                            Width="*" />
                        <DataGridTextColumn Header="Account Number"
                                            Binding="{Binding AccountNumberMasked}"
                                            Width="200" />
                        <DataGridTextColumn Header="PIN"
                                            Binding="{Binding PinMasked}"
                                            Width="80" />
                        <DataGridTemplateColumn Header="Active" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsActive}"
                                              IsHitTestVisible="False"
                                              HorizontalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Edit / Delete -->
                        <DataGridTemplateColumn Header="Edit" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SmallSquarePrimaryButton}"
                                            HorizontalAlignment="Center"
                                            Tag="{Binding}"
                                            Click="OnAccountEditClick">
                                        <TextBlock Text="✎" FontSize="12" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Del" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SmallSquarePrimaryButton}"
                                            HorizontalAlignment="Center"
                                            Tag="{Binding}"
                                            Click="OnAccountDeleteClick">
                                        <TextBlock Text="✖" FontSize="12" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- ================== SECURITY QUESTIONS / ANSWERS ================== -->
        <GroupBox Grid.Row="2"
                  Header="Security Questions / Answers"
                  Margin="0,6,0,0">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- entry row -->
                    <RowDefinition Height="Auto" />
                    <!-- error -->
                    <RowDefinition Height="Auto" />
                    <!-- grid -->
                </Grid.RowDefinitions>

                <!-- Entry row -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"   />
                        <!-- Question -->
                        <ColumnDefinition Width="*"   />
                        <!-- Answer -->
                        <ColumnDefinition Width="70"  />
                        <!-- Active -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Add -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Clear -->
                    </Grid.ColumnDefinitions>

                    <!-- Labels -->
                    <TextBlock Grid.Column="0"
                               Text="Security Question"
                               FontWeight="Bold"
                               Margin="0,0,0,2" />
                    <TextBlock Grid.Column="1"
                               Text="Answer"
                               FontWeight="Bold"
                               Margin="0,0,0,2" />
                    <TextBlock Grid.Column="2"
                               Text="Active"
                               FontWeight="Bold"
                               Margin="0,0,0,2" />

                    <!-- Question text (no LostFocus here now) -->
                    <TextBox x:Name="SecurityQuestionTextBox"
                             Grid.Column="0"
                             Margin="0,20,6,0" />

                    <!-- Answer with show/hide button -->
                    <Grid Grid.Column="1"
                          Margin="0,20,6,0"
                          Height="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <PasswordBox x:Name="SecurityAnswerBox"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         LostFocus="OnSecurityFieldLostFocus"
                                         PasswordChanged="SecurityAnswerBox_PasswordChanged" />
                            <TextBox x:Name="SecurityAnswerPlainText"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     IsReadOnly="False"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     LostFocus="OnSecurityFieldLostFocus" />
                        </Grid>

                        <Button x:Name="BtnToggleSecurityAnswer"
                                Grid.Column="1"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show/Hide answer"
                                Click="BtnToggleSecurityAnswer_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black"
                                          Fill="Transparent"
                                          StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z" />
                                    <Ellipse Width="6"
                                             Height="6"
                                             Stroke="Black"
                                             StrokeThickness="1.2"
                                             Fill="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                    <Ellipse Width="3"
                                             Height="3"
                                             Fill="Black"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                </Grid>
                            </Viewbox>
                        </Button>
                    </Grid>

                    <CheckBox x:Name="ChkSecurityActive"
                              Grid.Column="2"
                              Margin="0,24,0,0"
                              IsChecked="True"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Top" />

                    <Button x:Name="BtnSecurityAddOrUpdate"
                            Grid.Column="3"
                            Margin="8,18,0,0"
                            Content="Add"
                            Style="{StaticResource DialogPrimary}"
                            Click="OnSecurityAddOrUpdateClick" />

                    <Button x:Name="BtnSecurityClear"
                            Grid.Column="4"
                            Margin="6,18,0,0"
                            Content="Clear"
                            Style="{StaticResource DialogSecondary}"
                            Click="OnSecurityClearClick" />
                </Grid>

                <!-- Error text -->
                <TextBlock x:Name="SecurityErrorTextBlock"
                           Grid.Row="1"
                           Margin="0,4,0,4"
                           Foreground="Red"
                           FontWeight="Bold"
                           TextWrapping="Wrap" />

                <!-- Grid -->
                <DataGrid x:Name="SecurityGrid"
                          Grid.Row="2"
                          Margin="0,10,0,0"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding SecurityQuestionRows,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FF800000" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Question"
                                            Binding="{Binding Question}"
                                            Width="*" />
                        <DataGridTextColumn Header="Answer"
                                            Binding="{Binding AnswerMasked}"
                                            Width="220" />
                        <DataGridTemplateColumn Header="Active" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsActive}"
                                              IsHitTestVisible="False"
                                              HorizontalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Edit / Delete -->
                        <DataGridTemplateColumn Header="Edit" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SmallSquarePrimaryButton}"
                                            HorizontalAlignment="Center"
                                            Tag="{Binding}"
                                            Click="OnSecurityEditClick">
                                        <TextBlock Text="✎" FontSize="12" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Del" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SmallSquarePrimaryButton}"
                                            HorizontalAlignment="Center"
                                            Tag="{Binding}"
                                            Click="OnSecurityDeleteClick">
                                        <TextBlock Text="✖" FontSize="12" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>
    </Grid>
</UserControl>
