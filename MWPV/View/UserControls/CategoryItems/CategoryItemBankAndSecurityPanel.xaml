<UserControl x:Class="MWPV.View.UserControls.CategoryItems.CategoryItemBankAndSecurityPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="900">
    <UserControl.Resources>

        <!-- Pill buttons for Add/Update + Clear -->
        <Style x:Key="BankCardPillButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="14,4" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#CC008000" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BankCardPillButtonSecondaryStyle"
               TargetType="Button"
               BasedOn="{StaticResource BankCardPillButtonStyle}">
            <Setter Property="Background" Value="#FFE0E0E0" />
            <Setter Property="Foreground" Value="Black" />
        </Style>

        <!-- Small green icon buttons for Edit/Delete -->
        <Style x:Key="BankCardIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="#FF90EE90" />
            <Setter Property="BorderBrush" Value="#FF006400" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ========== BANK CARDS / ACCOUNTS PANEL ========== -->
        <GroupBox Grid.Row="0"
                  Header="Bank Cards / Accounts"
                  Margin="0,0,0,6">
            <Grid Margin="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- entry line -->
                    <RowDefinition Height="Auto" />
                    <!-- error text -->
                    <RowDefinition Height="Auto" />
                    <!-- grid -->
                </Grid.RowDefinitions>

                <!-- Entry row -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <!-- Card type -->
                        <ColumnDefinition Width="170" />
                        <!-- Card number -->
                        <ColumnDefinition Width="140" />
                        <!-- Expiration -->
                        <ColumnDefinition Width="110" />
                        <!-- CVV -->
                        <ColumnDefinition Width="140" />
                        <!-- PIN -->
                        <ColumnDefinition Width="70" />
                        <!-- Active -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Update -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Clear -->
                    </Grid.ColumnDefinitions>

                    <!-- Labels -->
                    <TextBlock Grid.Column="0"
                               Text="Card Type"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <TextBlock Grid.Column="1"
                               Text="Card Number"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <TextBlock Grid.Column="2"
                               Text="Expiration Date"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <TextBlock Grid.Column="3"
                               Text="CVV"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <TextBlock Grid.Column="4"
                               Text="Card PIN"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <TextBlock Grid.Column="5"
                               Text="Active"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />

                    <!-- Fields -->
                    <ComboBox x:Name="CardTypeCombo"
                              Grid.Column="0"
                              Margin="0,20,6,0"
                              ItemsSource="{Binding CardTypeItems,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                              DisplayMemberPath="DisplayText"
                              SelectedValuePath="ComboDetailId"
                              SelectedIndex="0" />

                    <TextBox x:Name="CardNumberTextBox"
                             Grid.Column="1"
                             Margin="0,20,6,0" />

                    <TextBox x:Name="ExpirationTextBox"
                             Grid.Column="2"
                             Margin="0,20,6,0"
                             ToolTip="MM/YYYY or MM/YY" />

                    <!-- CVV + PIN kept simple for now -->
                    <PasswordBox x:Name="CvvBox"
                                 Grid.Column="3"
                                 Margin="0,20,6,0" />

                    <PasswordBox x:Name="PinBox"
                                 Grid.Column="4"
                                 Margin="0,20,6,0" />

                    <CheckBox x:Name="ChkCardActive"
                              Grid.Column="5"
                              Margin="0,24,0,0"
                              IsChecked="True"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Top" />

                    <Button x:Name="BtnBankCardAddOrUpdate"
                            Grid.Column="6"
                            Margin="8,18,0,0"
                            Content="Add"
                            Style="{StaticResource BankCardPillButtonStyle}"
                            Click="OnBankCardAddOrUpdateClick" />

                    <Button x:Name="BtnBankCardClear"
                            Grid.Column="7"
                            Margin="6,18,0,0"
                            Content="Clear"
                            Style="{StaticResource BankCardPillButtonSecondaryStyle}"
                            Click="OnBankCardClearClick" />
                </Grid>

                <!-- Inline error message for bank cards (under entry row, above grid) -->
                <TextBlock x:Name="BankCardErrorTextBlock"
                           Grid.Row="1"
                           Margin="0,4,0,4"
                           Foreground="Red"
                           FontWeight="Bold"
                           TextWrapping="Wrap" />

                <!-- Grid of cards -->
                <DataGrid x:Name="BankCardGrid"
                          Grid.Row="2"
                          Margin="0,10,0,0"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding BankCardRows,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#FF800000" />
                            <!-- maroon -->
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Card Type"
                                            Binding="{Binding CardTypeDisplay}"
                                            Width="*" />
                        <DataGridTextColumn Header="Card Number"
                                            Binding="{Binding CardNumberMasked}"
                                            Width="150" />
                        <DataGridTextColumn Header="Expiration"
                                            Binding="{Binding Expiration}"
                                            Width="120" />
                        <DataGridTextColumn Header="CVV"
                                            Binding="{Binding CvvMasked}"
                                            Width="80" />
                        <DataGridTextColumn Header="PIN"
                                            Binding="{Binding PinMasked}"
                                            Width="80" />
                        <DataGridTemplateColumn Header="Active" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsActive}"
                                              IsHitTestVisible="False"
                                              HorizontalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Edit / Delete -->
                        <DataGridTemplateColumn Header="Edit" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource BankCardIconButtonStyle}"
                                            Tag="{Binding}"
                                            Click="OnBankCardEditClick">
                                        <TextBlock Text="✎" FontSize="12" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Del" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource BankCardIconButtonStyle}"
                                            Tag="{Binding}"
                                            Click="OnBankCardDeleteClick">
                                        <TextBlock Text="✖" FontSize="12" />
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- ========== SIMPLE PLACEHOLDER FOR ACCOUNTS ========== -->
        <Grid Grid.Row="1" Margin="0,4,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Account Name"
                       FontWeight="Bold" />
            <TextBlock Grid.Column="1"
                       Text="Account Number"
                       FontWeight="Bold" />
            <TextBlock Grid.Column="2"
                       Text="Account PIN (optional)"
                       FontWeight="Bold" />

            <ComboBox x:Name="AccountNameCombo"
                      Grid.Column="0"
                      Margin="0,20,6,0" />

            <TextBox x:Name="AccountNumberTextBox"
                     Grid.Column="1"
                     Margin="0,20,6,0" />

            <TextBox x:Name="AccountPinTextBox"
                     Grid.Column="2"
                     Margin="0,20,0,0" />
        </Grid>

        <!-- ========== SIMPLE PLACEHOLDER FOR SECURITY Q/A ========== -->
        <Grid Grid.Row="2" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SecurityQuestionAnswerTextBox"
                     Grid.Column="0"
                     Margin="0,0,6,0"
                     Height="26"
                     VerticalContentAlignment="Center"
                     Text="Security question / answer area to be wired later" />

            <Button Grid.Column="1"
                    Content="Add"
                    Style="{StaticResource BankCardPillButtonStyle}"
                    HorizontalAlignment="Right" />
        </Grid>
    </Grid>
</UserControl>
