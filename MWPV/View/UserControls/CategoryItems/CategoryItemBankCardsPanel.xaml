<UserControl x:Class="MWPV.View.UserControls.CategoryItems.CategoryItemBankCardsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="260"
             d:DesignWidth="900">

    <UserControl.Resources>

        <!-- Small square primary button (matches other panels) -->
        <Style x:Key="SmallSquarePrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Background" Value="{DynamicResource PrimaryNormalBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource DisabledBrush}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource DisabledForeground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- Match Basic tab background; no outer GroupBox -->
    <Grid Margin="0"
          Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- entry area -->
            <RowDefinition Height="Auto" />
            <!-- error text -->
            <RowDefinition Height="*" />
            <!-- grid -->
        </Grid.RowDefinitions>

        <!-- ================= ENTRY AREA ================= -->
        <!-- Centered wrapper so the edit block feels less crowded and more "anchored" -->
        <Border Grid.Row="0"
                Margin="0,0,0,6"
                Padding="14,10"
                Background="Transparent"
                HorizontalAlignment="Center"
                MaxWidth="760">

            <!-- 3 rows x 3 columns -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- line 1 -->
                    <RowDefinition Height="Auto" />
                    <!-- line 2 -->
                    <RowDefinition Height="Auto" />
                    <!-- line 3 (buttons) -->
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="190" />
                    <ColumnDefinition Width="*" MinWidth="280" />
                    <ColumnDefinition Width="*" MinWidth="170" />
                </Grid.ColumnDefinitions>

                <!-- ================= ROW 0 ================= -->
                <!-- Card Type -->
                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,16,8">
                    <TextBlock Text="Card Type"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <ComboBox x:Name="CardTypeCombo"
                              Height="28"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{Binding CardTypeItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              DisplayMemberPath="DisplayText"
                              SelectedValuePath="ComboDetailId"
                              SelectedIndex="0"
                              LostFocus="OnBankCardFieldLostFocus" />
                </StackPanel>

                <!-- Card Number -->
                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,16,8">
                    <TextBlock Text="Card Number"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <Grid Height="28"
                          HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              HorizontalAlignment="Stretch">
                            <PasswordBox x:Name="CardNumberBox"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         MinWidth="240"
                                         HorizontalAlignment="Stretch"
                                         MaxLength="19"
                                         LostFocus="OnBankCardFieldLostFocus"
                                         PasswordChanged="CardNumberBox_PasswordChanged" />
                            <TextBox x:Name="CardNumberPlainTextBox"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     MinWidth="240"
                                     HorizontalAlignment="Stretch"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black"
                                     LostFocus="OnBankCardFieldLostFocus" />
                        </Grid>

                        <Button x:Name="BtnViewCardNumber"
                                Grid.Column="1"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show card number"
                                Click="BtnViewCardNumber_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black"
                                          Fill="Transparent"
                                          StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z" />
                                    <Ellipse Width="6"
                                             Height="6"
                                             Stroke="Black"
                                             StrokeThickness="1.2"
                                             Fill="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                    <Ellipse Width="3"
                                             Height="3"
                                             Fill="Black"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                </Grid>
                            </Viewbox>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Expiration -->
                <StackPanel Grid.Row="0"
                            Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8">
                    <TextBlock Text="Expiration Date"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <TextBox x:Name="ExpirationTextBox"
                             Height="28"
                             HorizontalAlignment="Stretch"
                             VerticalContentAlignment="Center"
                             ToolTip="MM/YYYY or MM/YY"
                             MaxLength="7"
                             LostFocus="OnBankCardFieldLostFocus" />
                </StackPanel>

                <!-- ================= ROW 1 ================= -->
                <!-- CVV -->
                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,16,8">
                    <TextBlock Text="CVV"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <Grid Height="28"
                          HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              HorizontalAlignment="Stretch">
                            <PasswordBox x:Name="CvvBox"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         MinWidth="110"
                                         HorizontalAlignment="Stretch"
                                         MaxLength="4"
                                         LostFocus="OnBankCardFieldLostFocus"
                                         PasswordChanged="CvvBox_PasswordChanged" />
                            <TextBox x:Name="CvvPlainTextBox"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     MinWidth="110"
                                     HorizontalAlignment="Stretch"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black" />
                        </Grid>

                        <Button x:Name="BtnToggleCvvReveal"
                                Grid.Column="1"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show CVV"
                                Click="BtnToggleCvvReveal_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black"
                                          Fill="Transparent"
                                          StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z" />
                                    <Ellipse Width="6"
                                             Height="6"
                                             Stroke="Black"
                                             StrokeThickness="1.2"
                                             Fill="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                    <Ellipse Width="3"
                                             Height="3"
                                             Fill="Black"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                </Grid>
                            </Viewbox>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Card PIN -->
                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,16,8">
                    <TextBlock Text="Card PIN"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <Grid Height="28"
                          HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              HorizontalAlignment="Stretch">
                            <PasswordBox x:Name="PinBox"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         MinWidth="160"
                                         HorizontalAlignment="Stretch"
                                         MaxLength="6"
                                         LostFocus="OnBankCardFieldLostFocus"
                                         PasswordChanged="PinBox_PasswordChanged" />
                            <TextBox x:Name="PinPlainTextBox"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     MinWidth="160"
                                     HorizontalAlignment="Stretch"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black" />
                        </Grid>

                        <Button x:Name="BtnTogglePinReveal"
                                Grid.Column="1"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show card PIN"
                                Click="BtnTogglePinReveal_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black"
                                          Fill="Transparent"
                                          StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z" />
                                    <Ellipse Width="6"
                                             Height="6"
                                             Stroke="Black"
                                             StrokeThickness="1.2"
                                             Fill="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                    <Ellipse Width="3"
                                             Height="3"
                                             Fill="Black"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                </Grid>
                            </Viewbox>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- Active -->
                <StackPanel Grid.Row="1"
                            Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8">
                    <TextBlock Text="Active"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <CheckBox x:Name="ChkCardActive"
                              IsChecked="True"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center" />
                </StackPanel>

                <!-- ================= ROW 2 (BUTTONS) ================= -->
                <StackPanel Grid.Row="2"
                            Grid.ColumnSpan="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,6,0,0">
                    <Button x:Name="BtnBankCardAddOrUpdate"
                            Margin="0,0,12,0"
                            Content="Add"
                            Style="{StaticResource DialogPrimary}"
                            Click="OnBankCardAddOrUpdateClick" />
                    <Button x:Name="BtnBankCardClear"
                            Content="Clear"
                            Style="{StaticResource DialogSecondary}"
                            Click="OnBankCardClearClick" />
                </StackPanel>

            </Grid>
        </Border>

        <!-- Error text -->
        <TextBlock x:Name="BankCardErrorTextBlock"
                   Grid.Row="1"
                   Margin="0,4,0,4"
                   Foreground="Red"
                   FontWeight="Bold"
                   TextWrapping="Wrap" />

        <!-- Grid -->
        <DataGrid x:Name="BankCardGrid"
                  Grid.Row="2"
                  Margin="0,6,0,0"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding BankCardRows, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  Background="Bisque"
                  RowBackground="Bisque"
                  AlternatingRowBackground="Bisque">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FF800000" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Card Type"
                                    Binding="{Binding CardTypeDisplay}"
                                    Width="120" />
                <DataGridTextColumn Header="Card Number"
                                    Binding="{Binding CardNumberMasked}"
                                    Width="100" />
                <DataGridTextColumn Header="Expiration"
                                    Binding="{Binding Expiration}"
                                    Width="70" />
                <DataGridTextColumn Header="CVV"
                                    Binding="{Binding CvvMasked}"
                                    Width="40" />
                <DataGridTextColumn Header="PIN"
                                    Binding="{Binding PinMasked}"
                                    Width="50" />
                <DataGridTemplateColumn Header="Active" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsActive}"
                                      IsHitTestVisible="False"
                                      HorizontalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Edit / Delete -->
                <DataGridTemplateColumn Header="Edit" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource SmallSquarePrimaryButton}"
                                    HorizontalAlignment="Center"
                                    Tag="{Binding}"
                                    Click="OnBankCardEditClick">
                                <TextBlock Text="✎" FontSize="12" />
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- THIS is the restore: Del column eats remaining space -->
                <DataGridTemplateColumn Header="Del" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource SmallSquarePrimaryButton}"
                                    HorizontalAlignment="Center"
                                    Tag="{Binding}"
                                    Click="OnBankCardDeleteClick">
                                <TextBlock Text="✖" FontSize="12" />
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>