<!-- File: View/UserControls/CategoryItems/CategoryItemBankCardsPanel.xaml -->
<UserControl x:Class="MWPV.View.UserControls.CategoryItems.CategoryItemAccountsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="260"
             d:DesignWidth="900">

    <UserControl.Resources>
        <!-- Small square primary button (matches other panels) -->
        <Style x:Key="SmallSquarePrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Background" Value="{DynamicResource PrimaryNormalBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource DisabledBrush}" />
                                <Setter Property="Foreground"
                                        Value="{DynamicResource DisabledForeground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Grid action buttons (match Save/Cancel sizing via DialogPrimary/DialogSecondary) -->
        <Style x:Key="GridActionEditButton" TargetType="Button" BasedOn="{StaticResource DialogPrimary}">
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Style.Triggers>
                <!-- Disabled until a row is selected -->
                <DataTrigger Binding="{Binding SelectedItem, ElementName=BankCardGrid}" Value="{x:Null}">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GridActionDeleteButton" TargetType="Button" BasedOn="{StaticResource DialogSecondary}">
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="Foreground" Value="Maroon"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Style.Triggers>
                <!-- Disabled until a row is selected -->
                <DataTrigger Binding="{Binding SelectedItem, ElementName=BankCardGrid}" Value="{x:Null}">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <!-- Match other CategoryItem tabs (same Bisque surface) -->
    <Grid Margin="0"
          Background="Bisque">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- entry -->
            <RowDefinition Height="Auto" />
            <!-- error -->
            <RowDefinition Height="*" />
            <!-- grid (strip + datagrid live inside) -->
            <RowDefinition Height="Auto" />
            <!-- tab Save/Cancel -->
        </Grid.RowDefinitions>

        <!-- ================= ENTRY AREA ================= -->
        <Border Grid.Row="0"
                Margin="0,0,0,6"
                Padding="14,10"
                Background="Transparent"
                HorizontalAlignment="Center"
                MaxWidth="760">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Use 2 columns for the new layout -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="240" />
                    <ColumnDefinition Width="*" MinWidth="240" />
                </Grid.ColumnDefinitions>

                <!-- ROW 0: Card Type (col 0) -->
                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,16,8">
                    <TextBlock Text="Card Type"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <ComboBox x:Name="CardTypeCombo"
                              Height="28"
                              HorizontalAlignment="Stretch"
                              ItemsSource="{Binding CardTypeItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              DisplayMemberPath="DisplayText"
                              SelectedValuePath="ComboDetailId"
                              SelectedIndex="0"
                              LostFocus="OnBankCardFieldLostFocus" />
                </StackPanel>

                <!-- ROW 0: Card Number (col 1) -->
                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8">
                    <TextBlock Text="Card Number"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <Grid Height="28"
                          HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              HorizontalAlignment="Stretch">
                            <PasswordBox x:Name="CardNumberBox"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         MinWidth="240"
                                         HorizontalAlignment="Stretch"
                                         MaxLength="19"
                                         LostFocus="OnBankCardFieldLostFocus"
                                         PasswordChanged="CardNumberBox_PasswordChanged" />

                            <!-- Reveal overlay: read-only + transparent (CW style) -->
                            <TextBox x:Name="CardNumberPlainTextBox"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     MinWidth="240"
                                     HorizontalAlignment="Stretch"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black" />
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button x:Name="BtnCopyCardNumber"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    Visibility="Collapsed"
                                    ToolTip="Copy card number to clipboard"
                                    Click="BtnCopyCardNumber_Click">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE8C8;"
                                           FontSize="16"
                                           Foreground="Black"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Button>

                            <Button x:Name="BtnViewCardNumber"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    ToolTip="Show card number"
                                    Click="BtnViewCardNumber_Click">
                                <Viewbox Stretch="Uniform">
                                    <Grid Width="20" Height="20">
                                        <Path Stroke="Black"
                                              Fill="Transparent"
                                              StrokeThickness="1.6"
                                              Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z" />
                                        <Ellipse Width="6"
                                                 Height="6"
                                                 Stroke="Black"
                                                 StrokeThickness="1.2"
                                                 Fill="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                        <Ellipse Width="3"
                                                 Height="3"
                                                 Fill="Black"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                    </Grid>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- ROW 1: Expiration (col 0) -->
                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,16,8">
                    <TextBlock Text="Expiration Date"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <!-- CHANGE ONLY: make Expiration field a proper width for 7 chars (MM/YYYY) -->
                    <TextBox x:Name="ExpirationTextBox"
                             Height="28"
                             Width="92"
                             HorizontalAlignment="Left"
                             VerticalContentAlignment="Center"
                             ToolTip="MM/YYYY or MM/YY"
                             MaxLength="7"
                             LostFocus="OnBankCardFieldLostFocus" />
                </StackPanel>

                <!-- ROW 1: Active (col 1) -->
                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8">
                    <TextBlock Text="Active"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <CheckBox x:Name="ChkCardActive"
                              IsChecked="True"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center" />
                </StackPanel>

                <!-- ROW 2: CVV (col 0) -->
                <StackPanel Grid.Row="2"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,16,8">
                    <TextBlock Text="CVV"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <Grid Height="28"
                          HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              HorizontalAlignment="Left">
                            <!-- CHANGE ONLY: make CVV field a proper width for 3-4 digits -->
                            <PasswordBox x:Name="CvvBox"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         Width="64"
                                         HorizontalAlignment="Left"
                                         MaxLength="4"
                                         LostFocus="OnBankCardFieldLostFocus"
                                         PasswordChanged="CvvBox_PasswordChanged" />
                            <!-- Reveal overlay: read-only + transparent -->
                            <TextBox x:Name="CvvPlainTextBox"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     Width="64"
                                     HorizontalAlignment="Left"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black" />
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button x:Name="BtnCopyCvv"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    Visibility="Collapsed"
                                    ToolTip="Copy CVV to clipboard"
                                    Click="BtnCopyCvv_Click">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE8C8;"
                                           FontSize="16"
                                           Foreground="Black"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Button>

                            <Button x:Name="BtnToggleCvvReveal"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    ToolTip="Show CVV"
                                    Click="BtnToggleCvvReveal_Click">
                                <Viewbox Stretch="Uniform">
                                    <Grid Width="20" Height="20">
                                        <Path Stroke="Black"
                                              Fill="Transparent"
                                              StrokeThickness="1.6"
                                              Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z" />
                                        <Ellipse Width="6"
                                                 Height="6"
                                                 Stroke="Black"
                                                 StrokeThickness="1.2"
                                                 Fill="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                        <Ellipse Width="3"
                                                 Height="3"
                                                 Fill="Black"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                    </Grid>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- ROW 2: Card PIN (col 1) -->
                <StackPanel Grid.Row="2"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,8">
                    <TextBlock Text="Card PIN"
                               Margin="0,0,0,2"
                               FontWeight="Bold" />
                    <Grid Height="28"
                          HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              HorizontalAlignment="Stretch">
                            <PasswordBox x:Name="PinBox"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         MinWidth="160"
                                         HorizontalAlignment="Stretch"
                                         MaxLength="6"
                                         LostFocus="OnBankCardFieldLostFocus"
                                         PasswordChanged="PinBox_PasswordChanged" />
                            <!-- Reveal overlay: read-only + transparent -->
                            <TextBox x:Name="PinPlainTextBox"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     MinWidth="160"
                                     HorizontalAlignment="Stretch"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black" />
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button x:Name="BtnCopyPin"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    Visibility="Collapsed"
                                    ToolTip="Copy card PIN to clipboard"
                                    Click="BtnCopyPin_Click">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE8C8;"
                                           FontSize="16"
                                           Foreground="Black"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Button>

                            <Button x:Name="BtnTogglePinReveal"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    ToolTip="Show card PIN"
                                    Click="BtnTogglePinReveal_Click">
                                <Viewbox Stretch="Uniform">
                                    <Grid Width="20" Height="20">
                                        <Path Stroke="Black"
                                              Fill="Transparent"
                                              StrokeThickness="1.6"
                                              Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z" />
                                        <Ellipse Width="6"
                                                 Height="6"
                                                 Stroke="Black"
                                                 StrokeThickness="1.2"
                                                 Fill="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                        <Ellipse Width="3"
                                                 Height="3"
                                                 Fill="Black"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                    </Grid>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- ROW 3 (ROW-LEVEL buttons) - unchanged -->
                <StackPanel Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,6,0,0">
                    <Button x:Name="BtnBankCardAddOrUpdate"
                            Margin="0,0,12,0"
                            Content="Add"
                            Style="{StaticResource DialogPrimary}"
                            Click="OnBankCardAddOrUpdateClick" />
                    <Button x:Name="BtnBankCardClearRow"
                            Content="Clear Row"
                            Style="{StaticResource DialogSecondary}"
                            Click="OnBankCardClearRowClick" />
                </StackPanel>

            </Grid>
        </Border>

        <!-- Error text -->
        <TextBlock x:Name="BankCardErrorTextBlock"
                   Grid.Row="1"
                   Margin="0,4,0,4"
                   Foreground="Red"
                   FontWeight="Bold"
                   TextWrapping="Wrap" />

        <!-- ================= GRID AREA (STRIP + GRID, NO OVERLAP) ================= -->
        <Grid Grid.Row="2"
              Margin="0,6,0,0"
              HorizontalAlignment="Center"
              MaxWidth="760">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Grid action strip -->
            <Border Grid.Row="0"
                    Padding="10,8"
                    Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="Black"
                               Text="Saved Cards" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button x:Name="BtnBankCardEditSelected"
                                Content="Edit"
                                Style="{StaticResource GridActionEditButton}"
                                Click="OnBankCardEditClick" />
                        <Button x:Name="BtnBankCardDeleteSelected"
                                Content="Delete"
                                Style="{StaticResource GridActionDeleteButton}"
                                Click="OnBankCardDeleteClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Grid -->
            <DataGrid x:Name="BankCardGrid"
                      Grid.Row="1"
                      Margin="0,6,0,0"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      SelectionChanged="BankCardGrid_SelectionChanged"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      IsReadOnly="True"
                      ItemsSource="{Binding BankCardRows, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      Background="Bisque"
                      RowBackground="Bisque"
                      AlternatingRowBackground="Bisque"
                      RowHeight="28"
                      ColumnHeaderHeight="28"
                      MaxHeight="200"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#FF800000" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Card Type"
                                        Binding="{Binding CardTypeDisplay}"
                                        Width="160" />
                    <DataGridTextColumn Header="Card Number"
                                        Binding="{Binding CardNumberMasked}"
                                        Width="110" />
                    <DataGridTextColumn Header="Expiration"
                                        Binding="{Binding Expiration}"
                                        Width="90" />
                    <DataGridTextColumn Header="CVV"
                                        Binding="{Binding CvvMasked}"
                                        Width="60" />
                    <DataGridTextColumn Header="PIN"
                                        Binding="{Binding PinMasked}"
                                        Width="70" />

                    <DataGridTemplateColumn Header="Active" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsActive}"
                                          IsHitTestVisible="False"
                                          HorizontalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- REMOVED: Edit/Delete per-row columns -->
                </DataGrid.Columns>
            </DataGrid>

        </Grid>

        <!-- ================= TAB-LEVEL Save/Cancel + INFO STRIP ================= -->
        <Grid Grid.Row="3"
              Margin="0,10,0,0"
              VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- Buttons (kept intact: names, styles, handlers) -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button x:Name="BtnTabSave"
                        Content="Save"
                        Style="{StaticResource DialogPrimary}"
                        Margin="0,0,12,0"
                        Click="OnTabSaveClick" />
                <Button x:Name="BtnTabCancel"
                        Content="Cancel"
                        Style="{StaticResource DialogSecondary}"
                        Click="OnTabCancelClick" />
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
