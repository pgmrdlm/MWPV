<UserControl x:Class="MWPV.View.UserControls.LogListPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>

        <!-- Column header style -->
        <Style x:Key="LogHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#8B0000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#660000"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,4"/>

            <Style.Triggers>
                <!-- Hover/focus -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Interactive.HoverFg}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>

                <!-- Pressed -->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Interactive.HoverFg}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>

                <!-- Sorted column stays highlighted -->
                <Trigger Property="SortDirection" Value="Ascending">
                    <Setter Property="Foreground" Value="{DynamicResource Interactive.HoverFg}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
                <Trigger Property="SortDirection" Value="Descending">
                    <Setter Property="Foreground" Value="{DynamicResource Interactive.HoverFg}"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Row style -->
        <Style x:Key="LogRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Bisque"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#CDE3FF"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- DataGrid (no Detail button column) -->
        <DataGrid x:Name="dgLogs"
                  Grid.Row="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="False"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  Background="Bisque"
                  BorderThickness="0"
                  RowHeaderWidth="0"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  RowHeight="28"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True"
                  ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=ItemsSource}"
                  SelectedItem="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=SelectedItem, Mode=TwoWay}"
                  SelectionChanged="dgLogs_SelectionChanged"
                  ColumnHeaderStyle="{StaticResource LogHeaderStyle}"
                  RowStyle="{StaticResource LogRowStyle}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Created (Local)" Binding="{Binding CreatedLocal}" Width="170"/>

                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="140"/>

                <DataGridTextColumn Header="EventCode" Binding="{Binding EventCode}" Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Pager -->
        <Grid Grid.Row="1" Margin="12,0,12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="◀ Prev 15"
                        Style="{StaticResource DialogPrimary}"
                        Padding="12,4"
                        Margin="0,0,6,0"
                        Click="_btnPrev_Click"/>
                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=StatusText}"
                           VerticalAlignment="Center"
                           Margin="6,0"/>
                <Button Content="Next 15 ▶"
                        Style="{StaticResource DialogPrimary}"
                        Padding="12,4"
                        Margin="6,0,0,0"
                        Click="_btnNext_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
