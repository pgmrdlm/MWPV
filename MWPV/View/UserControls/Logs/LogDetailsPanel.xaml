<UserControl x:Class="MWPV.View.UserControls.LogDetailsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="320"
             Background="Transparent">

    <Grid Background="Transparent">
        <Border Background="Transparent"
                BorderBrush="#FFD8B8"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <!-- Layout -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Id -->
                    <RowDefinition Height="Auto"/>
                    <!-- Created -->
                    <RowDefinition Height="Auto"/>
                    <!-- Meta -->
                    <RowDefinition Height="*"/>
                    <!-- Message -->
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Header -->
                <TextBlock Text="Log Details"
                           Grid.Row="0" Grid.ColumnSpan="2"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#553300"
                           Margin="0,0,0,10"/>

                <!-- Id -->
                <TextBlock Text="Id:" Grid.Row="1" Grid.Column="0"
                           FontWeight="SemiBold"
                           Margin="0,0,8,6"
                           Foreground="#664000"/>
                <TextBlock Text="{Binding EntryId, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Grid.Row="1" Grid.Column="1"
                           Margin="0,0,0,6"
                           Foreground="#222"/>

                <!-- Created -->
                <TextBlock Text="Created (UTC):" Grid.Row="2" Grid.Column="0"
                           FontWeight="SemiBold"
                           Margin="0,0,8,6"
                           Foreground="#664000"/>
                <TextBlock Text="{Binding CreatedText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Grid.Row="2" Grid.Column="1"
                           Margin="0,0,0,6"
                           Foreground="#222"/>

                <!-- Level / Source / Event -->
                <TextBlock Text="Level / Source / Event:" Grid.Row="3" Grid.Column="0"
                           FontWeight="SemiBold"
                           Margin="0,4,8,6"
                           Foreground="#664000"/>
                <TextBlock Text="{Binding MetaText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Grid.Row="3" Grid.Column="1"
                           Margin="0,4,0,6"
                           Foreground="#222"
                           TextWrapping="Wrap"/>

                <!-- Message -->
                <TextBlock Text="Message:" Grid.Row="4" Grid.Column="0"
                           FontWeight="SemiBold"
                           Margin="0,4,8,6"
                           Foreground="#664000"
                           VerticalAlignment="Top"/>
                <TextBlock Text="{Binding Message, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Grid.Row="4" Grid.Column="1"
                           Margin="0,4,0,0"
                           Foreground="#222"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
