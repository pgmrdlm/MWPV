<UserControl x:Class="MWPV.View.UserControls.CategoryItemEditorTabs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:categoryItems="clr-namespace:MWPV.View.UserControls.CategoryItems"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="940"
             Focusable="True">

    <UserControl.Resources>
        <!-- Password-strength brushes (local; ok) -->
        <SolidColorBrush x:Key="PwWeak"       Color="#D32F2F"/>
        <SolidColorBrush x:Key="PwFair"       Color="#FBC02D"/>
        <SolidColorBrush x:Key="PwStrong"     Color="#388E3C"/>
        <SolidColorBrush x:Key="PwVeryStrong" Color="#2E7D32"/>

        <SolidColorBrush x:Key="FieldErrorFill" Color="#FFFFEEEE"/>

        <!-- Info strip colors (match AppEntryWindow InfoBanner) -->
        <SolidColorBrush x:Key="InfoBannerBackground" Color="#1E40AF"/>
        <SolidColorBrush x:Key="InfoBannerBorder"     Color="#1D4ED8"/>
        <SolidColorBrush x:Key="InfoBannerForeground" Color="White"/>

        <!-- Small square primary icon button -->
        <Style x:Key="SmallSquarePrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryNormalBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DisabledBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Simple tab styling -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Bisque"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="Bisque"/>
        </Style>
    </UserControl.Resources>

    <!-- Outer panel background stays Bisque so it matches old layout -->
    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <!-- header -->
            <RowDefinition Height="*"/>
            <!-- scrollable body -->
            <RowDefinition Height="Auto"/>
            <!-- STATUS LINE (always visible) -->
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Primary}"
                Padding="12,0,6,0">
            <TextBlock VerticalAlignment="Center"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="16"
                       Text="Add / Edit Category Item"/>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1"
                      Background="Bisque"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True"
                      PanningMode="VerticalOnly"
                      Focusable="False">

            <!-- ====================== TABS ====================== -->
            <TabControl x:Name="ItemTabs"
                        Margin="8"
                        SelectedIndex="0">

                <!-- ========== BASIC TAB ========== -->
                <TabItem Header="Basic">
                    <Grid Margin="20"
                          Background="Bisque"
                          Grid.IsSharedSizeScope="True">

                        <!-- ROWS:
                             0: Item name
                             1: Item name error
                             2: Password
                             3: Verify password
                             4: Password/Verify error
                             5: Strength panel
                             6: spacer
                             7: User / Email / Url
                             8: Email error
                             9: spacer
                            10: Phone
                            11: Phone error
                            12: spacer
                            13: Notes
                            14: Info strip + Save/Cancel
                        -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- 0 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 1 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 2 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 3 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 4 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 5 -->
                            <RowDefinition Height="10"/>
                            <!-- 6 spacer -->
                            <RowDefinition Height="Auto"/>
                            <!-- 7 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 8 -->
                            <RowDefinition Height="10"/>
                            <!-- 9 spacer -->
                            <RowDefinition Height="Auto"/>
                            <!-- 10 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 11 -->
                            <RowDefinition Height="10"/>
                            <!-- 12 spacer -->
                            <RowDefinition Height="Auto"/>
                            <!-- 13 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 14 -->
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="2.5*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ================== ROW 0: ITEM NAME ================== -->
                        <Label Grid.Row="0" Grid.Column="0"
                               Content="* Category Item Name"
                               FontWeight="Bold"
                               ToolTip="Required field"/>
                        <TextBox x:Name="txtItemName"
                                 Grid.Row="0" Grid.Column="0"
                                 Margin="0,22,0,0"
                                 Height="28"
                                 MinWidth="320"
                                 HorizontalAlignment="Left"/>

                        <!-- ================== ROW 1: ITEM NAME ERROR ================== -->
                        <StackPanel x:Name="ItemNameErrorPanel"
                                    Grid.Row="1" Grid.Column="0"
                                    Margin="0,6,0,0"
                                    Visibility="Collapsed">
                            <TextBlock x:Name="ItemNameErrorText"
                                       Foreground="#D32F2F"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- ================== ROW 2: PASSWORD ================== -->
                        <Label Grid.Row="2" Grid.Column="0"
                               Content="* Password"
                               FontWeight="Bold"
                               ToolTip="Required field"/>

                        <Grid Grid.Row="2"
                              Grid.Column="0"
                              Grid.ColumnSpan="3"
                              Margin="0,22,0,0"
                              Height="28"
                              MinWidth="320"
                              HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <PasswordBox x:Name="pwdPassword"
                                             VerticalAlignment="Center"
                                             Height="28"
                                             MinWidth="260"
                                             HorizontalAlignment="Stretch"
                                             PasswordChanged="pwdPassword_PasswordChanged"
                                             GotFocus="pwdPassword_GotFocus"
                                             PreviewKeyDown="PwdPassword_PreviewKeyDown"/>
                                <TextBox x:Name="txtPasswordPlain"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         MinWidth="260"
                                         HorizontalAlignment="Stretch"
                                         IsReadOnly="True"
                                         IsHitTestVisible="False"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Visibility="Collapsed"
                                         Foreground="Black"/>
                            </Grid>

                            <Button x:Name="btnGeneratePassword"
                                    Grid.Column="1"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    ToolTip="Generate password"
                                    Click="BtnGeneratePassword_Click">
                                <Viewbox Stretch="Uniform">
                                    <Canvas Width="18" Height="18">
                                        <Path Fill="Black"
                                              Data="M9,1.6 L10.1,5.3 13.6,4.2 11.6,7.3 15.4,8.4 11.6,9.5 13.6,12.6 10.1,11.5 9,15.2 7.9,11.5 4.4,12.6 6.4,9.5 2.6,8.4 6.4,7.3 4.4,4.2 7.9,5.3 z"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <Button x:Name="btnTogglePasswordReveal"
                                    Grid.Column="2"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    ToolTip="Show/Hide password"
                                    Click="BtnTogglePasswordReveal_Click">
                                <Viewbox Stretch="Uniform">
                                    <Grid Width="20" Height="20">
                                        <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                              Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                        <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Width="3" Height="3" Fill="Black"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Viewbox>
                            </Button>

                            <CheckBox x:Name="chkBookmarkOnly"
                                      Grid.Column="3"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"
                                      Content="Bookmark only"
                                      ToolTip="If checked, this item will be treated as a bookmark-only entry with no password."/>
                        </Grid>

                        <!-- ================== ROW 3: VERIFY ================== -->
                        <Label x:Name="lblVerifyPassword"
                               Grid.Row="3" Grid.Column="0"
                               Content="Verify Password"
                               FontWeight="Bold"
                               Visibility="Collapsed"/>

                        <Grid x:Name="VerifyRow"
                              Grid.Row="3"
                              Grid.Column="0"
                              Grid.ColumnSpan="3"
                              Margin="0,22,0,0"
                              Height="28"
                              MinWidth="320"
                              HorizontalAlignment="Left"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <PasswordBox x:Name="pwdVerify"
                                             VerticalAlignment="Center"
                                             Height="28"
                                             HorizontalAlignment="Stretch"
                                             PasswordChanged="pwdVerify_PasswordChanged"/>
                                <TextBox x:Name="txtVerifyPlain"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         HorizontalAlignment="Stretch"
                                         IsReadOnly="True"
                                         IsHitTestVisible="False"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Visibility="Collapsed"
                                         Foreground="Black"/>
                            </Grid>

                            <Button x:Name="btnVerifyDummyGenerate"
                                    Grid.Column="1"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    Visibility="Hidden"
                                    IsHitTestVisible="False"/>

                            <Button x:Name="btnToggleVerifyReveal"
                                    Grid.Column="2"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    ToolTip="Show/Hide verification"
                                    Margin="4,0,0,0"
                                    Visibility="Collapsed"
                                    Click="BtnToggleVerifyReveal_Click">
                                <Viewbox Stretch="Uniform">
                                    <Grid Width="20" Height="20">
                                        <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                              Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                        <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Width="3" Height="3" Fill="Black"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </Viewbox>
                            </Button>

                            <Button x:Name="btnVerifyNotUsed"
                                    Grid.Column="3"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    Margin="4,0,0,0"
                                    Visibility="Hidden"
                                    IsHitTestVisible="False"
                                    ToolTip="(not used – spacer only)"/>
                        </Grid>

                        <!-- ================== ROW 4: VERIFY ERROR ================== -->
                        <StackPanel x:Name="VerifyErrorPanel"
                                    Grid.Row="4" Grid.Column="0"
                                    Grid.ColumnSpan="3"
                                    Margin="0,6,0,0"
                                    Visibility="Collapsed">
                            <TextBlock x:Name="VerifyErrorText"
                                       Foreground="#D32F2F"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- ================== ROW 5: STRENGTH PANEL ================== -->
                        <StackPanel x:Name="StrengthPanel"
                                    Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3"
                                    Margin="0,6,0,0"
                                    Visibility="Collapsed">
                            <ProgressBar x:Name="PwStrengthBar"
                                         Height="8"
                                         Minimum="0"
                                         Maximum="1"
                                         Value="0"
                                         Background="#22000000"/>
                            <TextBlock x:Name="PwStrengthText"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="Black"
                                       Text=""/>
                            <ItemsControl x:Name="PwTipsList"
                                          Margin="0,2,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="• "/>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- ================== ROW 7: USER / EMAIL / URL ================== -->
                        <Label Grid.Row="7" Grid.Column="0"
                               Content="User Name"
                               FontWeight="Bold"/>
                        <TextBox x:Name="txtUsername"
                                 Grid.Row="7" Grid.Column="0"
                                 Margin="0,22,0,0"
                                 Height="28"
                                 MinWidth="240"
                                 HorizontalAlignment="Left"/>

                        <Label Grid.Row="7" Grid.Column="2"
                               Content="Email"
                               FontWeight="Bold"/>
                        <TextBox x:Name="txtEmail"
                                 Grid.Row="7" Grid.Column="2"
                                 Margin="0,22,0,0"
                                 Height="28"
                                 MinWidth="240"
                                 HorizontalAlignment="Left"
                                 LostFocus="txtEmail_LostFocus"/>

                        <Label Grid.Row="7" Grid.Column="4"
                               Content="URL or Absolute Location"
                               FontWeight="Bold"/>
                        <TextBox x:Name="txtUrl"
                                 Grid.Row="7" Grid.Column="4"
                                 Margin="0,22,0,0"
                                 Height="28"
                                 MinWidth="200"
                                 HorizontalAlignment="Left"/>

                        <!-- ================== ROW 8: EMAIL ERROR ================== -->
                        <StackPanel x:Name="EmailErrorPanel"
                                    Grid.Row="8" Grid.Column="2"
                                    Margin="0,6,0,0"
                                    Visibility="Collapsed">
                            <TextBlock x:Name="EmailErrorText"
                                       Foreground="#D32F2F"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- ================== ROW 10: PHONE ================== -->
                        <Label Grid.Row="10" Grid.Column="0"
                               Content="Phone Number"
                               FontWeight="Bold"/>
                        <Grid Grid.Row="10" Grid.Column="0"
                              Margin="0,22,0,0"
                              Height="28"
                              MinWidth="320"
                              HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <PasswordBox x:Name="txtPhone"
                                             VerticalAlignment="Center"
                                             Height="28"
                                             PasswordChanged="txtPhone_PasswordChanged"
                                             LostFocus="txtPhone_LostFocus"/>
                                <TextBox x:Name="txtPhonePlain"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         IsReadOnly="True"
                                         IsHitTestVisible="False"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Visibility="Collapsed"
                                         Foreground="Black"/>
                            </Grid>

                            <Button x:Name="btnTogglePhoneReveal"
                                    Grid.Column="1"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    ToolTip="Show/Hide phone number"
                                    Click="BtnTogglePhoneReveal_Click">
                                <Viewbox Stretch="Uniform">
                                    <Grid Width="20" Height="20">
                                        <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                              Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                        <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Ellipse Width="3" Height="3" Fill="Black"
                                                 HorizontalAlignment="Center"/>
                                    </Grid>
                                </Viewbox>
                            </Button>
                        </Grid>

                        <!-- ================== ROW 11: PHONE ERROR ================== -->
                        <StackPanel x:Name="PhoneErrorPanel"
                                    Grid.Row="11" Grid.Column="0"
                                    Margin="0,6,0,0"
                                    Visibility="Collapsed">
                            <TextBlock x:Name="PhoneErrorText"
                                       Foreground="#D32F2F"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- ================== ROW 13: NOTES ================== -->
                        <Label Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="5"
                               Content="Freeform Notes"
                               FontWeight="Bold"/>
                        <TextBox x:Name="txtDescription"
                                 Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="5"
                                 Margin="0,22,0,0"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="48"/>

                        <!-- ================== ROW 14: INFO STRIP + BUTTONS ================== -->
                        <Grid Grid.Row="14"
                              Grid.Column="0"
                              Grid.ColumnSpan="5"
                              Margin="0,16,0,10"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Info block (match AppEntryWindow InfoBanner dark-blue style) -->
                            <Border x:Name="ActionInfoStrip"
                                    Grid.Column="0"
                                    Margin="0,0,12,0"
                                    Padding="10"
                                    Background="{StaticResource InfoBannerBackground}"
                                    BorderBrush="{StaticResource InfoBannerBorder}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="ActionInfoText"
                                           Foreground="{StaticResource InfoBannerForeground}"
                                           FontSize="13"
                                           TextWrapping="Wrap">
                                    <Run Text="Tab changes save when there are no errors.  "/>
                                    <Run Text="Save " FontWeight="SemiBold"/>
                                    <Run Text="saves and closes.  "/>
                                    <Run Text="Cancel " FontWeight="SemiBold"/>
                                    <Run Text="exits (no save)."/>
                                </TextBlock>
                            </Border>

                            <!-- Buttons -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button x:Name="btnSubmit"
                                        Style="{StaticResource DialogPrimary}"
                                        Margin="0,0,12,0"
                                        Click="btnSubmit_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                   Text="&#xE8FB;"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="Save"/>
                                    </StackPanel>
                                </Button>

                                <Button x:Name="btnCancel"
                                        Style="{StaticResource DialogSecondary}"
                                        Click="btnCancel_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                   Text="&#xE711;"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="Cancel"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                    </Grid>
                </TabItem>

                <!-- ========== BANK CARDS TAB ========== -->
                <TabItem Header="Bank Cards">
                    <Grid Margin="20" Background="Bisque">
                        <categoryItems:CategoryItemBankCardsPanel/>
                    </Grid>
                </TabItem>

                <!-- ========== ACCOUNTS TAB ========== -->
                <TabItem Header="Accounts">
                    <Grid Margin="20" Background="Bisque">
                        <StackPanel>
                            <TextBlock Text="Account details will go here."
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="(Then we’ll carve the Accounts section out of CategoryItemBankAndSecurityPanel into a separate control and drop it in this tab.)"
                                       TextWrapping="Wrap"
                                       FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ========== SECURITY QUESTIONS TAB ========== -->
                <TabItem Header="Security Q/A">
                    <Grid Margin="20" Background="Bisque">
                        <StackPanel>
                            <TextBlock Text="Security questions and answers will go here."
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="(Finally we’ll move just the Security Questions piece into its own control and host it here.)"
                                       TextWrapping="Wrap"
                                       FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

            </TabControl>
        </ScrollViewer>

        <!-- ====================== STATUS LINE (always visible; not tied to any tab) ====================== -->
        <Border Grid.Row="2"
                Background="Transparent"
                Padding="10,6"
                Margin="8,0,8,8">
            <TextBlock x:Name="txtStatusLine"
                       Text=""
                       FontWeight="Bold"
                       FontSize="13"
                       Foreground="DarkGreen"
                       TextWrapping="Wrap"/>
        </Border>

    </Grid>
</UserControl>
