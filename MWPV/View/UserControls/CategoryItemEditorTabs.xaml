<UserControl x:Class="MWPV.View.UserControls.CategoryItemEditorTabs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="940"
             Focusable="True">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PwWeak"        Color="#D32F2F"/>
        <SolidColorBrush x:Key="PwFair"        Color="#FBC02D"/>
        <SolidColorBrush x:Key="PwStrong"      Color="#388E3C"/>
        <SolidColorBrush x:Key="PwVeryStrong"  Color="#2E7D32"/>

        <SolidColorBrush x:Key="FieldErrorFill" Color="#FFFFEEEE"/>

        <Style x:Key="SmallSquarePrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryNormalBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource DisabledBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource DisabledForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <!-- header -->
            <RowDefinition Height="*"/>
            <!-- scrollable body -->
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Primary}"
                Padding="12,0,6,0">
            <TextBlock VerticalAlignment="Center"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="16"
                       Text="Add / Edit Category Item"/>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True"
                      PanningMode="VerticalOnly"
                      Focusable="False">
            <!-- Shared-size scope so columns line up -->
            <Grid Margin="20"
                  Grid.IsSharedSizeScope="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 0: name / password -->
                    <RowDefinition Height="Auto"/>
                    <!-- 1: strength + verify err -->
                    <RowDefinition Height="10"/>
                    <!-- 2: spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- 3: user/email/url row -->
                    <RowDefinition Height="Auto"/>
                    <!-- 4: email error -->
                    <RowDefinition Height="10"/>
                    <!-- 5: spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- 6: phone -->
                    <RowDefinition Height="Auto"/>
                    <!-- 7: phone error -->
                    <RowDefinition Height="10"/>
                    <!-- 8: spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- 9: notes -->
                    <RowDefinition Height="Auto"/>
                    <!-- 10: Save/Cancel buttons -->
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- Name -->
                <Label Grid.Row="0" Grid.Column="0"
                       Content="* Category Item Name"
                       FontWeight="Bold"
                       ToolTip="Required field"/>
                <TextBox x:Name="txtItemName"
                         Grid.Row="0" Grid.Column="0"
                         Margin="0,22,0,0"
                         Height="28"
                         MinWidth="320"
                         HorizontalAlignment="Left"/>

                <!-- Password label -->
                <Label Grid.Row="0" Grid.Column="2"
                       Content="* Password"
                       FontWeight="Bold"
                       ToolTip="Required field"/>

                <!-- Password row: password + buttons + bookmark-only checkbox all in one line -->
                <Grid Grid.Row="0" Grid.Column="2"
                      Margin="0,22,0,0"
                      Height="28"
                      MinWidth="125"
                      HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Password / plain overlay -->
                    <Grid Grid.Column="0">
                        <PasswordBox x:Name="pwdPassword"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     MinWidth="220"
                                     HorizontalAlignment="Stretch"
                                     PasswordChanged="pwdPassword_PasswordChanged"
                                     GotFocus="pwdPassword_GotFocus"
                                     PreviewKeyDown="PwdPassword_PreviewKeyDown"/>
                        <TextBox x:Name="txtPasswordPlain"
                                 VerticalAlignment="Center"
                                 Height="28"
                                 MinWidth="220"
                                 HorizontalAlignment="Stretch"
                                 IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="Collapsed"
                                 Foreground="Black"/>
                    </Grid>

                    <!-- Generate -->
                    <Button x:Name="btnGeneratePassword"
                            Grid.Column="1"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Generate password"
                            Click="BtnGeneratePassword_Click">
                        <Viewbox Stretch="Uniform">
                            <Canvas Width="18" Height="18">
                                <Path Fill="Black"
                                      Data="M9,1.6 L10.1,5.3 13.6,4.2 11.6,7.3 15.4,8.4 11.6,9.5 13.6,12.6 10.1,11.5 9,15.2 7.9,11.5 4.4,12.6 6.4,9.5 2.6,8.4 6.4,7.3 4.4,4.2 7.9,5.3 z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Reveal -->
                    <Button x:Name="btnTogglePasswordReveal"
                            Grid.Column="2"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Show/Hide password"
                            Click="BtnTogglePasswordReveal_Click">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="20" Height="20">
                                <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                      Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Ellipse Width="3" Height="3" Fill="Black"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Viewbox>
                    </Button>

                    <!-- Bookmark-only toggle -->
                    <CheckBox x:Name="chkBookmarkOnly"
                              Grid.Column="3"
                              VerticalAlignment="Center"
                              Margin="8,0,0,0"
                              Content="Bookmark only"
                              ToolTip="If checked, this item will be treated as a bookmark-only entry with no password."/>
                </Grid>

                <!-- Verify password -->
                <Grid x:Name="VerifyRow"
                      Grid.Row="0" Grid.Column="4"
                      Visibility="Collapsed"
                      HorizontalAlignment="Left">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Content="Verify Password"
                           FontWeight="Bold"
                           Grid.Row="0"
                           Margin="0,0,0,4"/>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left">
                        <Grid Height="28"
                              Width="125">
                            <PasswordBox x:Name="pwdVerify"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         HorizontalAlignment="Stretch"
                                         PasswordChanged="pwdVerify_PasswordChanged"/>
                            <TextBox x:Name="txtVerifyPlain"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     HorizontalAlignment="Stretch"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black"/>
                        </Grid>

                        <!-- Reveal verify -->
                        <Button x:Name="btnToggleVerifyReveal"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show/Hide verification"
                                Margin="4,0,0,0"
                                Click="BtnToggleVerifyReveal_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                    <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse Width="3" Height="3" Fill="Black"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Viewbox>
                        </Button>

                        <!-- Spacer button: not used, hidden but keeps layout width -->
                        <Button x:Name="btnVerifyNotUsed"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                Margin="4,0,0,0"
                                Visibility="Hidden"
                                IsHitTestVisible="False"
                                ToolTip="(not used – spacer only)"/>
                    </StackPanel>
                </Grid>

                <!-- Strength -->
                <StackPanel x:Name="StrengthPanel"
                            Grid.Row="1" Grid.Column="2"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <ProgressBar x:Name="PwStrengthBar"
                                 Height="8"
                                 Minimum="0"
                                 Maximum="1"
                                 Value="0"
                                 Background="#22000000"/>
                    <TextBlock x:Name="PwStrengthText"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="Black"
                               Text=""/>
                    <ItemsControl x:Name="PwTipsList"
                                  Margin="0,2,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="• "/>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Verify error -->
                <StackPanel x:Name="VerifyErrorPanel"
                            Grid.Row="1" Grid.Column="4"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="VerifyErrorText"
                               Foreground="#D32F2F"
                               FontWeight="Bold"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- User/email/url -->
                <Label Grid.Row="3" Grid.Column="0"
                       Content="User Name"
                       FontWeight="Bold"/>
                <TextBox x:Name="txtUsername"
                         Grid.Row="3" Grid.Column="0"
                         Margin="0,22,0,0"
                         Height="28"
                         MinWidth="240"
                         HorizontalAlignment="Left"/>

                <Label Grid.Row="3" Grid.Column="2"
                       Content="Email"
                       FontWeight="Bold"/>
                <TextBox x:Name="txtEmail"
                         Grid.Row="3" Grid.Column="2"
                         Margin="0,22,0,0"
                         Height="28"
                         MinWidth="240"
                         HorizontalAlignment="Left"
                         LostFocus="txtEmail_LostFocus"/>

                <Label Grid.Row="3" Grid.Column="4"
                       Content="URL or Absolute Location"
                       FontWeight="Bold"/>
                <TextBox x:Name="txtUrl"
                         Grid.Row="3" Grid.Column="4"
                         Margin="0,22,0,0"
                         Height="28"
                         MinWidth="220"
                         HorizontalAlignment="Left"/>

                <StackPanel x:Name="EmailErrorPanel"
                            Grid.Row="4" Grid.Column="2"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="EmailErrorText"
                               Foreground="#D32F2F"
                               FontWeight="Bold"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Phone -->
                <Label Grid.Row="6" Grid.Column="0"
                       Content="Phone Number"
                       FontWeight="Bold"/>
                <Grid Grid.Row="6" Grid.Column="0"
                      Margin="0,22,0,0"
                      Height="28"
                      MinWidth="320"
                      HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <PasswordBox x:Name="txtPhone"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     PasswordChanged="txtPhone_PasswordChanged"
                                     LostFocus="txtPhone_LostFocus"/>
                        <TextBox x:Name="txtPhonePlain"
                                 VerticalAlignment="Center"
                                 Height="28"
                                 IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="Collapsed"
                                 Foreground="Black"/>
                    </Grid>

                    <Button x:Name="btnTogglePhoneReveal"
                            Grid.Column="1"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Show/Hide phone number"
                            Click="BtnTogglePhoneReveal_Click">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="20" Height="20">
                                <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                      Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Ellipse Width="3" Height="3" Fill="Black"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Viewbox>
                    </Button>
                </Grid>

                <StackPanel x:Name="PhoneErrorPanel"
                            Grid.Row="7" Grid.Column="0"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="PhoneErrorText"
                               Foreground="#D32F2F"
                               FontWeight="Bold"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Notes -->
                <Label Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="5"
                       Content="Freeform Notes"
                       FontWeight="Bold"/>
                <TextBox x:Name="txtDescription"
                         Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="5"
                         Margin="0,22,0,0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="48"/>

                <!-- Save / Cancel buttons inside scrollable content -->
                <StackPanel Grid.Row="10"
                            Grid.Column="0"
                            Grid.ColumnSpan="5"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,10">
                    <Button x:Name="btnSubmit"
                            Style="{StaticResource DialogPrimary}"
                            Margin="0,0,12,0"
                            Click="btnSubmit_Click">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8FB;"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Save"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnCancel"
                            Style="{StaticResource DialogSecondary}"
                            Click="btnCancel_Click">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE711;"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="Cancel"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
