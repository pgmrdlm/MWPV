<UserControl x:Class="MWPV.View.UserControls.CategoryItemEditorTabs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:categoryItems="clr-namespace:MWPV.View.UserControls.CategoryItems"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="940"
             Focusable="True">

    <UserControl.Resources>
        <!-- Password-strength brushes (local; ok) -->
        <SolidColorBrush x:Key="PwWeak"       Color="#D32F2F"/>
        <SolidColorBrush x:Key="PwFair"       Color="#FBC02D"/>
        <SolidColorBrush x:Key="PwStrong"     Color="#388E3C"/>
        <SolidColorBrush x:Key="PwVeryStrong" Color="#2E7D32"/>

        <SolidColorBrush x:Key="FieldErrorFill" Color="#FFFFEEEE"/>

        <!-- Info strip colors (match AppEntryWindow InfoBanner) -->
        <SolidColorBrush x:Key="InfoBannerBackground" Color="#1E40AF"/>
        <SolidColorBrush x:Key="InfoBannerBorder"     Color="#1D4ED8"/>
        <SolidColorBrush x:Key="InfoBannerForeground" Color="White"/>

        <!-- Small square primary icon button -->
        <Style x:Key="SmallSquarePrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryNormalBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DisabledBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Simple tab styling -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Bisque"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="Bisque"/>
        </Style>
    </UserControl.Resources>

    <!-- Outer panel background stays Bisque so it matches old layout -->
    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Primary}"
                Padding="12,0,6,0">
            <TextBlock VerticalAlignment="Center"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="16"
                       Text="Add / Edit Category Item"/>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1"
                      Background="Bisque"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True"
                      PanningMode="VerticalOnly"
                      Focusable="False">

            <TabControl x:Name="ItemTabs"
                        Margin="8"
                        SelectedIndex="0">

                <!-- ========== BASIC TAB ========== -->
                <TabItem Header="Basic">
                    <categoryItems:CategoryItemBasicPanel x:Name="BasicPanel"/>
                </TabItem>

                <!-- ========== BANK CARDS TAB ========== -->
                <TabItem Header="Bank Cards">
                    <Grid Margin="20" Background="Bisque">
                        <categoryItems:CategoryItemBankCardsPanel x:Name="BankCardsPanel"/>
                    </Grid>
                </TabItem>

                <!-- ========== ACCOUNTS TAB ========== -->
                <TabItem Header="Accounts">
                    <Grid Margin="20" Background="Bisque">
                        <categoryItems:CategoryItemAccountsPanel x:Name="AccountsPanel"/>
                    </Grid>
                </TabItem>

                <!-- ========== SECURITY QUESTIONS TAB ========== -->
                <TabItem Header="Security Q/A">
                    <Grid Margin="20" Background="Bisque">
                        <StackPanel>
                            <TextBlock Text="Security questions and answers will go here."
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="(Finally we’ll move just the Security Questions piece into its own control and host it here.)"
                                       TextWrapping="Wrap"
                                       FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

            </TabControl>
        </ScrollViewer>

        <!-- STATUS LINE -->
        <Border Grid.Row="2"
                Background="Transparent"
                Padding="10,6"
                Margin="8,0,8,8">
            <TextBlock x:Name="txtStatusLine"
                       Text=""
                       FontWeight="Bold"
                       FontSize="13"
                       Foreground="DarkGreen"
                       TextWrapping="Wrap"/>
        </Border>

    </Grid>
</UserControl>
