<UserControl x:Class="MWPV.View.UserControls.CategoryItemNew"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="940"
             Focusable="True">

    <UserControl.Resources>
        <!-- Strength brushes (match AppEntryWindow) -->
        <SolidColorBrush x:Key="PwWeak"        Color="#D32F2F"/>
        <SolidColorBrush x:Key="PwFair"        Color="#FBC02D"/>
        <SolidColorBrush x:Key="PwStrong"      Color="#388E3C"/>
        <SolidColorBrush x:Key="PwVeryStrong"  Color="#2E7D32"/>

        <!-- Email/phone error fill -->
        <SolidColorBrush x:Key="FieldErrorFill" Color="#FFFFEEEE"/>

        <!-- compact green square button (uses your gradient resources) -->
        <Style x:Key="SmallSquarePrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="4"
                                Background="{DynamicResource PrimaryNormalBrush}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource DisabledBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource DisabledForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Primary}"
                Padding="12,0,6,0">
            <TextBlock VerticalAlignment="Center"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="16"
                       Text="Add / Edit Category Item"/>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True"
                      PanningMode="VerticalOnly"
                      Focusable="False">
            <Grid Margin="20">
                <!-- Layout rows -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 0: name/password/verify -->
                    <RowDefinition Height="Auto"/>
                    <!-- 1: strength + verify error -->
                    <RowDefinition Height="10"/>
                    <!-- 2 spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- 3: username/email/url -->
                    <RowDefinition Height="Auto"/>
                    <!-- 4: email error -->
                    <RowDefinition Height="10"/>
                    <!-- 5 spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- 6: phone -->
                    <RowDefinition Height="Auto"/>
                    <!-- 7: phone error -->
                    <RowDefinition Height="10"/>
                    <!-- 8 spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- 9: notes -->
                    <RowDefinition Height="16"/>
                    <!-- 10 spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- 11: bank header -->
                    <RowDefinition Height="10"/>
                    <!-- 12 spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- 13: card line -->
                    <RowDefinition Height="10"/>
                    <!-- 14 spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- 15: account line -->
                    <RowDefinition Height="10"/>
                    <!-- 16 spacer -->
                    <RowDefinition Height="Auto"/>
                    <!-- 17: security Q/A (future) -->
                </Grid.RowDefinitions>

                <!-- Columns -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <!-- left -->
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="2*"/>
                    <!-- middle -->
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="3*"/>
                    <!-- right -->
                </Grid.ColumnDefinitions>

                <!-- ===== row 0: NAME ===== -->
                <Label Grid.Row="0" Grid.Column="0"
                       Content="* Category Item Name"
                       FontWeight="Bold"
                       ToolTip="Required field"/>
                <TextBox x:Name="txtItemName"
                         Grid.Row="0" Grid.Column="0"
                         Margin="0,22,0,0"
                         Height="28"
                         MinWidth="320"
                         HorizontalAlignment="Left"/>

                <!-- ===== row 0: PASSWORD ===== -->
                <Label Grid.Row="0" Grid.Column="2"
                       Content="* Password"
                       FontWeight="Bold"
                       ToolTip="Required field"/>
                <Grid Grid.Row="0" Grid.Column="2"
                      Margin="0,22,0,0"
                      Height="28"
                      MinWidth="280"
                      HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- masked + plain overlay -->
                    <Grid Grid.Column="0">
                        <PasswordBox x:Name="pwdPassword"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     PasswordChanged="pwdPassword_PasswordChanged"
                                     GotFocus="pwdPassword_GotFocus"
                                     PreviewKeyDown="PwdPassword_PreviewKeyDown"/>
                        <TextBox x:Name="txtPasswordPlain"
                                 VerticalAlignment="Center"
                                 Height="28"
                                 IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="Collapsed"
                                 Foreground="Black"/>
                    </Grid>

                    <!-- generate -->
                    <Button x:Name="btnGeneratePassword"
                            Grid.Column="1"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Generate password"
                            Click="BtnGeneratePassword_Click">
                        <Viewbox Stretch="Uniform">
                            <Canvas Width="18" Height="18">
                                <Path Fill="Black"
                                      Data="M9,1.6 L10.1,5.3 13.6,4.2 11.6,7.3 15.4,8.4 11.6,9.5 13.6,12.6 10.1,11.5 9,15.2 7.9,11.5 4.4,12.6 6.4,9.5 2.6,8.4 6.4,7.3 4.4,4.2 7.9,5.3 z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- reveal -->
                    <Button x:Name="btnTogglePasswordReveal"
                            Grid.Column="2"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Show/Hide password"
                            Click="BtnTogglePasswordReveal_Click">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="20" Height="20">
                                <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                      Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Ellipse Width="3" Height="3" Fill="Black"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Viewbox>
                    </Button>
                </Grid>

                <!-- ===== row 0: VERIFY ===== -->
                <Grid x:Name="VerifyRow"
                      Grid.Row="0" Grid.Column="4"
                      Visibility="Collapsed"
                      HorizontalAlignment="Left">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Content="Verify Password"
                           FontWeight="Bold"
                           Grid.Row="0"
                           Margin="0,0,0,4"/>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left">
                        <Grid Width="280" Height="28">
                            <PasswordBox x:Name="pwdVerify"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         PasswordChanged="pwdVerify_PasswordChanged"/>
                            <TextBox x:Name="txtVerifyPlain"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black"/>
                        </Grid>

                        <!-- view button for verify -->
                        <Button x:Name="btnToggleVerifyReveal"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show/Hide verification"
                                Margin="4,0,0,0"
                                Click="BtnToggleVerifyReveal_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                    <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse Width="3" Height="3" Fill="Black"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ===== row 1: strength under password ===== -->
                <StackPanel x:Name="StrengthPanel"
                            Grid.Row="1" Grid.Column="2"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <ProgressBar x:Name="PwStrengthBar"
                                 Height="8"
                                 Minimum="0"
                                 Maximum="1"
                                 Value="0"
                                 Background="#22000000"/>
                    <TextBlock x:Name="PwStrengthText"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="Black"
                               Text=""/>
                    <ItemsControl x:Name="PwTipsList"
                                  Margin="0,2,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="• "/>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ===== row 1: verify error under verify ===== -->
                <StackPanel x:Name="VerifyErrorPanel"
                            Grid.Row="1" Grid.Column="4"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="VerifyErrorText"
                               Foreground="#D32F2F"
                               FontWeight="Bold"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ===== row 3: user / email / url ===== -->
                <Label Grid.Row="3" Grid.Column="0"
                       Content="User Name"
                       FontWeight="Bold"/>
                <TextBox x:Name="txtUsername"
                         Grid.Row="3" Grid.Column="0"
                         Margin="0,22,0,0"
                         Height="28"
                         MinWidth="240"
                         HorizontalAlignment="Left"/>

                <Label Grid.Row="3" Grid.Column="2"
                       Content="Email"
                       FontWeight="Bold"/>
                <TextBox x:Name="txtEmail"
                         Grid.Row="3" Grid.Column="2"
                         Margin="0,22,0,0"
                         Height="28"
                         MinWidth="240"
                         HorizontalAlignment="Left"
                         LostFocus="txtEmail_LostFocus"/>

                <Label Grid.Row="3" Grid.Column="4"
                       Content="URL or Absolute Location"
                       FontWeight="Bold"/>
                <TextBox x:Name="txtUrl"
                         Grid.Row="3" Grid.Column="4"
                         Margin="0,22,0,0"
                         Height="28"
                         MinWidth="220"
                         HorizontalAlignment="Left"/>

                <!-- ===== row 4: email error ===== -->
                <StackPanel x:Name="EmailErrorPanel"
                            Grid.Row="4" Grid.Column="2"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="EmailErrorText"
                               Foreground="#D32F2F"
                               FontWeight="Bold"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ===== row 6: phone ===== -->
                <Label Grid.Row="6" Grid.Column="0"
                       Content="Phone Number"
                       FontWeight="Bold"/>
                <Grid Grid.Row="6" Grid.Column="0"
                      Margin="0,22,0,0"
                      Height="28"
                      MinWidth="320"
                      HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- masked + plain overlay -->
                    <Grid Grid.Column="0">
                        <PasswordBox x:Name="txtPhone"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     PasswordChanged="txtPhone_PasswordChanged"
                                     LostFocus="txtPhone_LostFocus"/>
                        <TextBox x:Name="txtPhonePlain"
                                 VerticalAlignment="Center"
                                 Height="28"
                                 IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="Collapsed"
                                 Foreground="Black"/>
                    </Grid>

                    <!-- reveal -->
                    <Button x:Name="btnTogglePhoneReveal"
                            Grid.Column="1"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Show/Hide phone number"
                            Click="BtnTogglePhoneReveal_Click">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="20" Height="20">
                                <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                      Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Ellipse Width="3" Height="3" Fill="Black"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Viewbox>
                    </Button>
                </Grid>

                <!-- ===== row 7: phone error ===== -->
                <StackPanel x:Name="PhoneErrorPanel"
                            Grid.Row="7" Grid.Column="0"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="PhoneErrorText"
                               Foreground="#D32F2F"
                               FontWeight="Bold"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ===== row 9: notes ===== -->
                <Label Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="5"
                       Content="Freeform Notes"
                       FontWeight="Bold"/>
                <TextBox x:Name="txtDescription"
                         Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="5"
                         Margin="0,22,0,0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="48"/>

                <!-- ===== row 11: bank section header ===== -->
                <TextBlock Grid.Row="11"
                           Grid.Column="0"
                           Grid.ColumnSpan="5"
                           Text="Bank Cards / Accounts"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <!-- ===== row 13: Bank CARD line ===== -->
                <Grid Grid.Row="13"
                      Grid.Column="0"
                      Grid.ColumnSpan="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- labels -->
                        <RowDefinition Height="Auto"/>
                        <!-- fields -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <!-- card type -->
                        <ColumnDefinition Width="2.4*"/>
                        <!-- card number -->
                        <ColumnDefinition Width="2*"/>
                        <!-- exp date -->
                        <ColumnDefinition Width="2*"/>
                        <!-- CVV group (field+eye) -->
                        <ColumnDefinition Width="2*"/>
                        <!-- Card PIN group (field+eye) -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- add/clear group -->
                    </Grid.ColumnDefinitions>

                    <!-- labels -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Card Type"
                               FontWeight="Bold"
                               Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="Card Number"
                               FontWeight="Bold"
                               Margin="10,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="Expiration Date"
                               FontWeight="Bold"
                               Margin="10,0,0,4"/>
                    <!-- CVV heading aligns with field inside CVV group -->
                    <TextBlock Grid.Row="0" Grid.Column="3"
                               Text="CVV"
                               FontWeight="Bold"
                               Margin="10,0,0,4"/>
                    <!-- Card PIN heading aligns with field inside Card PIN group -->
                    <TextBlock Grid.Row="0" Grid.Column="4"
                               Text="Card PIN"
                               FontWeight="Bold"
                               Margin="10,0,0,4"/>

                    <!-- Card Type -->
                    <ComboBox x:Name="cboCardType"
                              Grid.Row="1" Grid.Column="0"
                              Margin="0,0,0,0"
                              Height="28"
                              MinWidth="150"
                              HorizontalAlignment="Left"
                              Style="{StaticResource FilterComboStyle}"
                              DisplayMemberPath="Description"
                              SelectedValuePath="Code"/>

                    <!-- Card Number -->
                    <TextBox x:Name="txtCardNumber"
                             Grid.Row="1" Grid.Column="1"
                             Margin="10,0,0,0"
                             Height="28"
                             MinWidth="150"
                             HorizontalAlignment="Left"/>

                    <!-- Expiration Date -->
                    <TextBox x:Name="txtExpDate"
                             Grid.Row="1" Grid.Column="2"
                             Margin="10,0,0,0"
                             Height="28"
                             Width="140"
                             MaxLength="10"
                             HorizontalAlignment="Left"/>

                    <!-- CVV group: field + eye, like Password -->
                    <Grid Grid.Row="1" Grid.Column="3"
                          Margin="10,0,0,0"
                          Height="28"
                          HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- field (masked/plain overlay) -->
                        <Grid Grid.Column="0">
                            <PasswordBox x:Name="txtCvv"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         Width="120"
                                         MaxLength="6"
                                         PasswordChanged="txtCvv_PasswordChanged"/>
                            <TextBox x:Name="txtCvvPlain"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     Width="120"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black"/>
                        </Grid>

                        <!-- eye -->
                        <Button x:Name="btnToggleCvvReveal"
                                Grid.Column="1"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show/Hide CVV"
                                Click="BtnToggleCvvReveal_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                    <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse Width="3" Height="3" Fill="Black"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                    </Grid>

                    <!-- Card PIN group: field + eye -->
                    <Grid Grid.Row="1" Grid.Column="4"
                          Margin="10,0,0,0"
                          Height="28"
                          HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- field (masked/plain overlay) -->
                        <Grid Grid.Column="0">
                            <PasswordBox x:Name="txtCardPin"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         Width="120"
                                         MaxLength="12"
                                         PasswordChanged="txtCardPin_PasswordChanged"/>
                            <TextBox x:Name="txtCardPinPlain"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     Width="120"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black"/>
                        </Grid>

                        <!-- eye -->
                        <Button x:Name="btnToggleCardPinReveal"
                                Grid.Column="1"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show/Hide card PIN"
                                Click="BtnToggleCardPinReveal_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                    <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse Width="3" Height="3" Fill="Black"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                    </Grid>

                    <!-- Add / Clear group (full-line actions, visually separate) -->
                    <Border Grid.Row="1" Grid.Column="5"
                            Margin="20,0,0,0"
                            Padding="8,2"
                            CornerRadius="8"
                            Background="{DynamicResource Brush.Primary}"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <!-- Add (+) bank card (wire up later) -->
                            <Button x:Name="btnBankCardAdd"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    ToolTip="Add this card to the in-memory list">
                                <TextBlock Text="+"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Button>

                            <!-- Clear current bank card fields -->
                            <Button x:Name="btnBankCardClear"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    Margin="8,0,0,0"
                                    ToolTip="Clear the bank card fields">
                                <TextBlock Text="X"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===== row 15: ACCOUNT line ===== -->
                <Label Grid.Row="15" Grid.Column="0"
                       Content="Account Name"
                       FontWeight="Bold"/>
                <Label Grid.Row="15" Grid.Column="2"
                       Content="Account Number"
                       FontWeight="Bold"/>
                <Label Grid.Row="15" Grid.Column="4"
                       Content="Account PIN (optional)"
                       FontWeight="Bold"/>

                <ComboBox x:Name="cboAccountName"
                          Grid.Row="15" Grid.Column="0"
                          Margin="0,22,0,0"
                          Height="28"
                          MinWidth="150"
                          MaxWidth="220"
                          HorizontalAlignment="Left"
                          Style="{StaticResource FilterComboStyle}"/>

                <TextBox x:Name="txtAccountNumber"
                         Grid.Row="15" Grid.Column="2"
                         Margin="0,22,0,0"
                         Height="28"
                         Width="260"
                         MaxLength="24"
                         HorizontalAlignment="Left"/>

                <PasswordBox x:Name="txtAccountPin"
                             Grid.Row="15" Grid.Column="4"
                             Margin="0,22,0,0"
                             Height="28"
                             Width="120"
                             MaxLength="12"
                             HorizontalAlignment="Left"/>

                <!-- row 17: Security Questions / Answers area goes here later -->
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <Button x:Name="btnSubmit"
                    Style="{StaticResource DialogPrimary}"
                    Margin="0,0,12,0"
                    Click="btnSubmit_Click">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE8FB;"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Submit"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCancel"
                    Style="{StaticResource DialogSecondary}"
                    Click="btnCancel_Click">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE711;"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Cancel"/>
