﻿<UserControl x:Class="MWPV.View.UserControls.CategoryItemNew"
>>>>>>> CategoryItemChanges
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="940"
             Focusable="True">

    <UserControl.Resources>
        <!-- Strength brushes (match AppEntryWindow) -->
        <SolidColorBrush x:Key="PwWeak"        Color="#D32F2F"/>
        <SolidColorBrush x:Key="PwFair"        Color="#FBC02D"/>
        <SolidColorBrush x:Key="PwStrong"      Color="#388E3C"/>
        <SolidColorBrush x:Key="PwVeryStrong"  Color="#2E7D32"/>

        <!-- Email error fill (very light red for visibility) -->
        <SolidColorBrush x:Key="FieldErrorFill" Color="#FFFFEEEE"/>

        <!-- compact green square button (uses your gradient resources) -->
        <Style x:Key="SmallSquarePrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="4"
                                Background="{DynamicResource PrimaryNormalBrush}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource DisabledBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource DisabledForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Primary}" Padding="12,0,6,0">
            <TextBlock VerticalAlignment="Center"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="16"
                       Text="Add / Edit Category Item"/>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True"
                      PanningMode="VerticalOnly"
                      Focusable="False">
            <Grid Margin="20">
                <!-- Layout rows:
                     0 : Name / Password / Verify
                     1 : Strength (under Password)  +  VerifyError (under Verify)
                     2 : spacer
                     3 : User / Email / URL
                     4 : EmailError (under Email)
                     5 : spacer
                     6 : Phone only  (Security Q/A single-line REMOVED)
                     7 : spacer
                     8 : Notes (full width)
                     9 : spacer
                     10: Bank title
                     11: spacer
                     12: CardType / Exp / CVV
                     13: spacer
                     14: AccountName / AccountNumber / PIN
                     15: spacer
                     16: Security Questions (optional) block
                -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="160"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== row 0: NAME ===== -->
                <Label Grid.Row="0" Grid.Column="0" Content="Category Item Name" FontWeight="Bold"/>
                <TextBox x:Name="txtItemName"
                         Grid.Row="0" Grid.Column="0"
                         Margin="0,22,0,0" Height="28" MinWidth="320"
                         HorizontalAlignment="Left"/>

                <!-- ===== row 0: PASSWORD ===== -->
                <Label Grid.Row="0" Grid.Column="2" Content="Password" FontWeight="Bold"/>
                <Grid Grid.Row="0" Grid.Column="2" Margin="0,22,0,0" Height="28" MinWidth="280" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- masked + plain overlay -->
                    <Grid Grid.Column="0">
                        <PasswordBox x:Name="pwdPassword"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     PasswordChanged="pwdPassword_PasswordChanged"
                                     GotFocus="pwdPassword_GotFocus"/>
                        <TextBox x:Name="txtPasswordPlain"
                                 VerticalAlignment="Center"
                                 Height="28"
                                 IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="Collapsed"
                                 Foreground="Black"/>
                    </Grid>

                    <!-- generate -->
                    <Button x:Name="btnGeneratePassword"
                            Grid.Column="1"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Generate password"
                            Click="BtnGeneratePassword_Click">
                        <Viewbox Stretch="Uniform">
                            <Canvas Width="18" Height="18">
                                <Path Fill="Black"
                                      Data="M9,1.6 L10.1,5.3 13.6,4.2 11.6,7.3 15.4,8.4 11.6,9.5 13.6,12.6 10.1,11.5 9,15.2 7.9,11.5 4.4,12.6 6.4,9.5 2.6,8.4 6.4,7.3 4.4,4.2 7.9,5.3 z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- reveal -->
                    <Button x:Name="btnTogglePasswordReveal"
                            Grid.Column="2"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Show/Hide password"
                            Click="BtnTogglePasswordReveal_Click">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="20" Height="20">
                                <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                      Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Ellipse Width="3" Height="3" Fill="Black"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Viewbox>
                    </Button>
                </Grid>

                <!-- ===== row 0: VERIFY (right of Password) ===== -->
                <Grid x:Name="VerifyRow"
                      Grid.Row="0" Grid.Column="4"
                      Visibility="Collapsed"
                      HorizontalAlignment="Left">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Content="Verify Password" FontWeight="Bold" Grid.Row="0" Margin="0,0,0,4"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Grid Width="280" Height="28">
                            <PasswordBox x:Name="pwdVerify"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         PasswordChanged="pwdVerify_PasswordChanged"/>
                            <TextBox x:Name="txtVerifyPlain"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black"/>
                        </Grid>

                        <Button x:Name="btnToggleVerifyReveal"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show/Hide verification"
                                Margin="4,0,0,0"
                                Click="BtnToggleVerifyReveal_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                    <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse Width="3" Height="3" Fill="Black"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ===== row 1: strength (under Password) ===== -->
                <StackPanel x:Name="StrengthPanel"
                            Grid.Row="1" Grid.Column="2"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <ProgressBar x:Name="PwStrengthBar" Height="8" Minimum="0" Maximum="1" Value="0" Background="#22000000"/>
                    <TextBlock x:Name="PwStrengthText" Margin="0,4,0,0" FontSize="12" Foreground="Black" Text=""/>
                    <ItemsControl x:Name="PwTipsList" Margin="0,2,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="• "/>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ===== row 1: VERIFY ERROR (under Verify) ===== -->
                <StackPanel x:Name="VerifyErrorPanel"
                            Grid.Row="1" Grid.Column="4"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="VerifyErrorText"
                               Foreground="#D32F2F"
                               FontWeight="Bold"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ===== row 3: user / email / url ===== -->
                <Label Grid.Row="3" Grid.Column="0" Content="User Name" FontWeight="Bold"/>
                <TextBox x:Name="txtUsername"
                         Grid.Row="3" Grid.Column="0"
                         Margin="0,22,0,0" Height="28" MinWidth="240"
                         HorizontalAlignment="Left"/>

                <Label Grid.Row="3" Grid.Column="2" Content="Email" FontWeight="Bold"/>
                <TextBox x:Name="txtEmail"
                         Grid.Row="3" Grid.Column="2"
                         Margin="0,22,0,0" Height="28" MinWidth="240"
                         HorizontalAlignment="Left"
                         LostFocus="txtEmail_LostFocus"/>

                <Label Grid.Row="3" Grid.Column="4" Content="URL or Absolute Location" FontWeight="Bold"/>
                <TextBox x:Name="txtUrl"
                         Grid.Row="3" Grid.Column="4"
                         Margin="0,22,0,0" Height="28" MinWidth="220"/>

                <!-- ===== row 4: EMAIL ERROR (under Email) ===== -->
                <StackPanel x:Name="EmailErrorPanel"
                            Grid.Row="4" Grid.Column="2"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="EmailErrorText"
                               Foreground="#D32F2F"
                               FontWeight="Bold"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ===== row 6: phone only (legacy Security Q/A removed) ===== -->
                <Label Grid.Row="6" Grid.Column="0" Content="Phone Number" FontWeight="Bold"/>
                <TextBox x:Name="txtPhone"
                         Grid.Row="6" Grid.Column="0"
                         Margin="0,22,0,0" Height="28" MinWidth="180"
                         HorizontalAlignment="Left"/>

                <!-- ===== row 8: notes ===== -->
                <Label Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="5" Content="Freeform Notes" FontWeight="Bold"/>
                <TextBox x:Name="txtDescription"
                         Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="5"
                         Margin="0,22,0,0"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                <!-- ===== row 10: bank section ===== -->
                <TextBlock Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="5"
                           Text="Bank Cards / Accounts"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <!-- row 12: card type / exp / cvv -->
                <Label Grid.Row="12" Grid.Column="0" Content="Card Type"/>
                <Border Grid.Row="12" Grid.Column="0"
                        Margin="0,22,0,0" Height="28"
                        CornerRadius="4" Background="Transparent"
                        BorderBrush="#8A8A8A" BorderThickness="1">
                    <ComboBox x:Name="cboCardType"
                              Background="Transparent" BorderThickness="0"
                              Style="{StaticResource FilterComboStyle}"/>
                </Border>

                <Label Grid.Row="12" Grid.Column="2" Content="Expiration Date"/>
                <TextBox x:Name="txtExpDate"
                         Grid.Row="12" Grid.Column="2"
                         Margin="0,22,0,0" Height="28"/>

                <Label Grid.Row="12" Grid.Column="4" Content="CVV Code"/>
                <TextBox x:Name="txtCvv"
                         Grid.Row="12" Grid.Column="4"
                         Margin="0,22,0,0" Height="28"/>

                <!-- row 14: account name / number / pin -->
                <Label Grid.Row="14" Grid.Column="0" Content="Account Name"/>
                <Border Grid.Row="14" Grid.Column="0"
                        Margin="0,22,0,0" Height="28"
                        CornerRadius="4" Background="Transparent"
                        BorderBrush="#8A8A8A" BorderThickness="1">
                    <ComboBox x:Name="cboAccountName"
                              Background="Transparent" BorderThickness="0"
                              Style="{StaticResource FilterComboStyle}"/>
                </Border>

                <Label Grid.Row="14" Grid.Column="2" Content="Account Number"/>
                <TextBox x:Name="txtAccountNumber"
                         Grid.Row="14" Grid.Column="2"
                         Margin="0,22,0,0" Height="28"/>

                <Label Grid.Row="14" Grid.Column="4" Content="PIN"/>
                <TextBox x:Name="txtPin"
                         Grid.Row="14" Grid.Column="4"
                         Margin="0,22,0,0" Height="28"/>

                <!-- spacer before Q/A -->
                <Rectangle Grid.Row="15" Grid.Column="0" Grid.ColumnSpan="5" Height="10" Fill="Transparent"/>

                <!-- ===== row 16: Security Questions (optional) ===== -->
                <Border Grid.Row="16" Grid.Column="0" Grid.ColumnSpan="5"
                        BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="6" Padding="10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Security Questions (optional)" FontWeight="SemiBold" />
                            <TextBlock x:Name="QaCountText" Foreground="#666" Margin="8,0,0,0" Text="— 0"/>
                        </StackPanel>

                        <!-- Add row -->
                        <Grid Margin="0,8,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Question" FontSize="12" Foreground="#666"/>
                                <TextBox x:Name="qaNewQuestion" Height="28"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Answer" FontSize="12" Foreground="#666"/>
                                <PasswordBox x:Name="qaNewAnswer" Height="28"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <Button x:Name="qaAddButton" Content="Add" Height="28" MinWidth="80"/>
                            </StackPanel>
                        </Grid>

                        <!-- Column headers -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Question" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Column="1" Text="Answer" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="View" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Column="3" Text="Delete" FontWeight="Bold" FontSize="12"/>
                            <TextBlock Grid.Column="4" Text="Move" FontWeight="Bold" FontSize="12"/>
                        </Grid>

                        <!-- List -->
                        <Border BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="4">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="160">
                                <ItemsControl x:Name="qaList" Margin="0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,2" Background="White">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="48"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="90"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding QuestionDisplay}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding QuestionDisplay}"/>

                                                <TextBlock Grid.Column="1"
                                                           Foreground="#666"
                                                           Text="{Binding AnswerDisplay}"/>

                                                <Button Grid.Column="2" Content="View" Height="24" Margin="2"/>

                                                <Button Grid.Column="3" Content="Delete" Height="24" Margin="2"/>

                                                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Left">
                                                    <Button Content="Up" Height="24" Margin="2,2,6,2"/>
                                                    <Button Content="Down" Height="24" Margin="0,2,2,2"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnSubmit" Style="{StaticResource DialogPrimary}" Margin="0,0,12,0" Click="btnSubmit_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FB;" Margin="0,0,8,0"/>
                    <TextBlock Text="Submit"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCancel" Style="{StaticResource DialogSecondary}" Click="btnCancel_Click">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" Margin="0,0,8,0"/>
                    <TextBlock Text="Cancel"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
