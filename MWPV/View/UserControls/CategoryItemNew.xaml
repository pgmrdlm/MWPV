<UserControl x:Class="MWPV.View.UserControls.CategoryItemNew"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="940"
             Focusable="True">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PwWeak"        Color="#D32F2F"/>
        <SolidColorBrush x:Key="PwFair"        Color="#FBC02D"/>
        <SolidColorBrush x:Key="PwStrong"      Color="#388E3C"/>
        <SolidColorBrush x:Key="PwVeryStrong"  Color="#2E7D32"/>

        <SolidColorBrush x:Key="FieldErrorFill" Color="#FFFFEEEE"/>

        <Style x:Key="SmallSquarePrimaryButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Background" Value="{DynamicResource PrimaryNormalBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource PrimaryPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="{DynamicResource DisabledBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource DisabledForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Bisque">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource Brush.Primary}"
                Padding="12,0,6,0">
            <TextBlock VerticalAlignment="Center"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="16"
                       Text="Add / Edit Category Item"/>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True"
                      PanningMode="VerticalOnly"
                      Focusable="False">
            <!-- Shared-size scope so card columns line up everywhere -->
            <Grid Margin="20"
                  Grid.IsSharedSizeScope="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- name / password -->
                    <RowDefinition Height="Auto"/>
                    <!-- strength + verify err -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <!-- user/email/url row -->
                    <RowDefinition Height="Auto"/>
                    <!-- email error -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <!-- phone -->
                    <RowDefinition Height="Auto"/>
                    <!-- phone error -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <!-- notes -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <!-- bank header -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <!-- bank entry line -->
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <!-- bank list -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <!-- account line -->
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <!-- security QA header -->
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>

                <!-- Name -->
                <Label Grid.Row="0" Grid.Column="0"
                       Content="* Category Item Name"
                       FontWeight="Bold"
                       ToolTip="Required field"/>
                <TextBox x:Name="txtItemName"
                         Grid.Row="0" Grid.Column="0"
                         Margin="0,22,0,0"
                         Height="28"
                         MinWidth="320"
                         HorizontalAlignment="Left"/>

                <!-- Password -->
                <Label Grid.Row="0" Grid.Column="2"
                       Content="* Password"
                       FontWeight="Bold"
                       ToolTip="Required field"/>
                <Grid Grid.Row="0" Grid.Column="2"
                      Margin="0,22,0,0"
                      Height="28"
                      MinWidth="280"
                      HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <PasswordBox x:Name="pwdPassword"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     PasswordChanged="pwdPassword_PasswordChanged"
                                     GotFocus="pwdPassword_GotFocus"
                                     PreviewKeyDown="PwdPassword_PreviewKeyDown"/>
                        <TextBox x:Name="txtPasswordPlain"
                                 VerticalAlignment="Center"
                                 Height="28"
                                 IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="Collapsed"
                                 Foreground="Black"/>
                    </Grid>

                    <Button x:Name="btnGeneratePassword"
                            Grid.Column="1"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Generate password"
                            Click="BtnGeneratePassword_Click">
                        <Viewbox Stretch="Uniform">
                            <Canvas Width="18" Height="18">
                                <Path Fill="Black"
                                      Data="M9,1.6 L10.1,5.3 13.6,4.2 11.6,7.3 15.4,8.4 11.6,9.5 13.6,12.6 10.1,11.5 9,15.2 7.9,11.5 4.4,12.6 6.4,9.5 2.6,8.4 6.4,7.3 4.4,4.2 7.9,5.3 z"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button x:Name="btnTogglePasswordReveal"
                            Grid.Column="2"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Show/Hide password"
                            Click="BtnTogglePasswordReveal_Click">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="20" Height="20">
                                <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                      Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Ellipse Width="3" Height="3" Fill="Black"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Viewbox>
                    </Button>
                </Grid>

                <!-- Verify password -->
                <Grid x:Name="VerifyRow"
                      Grid.Row="0" Grid.Column="4"
                      Visibility="Collapsed"
                      HorizontalAlignment="Left">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Content="Verify Password"
                           FontWeight="Bold"
                           Grid.Row="0"
                           Margin="0,0,0,4"/>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left">
                        <Grid Width="280" Height="28">
                            <PasswordBox x:Name="pwdVerify"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         PasswordChanged="pwdVerify_PasswordChanged"/>
                            <TextBox x:Name="txtVerifyPlain"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black"/>
                        </Grid>

                        <Button x:Name="btnToggleVerifyReveal"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show/Hide verification"
                                Margin="4,0,0,0"
                                Click="BtnToggleVerifyReveal_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                    <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse Width="3" Height="3" Fill="Black"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Strength -->
                <StackPanel x:Name="StrengthPanel"
                            Grid.Row="1" Grid.Column="2"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <ProgressBar x:Name="PwStrengthBar"
                                 Height="8"
                                 Minimum="0"
                                 Maximum="1"
                                 Value="0"
                                 Background="#22000000"/>
                    <TextBlock x:Name="PwStrengthText"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="Black"
                               Text=""/>
                    <ItemsControl x:Name="PwTipsList"
                                  Margin="0,2,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="• "/>
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Verify error -->
                <StackPanel x:Name="VerifyErrorPanel"
                            Grid.Row="1" Grid.Column="4"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="VerifyErrorText"
                               Foreground="#D32F2F"
                               FontWeight="Bold"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- User/email/url -->
                <Label Grid.Row="3" Grid.Column="0"
                       Content="User Name"
                       FontWeight="Bold"/>
                <TextBox x:Name="txtUsername"
                         Grid.Row="3" Grid.Column="0"
                         Margin="0,22,0,0"
                         Height="28"
                         MinWidth="240"
                         HorizontalAlignment="Left"/>

                <Label Grid.Row="3" Grid.Column="2"
                       Content="Email"
                       FontWeight="Bold"/>
                <TextBox x:Name="txtEmail"
                         Grid.Row="3" Grid.Column="2"
                         Margin="0,22,0,0"
                         Height="28"
                         MinWidth="240"
                         HorizontalAlignment="Left"
                         LostFocus="txtEmail_LostFocus"/>

                <Label Grid.Row="3" Grid.Column="4"
                       Content="URL or Absolute Location"
                       FontWeight="Bold"/>
                <TextBox x:Name="txtUrl"
                         Grid.Row="3" Grid.Column="4"
                         Margin="0,22,0,0"
                         Height="28"
                         MinWidth="220"
                         HorizontalAlignment="Left"/>

                <StackPanel x:Name="EmailErrorPanel"
                            Grid.Row="4" Grid.Column="2"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="EmailErrorText"
                               Foreground="#D32F2F"
                               FontWeight="Bold"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Phone -->
                <Label Grid.Row="6" Grid.Column="0"
                       Content="Phone Number"
                       FontWeight="Bold"/>
                <Grid Grid.Row="6" Grid.Column="0"
                      Margin="0,22,0,0"
                      Height="28"
                      MinWidth="320"
                      HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <PasswordBox x:Name="txtPhone"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     PasswordChanged="txtPhone_PasswordChanged"
                                     LostFocus="txtPhone_LostFocus"/>
                        <TextBox x:Name="txtPhonePlain"
                                 VerticalAlignment="Center"
                                 Height="28"
                                 IsReadOnly="True"
                                 IsHitTestVisible="False"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="Collapsed"
                                 Foreground="Black"/>
                    </Grid>

                    <Button x:Name="btnTogglePhoneReveal"
                            Grid.Column="1"
                            Style="{StaticResource SmallSquarePrimaryButton}"
                            ToolTip="Show/Hide phone number"
                            Click="BtnTogglePhoneReveal_Click">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="20" Height="20">
                                <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                      Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Ellipse Width="3" Height="3" Fill="Black"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Viewbox>
                    </Button>
                </Grid>

                <StackPanel x:Name="PhoneErrorPanel"
                            Grid.Row="7" Grid.Column="0"
                            Margin="0,6,0,0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="PhoneErrorText"
                               Foreground="#D32F2F"
                               FontWeight="Bold"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Notes -->
                <Label Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="5"
                       Content="Freeform Notes"
                       FontWeight="Bold"/>
                <TextBox x:Name="txtDescription"
                         Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="5"
                         Margin="0,22,0,0"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="48"/>

                <!-- Bank section header -->
                <TextBlock Grid.Row="11"
                           Grid.Column="0"
                           Grid.ColumnSpan="5"
                           Text="Bank Cards / Accounts"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <!-- Bank card entry line -->
                <Grid Grid.Row="13"
                      Grid.Column="0"
                      Grid.ColumnSpan="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"   SharedSizeGroup="CardCol0"/>
                        <!-- type -->
                        <ColumnDefinition Width="2.4*" SharedSizeGroup="CardCol1"/>
                        <!-- number -->
                        <ColumnDefinition Width="2*"   SharedSizeGroup="CardCol2"/>
                        <!-- exp -->
                        <ColumnDefinition Width="2*"   SharedSizeGroup="CardCol3"/>
                        <!-- cvv -->
                        <ColumnDefinition Width="2*"   SharedSizeGroup="CardCol4"/>
                        <!-- pin -->
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CardCol5"/>
                        <!-- active -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- actions -->
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Card Type"
                               FontWeight="Bold"
                               Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="Card Number"
                               FontWeight="Bold"
                               Margin="10,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="Expiration Date"
                               FontWeight="Bold"
                               Margin="10,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="3"
                               Text="CVV"
                               FontWeight="Bold"
                               Margin="10,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="4"
                               Text="Card PIN"
                               FontWeight="Bold"
                               Margin="10,0,0,4"/>
                    <TextBlock Grid.Row="0" Grid.Column="5"
                               Text="Active"
                               FontWeight="Bold"
                               Margin="10,0,0,4"/>

                    <ComboBox x:Name="cboCardType"
                              Grid.Row="1" Grid.Column="0"
                              Height="28"
                              MinWidth="150"
                              HorizontalAlignment="Left"
                              Style="{StaticResource FilterComboStyle}"
                              DisplayMemberPath="Description"
                              SelectedValuePath="Code"/>

                    <TextBox x:Name="txtCardNumber"
                             Grid.Row="1" Grid.Column="1"
                             Margin="10,0,0,0"
                             Height="28"
                             MinWidth="150"
                             HorizontalAlignment="Left"/>

                    <TextBox x:Name="txtExpDate"
                             Grid.Row="1" Grid.Column="2"
                             Margin="10,0,0,0"
                             Height="28"
                             Width="140"
                             MaxLength="10"
                             HorizontalAlignment="Left"/>

                    <Grid Grid.Row="1" Grid.Column="3"
                          Margin="10,0,0,0"
                          Height="28"
                          HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <PasswordBox x:Name="txtCvv"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         Width="120"
                                         MaxLength="6"
                                         PasswordChanged="txtCvv_PasswordChanged"/>
                            <TextBox x:Name="txtCvvPlain"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     Width="120"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black"/>
                        </Grid>

                        <Button x:Name="btnToggleCvvReveal"
                                Grid.Column="1"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show/Hide CVV"
                                Click="BtnToggleCvvReveal_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                    <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse Width="3" Height="3" Fill="Black"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" Grid.Column="4"
                          Margin="10,0,0,0"
                          Height="28"
                          HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <PasswordBox x:Name="txtCardPin"
                                         VerticalAlignment="Center"
                                         Height="28"
                                         Width="120"
                                         MaxLength="12"
                                         PasswordChanged="txtCardPin_PasswordChanged"/>
                            <TextBox x:Name="txtCardPinPlain"
                                     VerticalAlignment="Center"
                                     Height="28"
                                     Width="120"
                                     IsReadOnly="True"
                                     IsHitTestVisible="False"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Foreground="Black"/>
                        </Grid>

                        <Button x:Name="btnToggleCardPinReveal"
                                Grid.Column="1"
                                Style="{StaticResource SmallSquarePrimaryButton}"
                                ToolTip="Show/Hide card PIN"
                                Click="BtnToggleCardPinReveal_Click">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="20" Height="20">
                                    <Path Stroke="Black" Fill="Transparent" StrokeThickness="1.6"
                                          Data="M1.8,10 C4.6,6.0 8.3,4 10.8,4 13.3,4 17.0,6.0 19.8,10 17.0,14.0 13.3,16 10.8,16 8.3,16 4.6,14.0 1.8,10 Z"/>
                                    <Ellipse Width="6" Height="6" Stroke="Black" StrokeThickness="1.2" Fill="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Ellipse Width="3" Height="3" Fill="Black"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Viewbox>
                        </Button>
                    </Grid>

                    <!-- Active checkbox -->
                    <CheckBox x:Name="chkCardActive"
                              Grid.Row="1" Grid.Column="5"
                              Margin="10,0,0,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>

                    <!-- Add / Clear -->
                    <Border Grid.Row="1" Grid.Column="6"
                            Margin="8,0,0,0"
                            Padding="8,2"
                            CornerRadius="8"
                            Background="{DynamicResource Brush.Primary}"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnBankCardAdd"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    ToolTip="Add this card to the in-memory list"
                                    Click="btnBankCardAdd_Click">
                                <TextBlock Text="+"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Button>

                            <Button x:Name="btnBankCardClear"
                                    Style="{StaticResource SmallSquarePrimaryButton}"
                                    Margin="8,0,0,0"
                                    ToolTip="Reset this card line"
                                    Click="btnBankCardClear_Click">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE895;"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Bank card display grid -->
                <Border Grid.Row="15"
                        Grid.Column="0"
                        Grid.ColumnSpan="5"
                        Margin="0,6,0,0"
                        Padding="0"
                        BorderBrush="{DynamicResource ShadowStroke}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="#FFFDF5E6"
                        MaxWidth="780"
                        HorizontalAlignment="Left">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header row shares same column groups -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"   SharedSizeGroup="CardCol0"/>
                                <ColumnDefinition Width="2.4*" SharedSizeGroup="CardCol1"/>
                                <ColumnDefinition Width="2*"   SharedSizeGroup="CardCol2"/>
                                <ColumnDefinition Width="2*"   SharedSizeGroup="CardCol3"/>
                                <ColumnDefinition Width="2*"   SharedSizeGroup="CardCol4"/>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="CardCol5"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Card Type"
                                       FontWeight="Bold"
                                       Margin="0,0,0,2"/>
                            <TextBlock Grid.Column="1"
                                       Text="Card Number"
                                       FontWeight="Bold"
                                       Margin="10,0,0,2"/>
                            <TextBlock Grid.Column="2"
                                       Text="Expiration"
                                       FontWeight="Bold"
                                       Margin="10,0,0,2"/>
                            <TextBlock Grid.Column="3"
                                       Text="CVV"
                                       FontWeight="Bold"
                                       Margin="10,0,0,2"/>
                            <TextBlock Grid.Column="4"
                                       Text="PIN"
                                       FontWeight="Bold"
                                       Margin="10,0,0,2"/>
                            <TextBlock Grid.Column="5"
                                       Text="Active"
                                       FontWeight="Bold"
                                       Margin="10,0,0,2"/>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,2,0,2"
                                Background="{DynamicResource ShadowStroke}"
                                Height="1"/>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="txtNoBankCardsPlaceholder"
                                       Grid.Row="0"
                                       Text="No bank cards added yet."
                                       FontStyle="Italic"
                                       Foreground="Gray"
                                       Margin="4,4,0,4"/>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Height="96">
                                <ItemsControl x:Name="icBankCards">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"   SharedSizeGroup="CardCol0"/>
                                                    <ColumnDefinition Width="2.4*" SharedSizeGroup="CardCol1"/>
                                                    <ColumnDefinition Width="2*"   SharedSizeGroup="CardCol2"/>
                                                    <ColumnDefinition Width="2*"   SharedSizeGroup="CardCol3"/>
                                                    <ColumnDefinition Width="2*"   SharedSizeGroup="CardCol4"/>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="CardCol5"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- TODO: bind these to your BankCard properties -->
                                                <TextBlock Grid.Column="0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding CardTypeDisplay}"/>
                                                <TextBlock Grid.Column="1"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding CardNumberMasked}"/>
                                                <TextBlock Grid.Column="2"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding ExpirationDisplay}"/>
                                                <TextBlock Grid.Column="3"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding CvvMasked}"/>
                                                <TextBlock Grid.Column="4"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding PinMasked}"/>

                                                <CheckBox Grid.Column="5"
                                                          Margin="10,0,0,0"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding IsActive}"
                                                          IsEnabled="False"/>

                                                <Button x:Name="btnBankCardRowEdit"
                                                        Grid.Column="6"
                                                        Margin="6,0,0,0"
                                                        Padding="0"
                                                        Height="24"
                                                        VerticalAlignment="Center"
                                                        Style="{StaticResource SmallSquarePrimaryButton}"
                                                        ToolTip="Edit this card"
                                                        Click="btnBankCardRowEdit_Click">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               Text="&#xE70F;"
                                                               FontSize="14"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>
                                                </Button>

                                                <Button x:Name="btnBankCardRowDelete"
                                                        Grid.Column="6"
                                                        Margin="40,0,0,0"
                                                        Padding="0"
                                                        Height="24"
                                                        VerticalAlignment="Center"
                                                        Style="{StaticResource SmallSquarePrimaryButton}"
                                                        Background="#C62828"
                                                        ToolTip="Remove this card"
                                                        Click="btnBankCardRowDelete_Click">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               Text="&#xE711;"
                                                               FontSize="14"
                                                               Foreground="White"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Account line -->
                <Label Grid.Row="17" Grid.Column="0"
                       Content="Account Name"
                       FontWeight="Bold"/>
                <Label Grid.Row="17" Grid.Column="2"
                       Content="Account Number"
                       FontWeight="Bold"/>
                <Label Grid.Row="17" Grid.Column="4"
                       Content="Account PIN (optional)"
                       FontWeight="Bold"/>

                <ComboBox x:Name="cboAccountName"
                          Grid.Row="17" Grid.Column="0"
                          Margin="0,22,0,0"
                          Height="28"
                          MinWidth="150"
                          MaxWidth="220"
                          HorizontalAlignment="Left"
                          Style="{StaticResource FilterComboStyle}"/>

                <TextBox x:Name="txtAccountNumber"
                         Grid.Row="17" Grid.Column="2"
                         Margin="0,22,0,0"
                         Height="28"
                         Width="260"
                         MaxLength="24"
                         HorizontalAlignment="Left"/>

                <PasswordBox x:Name="txtAccountPin"
                             Grid.Row="17" Grid.Column="4"
                             Margin="0,22,0,0"
                             Height="28"
                             Width="120"
                             MaxLength="12"
                             HorizontalAlignment="Left"/>

                <!-- Security Q/A placeholder -->
                <TextBlock Grid.Row="19"
                           Grid.Column="0"
                           Grid.ColumnSpan="5"
                           Text="Security Questions / Answers"
                           FontWeight="Bold"
                           Margin="0,24,0,0"/>
            </Grid>
        </ScrollViewer>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">
            <Button x:Name="btnSubmit"
                    Style="{StaticResource DialogPrimary}"
                    Margin="0,0,12,0"
                    Click="btnSubmit_Click">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE8FB;"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Submit"/>
                </StackPanel>
            </Button>

            <Button x:Name="btnCancel"
                    Style="{StaticResource DialogSecondary}"
                    Click="btnCancel_Click">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE711;"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Cancel"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
