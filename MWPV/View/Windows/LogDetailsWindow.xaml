<Window x:Class="MWPV.View.Windows.LogDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Log Details" Width="1040" Height="720"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <DockPanel Margin="8">
        <!-- Top: header line -->
        <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="0,0,0,8">
            <TextBlock x:Name="txtId" FontWeight="Bold" FontSize="18"/>
            <WrapPanel Margin="0,4,0,0">
                <TextBlock Text="Created: " FontWeight="Bold"/>
                <TextBlock x:Name="txtCreated" Margin="4,0,16,0"/>
                <TextBlock Text="Level: " FontWeight="Bold"/>
                <TextBlock x:Name="txtLevel" Margin="4,0,16,0"/>
                <TextBlock Text="Source: " FontWeight="Bold"/>
                <TextBlock x:Name="txtSource" Margin="4,0,16,0"/>
                <TextBlock Text="Event: " FontWeight="Bold"/>
                <TextBlock x:Name="txtEvent" Margin="4,0,16,0"/>
            </WrapPanel>

            <WrapPanel Margin="0,6,0,0">
                <TextBlock Text="PayloadFmt: " FontWeight="Bold"/>
                <TextBlock x:Name="txtFmt" Margin="4,0,16,0"/>
                <TextBlock Text="Bytes: " FontWeight="Bold"/>
                <TextBlock x:Name="txtSize" Margin="4,0,16,0"/>
            </WrapPanel>
        </StackPanel>

        <!-- Body: payload box -->
        <GroupBox Header="Payload (pretty-printed)" Margin="0,0,0,8">
            <Grid>
                <TextBox x:Name="txtPayload"
                         FontFamily="Consolas"
                         FontSize="13"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         IsReadOnly="True"/>
            </Grid>
        </GroupBox>

        <!-- Bottom: buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" >
            <Button x:Name="btnCopy" Width="140" Height="28" Margin="0,0,12,0" Content="Copy Payload" Click="btnCopy_Click"/>
            <Button x:Name="btnClose" Width="120" Height="28" Content="Close" Click="btnClose_Click"/>
        </StackPanel>
    </DockPanel>
</Window>
