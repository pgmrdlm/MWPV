<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- =======================
         GLOBAL SIZES & PADDING
         ======================= -->
    <sys:Double   x:Key="StdButtonWidth">130</sys:Double>
    <sys:Double   x:Key="StdButtonHeight">20</sys:Double>
    <Thickness    x:Key="StdButtonPadding">10,6,10,6</Thickness>

    <sys:Double   x:Key="FatButtonHeight">28</sys:Double>
    <Thickness    x:Key="FatButtonPadding">16,6,16,6</Thickness>

    <!-- =======================
         BASE TEMPLATE (130×20)
         ======================= -->
    <Style x:Key="RoundedButtonBase" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource StdButtonWidth}"/>
        <Setter Property="Height" Value="{StaticResource StdButtonHeight}"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Padding" Value="{StaticResource StdButtonPadding}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Border x:Name="HoverOverlay"  CornerRadius="14" Background="#40FFFFFF" Opacity="0"/>
                            <Border x:Name="PressedOverlay" CornerRadius="14" Background="#20000000" Opacity="0"/>
                            <ContentPresenter RecognizesAccessKey="True"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.18" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PressedOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.22" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled"/>
                            </VisualStateGroup>
                            <VisualStateGroup x:Name="FocusStates">
                                <VisualState x:Name="Unfocused"/>
                                <VisualState x:Name="Focused"/>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Padding" Value="10,7,10,7"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource FocusBorder}"/>
                            <Setter Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsDefault" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#5B9DFF"/>
                        </Trigger>
                        <Trigger Property="IsCancel" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#FF7B7B"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource DisabledBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource DisabledForeground}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="#33000000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =======================
         SIZE / PURPOSE VARIANTS
         ======================= -->
    <Style x:Key="ActionFat" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
        <Setter Property="Height" Value="{StaticResource FatButtonHeight}"/>
        <Setter Property="Padding" Value="{StaticResource FatButtonPadding}"/>
    </Style>

    <!-- =======================
         DIALOG BUTTONS
         ======================= -->

    <!-- Primary (green) -->
    <Style x:Key="DialogPrimary" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
        <Setter Property="Background" Value="{DynamicResource PrimaryNormalBrush}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource PrimaryPressedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Secondary (gray/silver) -->
    <Style x:Key="DialogSecondary" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
        <Setter Property="Background" Value="{DynamicResource SecondaryNormalBrush}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource SecondaryHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource SecondaryPressedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Danger (red) -->
    <Style x:Key="DialogDanger" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
        <Setter Property="Background" Value="{DynamicResource DangerNormalBrush}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="BorderBrush" Value="#40000000"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource DangerPressedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =======================
         CATEGORY / ITEM PILLS
         ======================= -->
    <Style x:Key="CategoryPill" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
        <Setter Property="Background" Value="{DynamicResource NavNormalBrush}"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource NavHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource NavPressedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ItemPill" TargetType="Button" BasedOn="{StaticResource RoundedButtonBase}">
        <Setter Property="Background" Value="{DynamicResource ItemNormalBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ShadowStroke}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ItemHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource ItemPressedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =======================
         TITLEBAR BUTTONS
         ======================= -->
    <Style x:Key="TitleButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#30FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#50FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="Transparent"/>
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
