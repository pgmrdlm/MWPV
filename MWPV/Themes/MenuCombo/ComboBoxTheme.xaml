<!-- Themes/MenuCombo/ComboBoxTheme.xaml -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Rounded dropdown items -->
    <Style x:Key="FilterComboItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource ComboDropItemBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  CornerRadius="6"
                  Margin="2">
                        <ContentPresenter Margin="8,4"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Mouse hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                      Value="{StaticResource ComboDropItemHoverBrush}"/>
                            <Setter Property="Foreground"
                      Value="{DynamicResource Interactive.HoverFg}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>

                        <!-- Keyboard highlight (arrow keys) -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                      Value="{StaticResource ComboDropItemHoverBrush}"/>
                            <Setter Property="Foreground"
                      Value="{DynamicResource Interactive.HoverFg}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>

                        <!-- Selected row -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                      Value="{StaticResource ComboDropItemSelectedBrush}"/>
                            <Setter Property="Foreground"
                      Value="{DynamicResource Interactive.HoverFg}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#90FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Opt-in ComboBox style (keeps default template) -->
    <Style x:Key="FilterComboStyle" TargetType="ComboBox">
        <!-- Scope the popup tray & border to THIS ComboBox only -->
        <Style.Resources>
            <!-- Maroon popup tray -->
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#7A0000"/>
            <!-- Hide default popup border -->
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowFrameBrushKey}" Color="Transparent"/>
        </Style.Resources>

        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource FilterComboItemStyle}"/>
    </Style>

</ResourceDictionary>
