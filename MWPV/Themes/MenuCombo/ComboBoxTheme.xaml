<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Items: background never changes; text changes on hover/selected -->
    <Style x:Key="FilterComboItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="White"/>
        <!-- readable on blue tray -->
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  CornerRadius="6"
                  Margin="2"
                  SnapsToDevicePixels="True">
                        <ContentPresenter Margin="8,4"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- text-only change -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Interactive.HoverFg}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Interactive.HoverFg}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Interactive.HoverFg}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#99000000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox: solid blue tray; thin border in brand color -->
    <Style x:Key="FilterComboStyle" TargetType="ComboBox">
        <Style.Resources>
            <!-- 🔵 make the dropdown tray BLUE -->
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"
                       Color="{DynamicResource Color.Primary}"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowFrameBrushKey}"
                       Color="{DynamicResource Color.Primary}"/>
        </Style.Resources>

        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource FilterComboItemStyle}"/>

        <!-- Closed control sits on the page surface (Bisque), so keep its text dark -->
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="#222"/>
    </Style>

</ResourceDictionary>
