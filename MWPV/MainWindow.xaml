<Window x:Class="MWPV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MWPV"
        xmlns:userControls="clr-namespace:MWPV.View.UserControls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="MWPV - My Windows Password Vault"
        WindowStyle="None"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        Width="1536" Height="864"
        MinWidth="1100" MinHeight="700"
        WindowState="Maximized"
        Icon="/Assets/Icons/MWPV.ico">

    <!-- Borderless drag/resize -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <!-- Root layout: Title (Auto) / Menu (Auto) / Content (*) / Status/Banner (Auto) -->
    <Grid Background="{DynamicResource Brush.Secondary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <!-- Title Bar (fixed) -->
            <RowDefinition Height="Auto"/>
            <!-- Menu Bar -->
            <RowDefinition Height="*"/>
            <!-- CONTENT VIEWPORT -->
            <RowDefinition Height="Auto"/>
            <!-- Status/Banner -->
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <!-- icon -->
                    <ColumnDefinition Width="*"/>
                    <!-- title / drag area -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- caption buttons -->
                </Grid.ColumnDefinitions>

                <!-- App icon -->
                <Image Grid.Column="0"
                       Width="16" Height="16"
                       Margin="6,0,6,0"
                       VerticalAlignment="Center"
                       Source="/Assets/Icons/MWPV.ico"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       shell:WindowChrome.IsHitTestVisibleInChrome="False"/>

                <!-- Drag area + window title -->
                <Grid Grid.Column="1"
                      MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown"
                      MouseRightButtonUp="TitleBar_OnMouseRightButtonUp">
                    <Grid Margin="0,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,12,0"
                                   IsHitTestVisible="False"/>

                        <TextBlock x:Name="VersionDisplayText"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Foreground="White"
                                   FontSize="11"
                                   Opacity="0.9"
                                   TextTrimming="CharacterEllipsis"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Grid>

                <!-- Caption buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Minimize -->
                    <Button Width="46" Height="36" Background="Transparent" BorderThickness="0"
                            Click="Minimize_Click" ToolTip="Minimize"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"
                                   Text="&#xE921;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <!-- Max/Restore -->
                    <Button x:Name="MaxRestoreButton" Width="46" Height="36" Background="Transparent" BorderThickness="0"
                            Click="MaxRestore_Click" ToolTip="Maximize"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock x:Name="TbMaxGlyph" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"
                                   Text="&#xE922;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <!-- Close -->
                    <Button Width="46" Height="36" Background="Transparent" BorderThickness="0"
                            Click="Close_Click" ToolTip="Close"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"
                                   Text="&#xE8BB;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MENU (Auto) -->
        <Grid Grid.Row="1">
            <userControls:MenuBar x:Name="MenuBar"/>
            <Border x:Name="MenuLockOverlay"
                    Background="Transparent"
                    Visibility="Collapsed"
                    Panel.ZIndex="10"
                    ToolTipService.ShowDuration="6000"
                    ToolTipService.InitialShowDelay="250"
                    ToolTip="You cannot leave item edit mode until you save, cancel, or close the item edit screen."/>
        </Grid>

        <!-- CONTENT VIEWPORT (row *) — Panel hosts its own outer ScrollViewer -->
        <userControls:Panel x:Name="Panel" Grid.Row="2"/>

        <!-- STATUS / BANNER (Auto) -->
        <!-- This is our "blue box" host. MainWindow.xaml.cs still writes to StatusText. -->
        <Border x:Name="StatusBannerHost"
                Grid.Row="3"
                Margin="8,2,8,4"
                Padding="10,8"
                CornerRadius="8"
                Background="{DynamicResource Brush.Secondary}"
                BorderBrush="#DC2626"
                BorderThickness="2"
                Visibility="Visible">
            <TextBlock x:Name="StatusText"
                       TextWrapping="Wrap"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="Black"
                       HorizontalAlignment="Stretch"
                       TextAlignment="Center"/>
        </Border>

        <Grid x:Name="MaintenanceOverlay" Grid.RowSpan="4" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="100">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="White" CornerRadius="8" Padding="28" MinWidth="420">
                <StackPanel>
                    <TextBlock Text="Maintenance in progress" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="MaintenanceStageText" Margin="0,14,0,12" TextWrapping="Wrap" TextAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True" Height="16"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
