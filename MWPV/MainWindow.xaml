<Window x:Class="MWPV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MWPV"
        xmlns:userControls="clr-namespace:MWPV.View.UserControls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="MWPV - My Windows Password Vault"
        WindowStyle="None"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        Width="1536" Height="864"           
    MinWidth="1100" MinHeight="700"
    Icon="/Assets/Icons/MWPV.ico">

    <!-- Borderless drag/resize -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <!-- Root layout: Title (Auto) / Menu (Auto) / Content (*) / Status (Auto) -->
    <Grid Background="{DynamicResource Brush.Secondary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <!-- Title Bar (fixed) -->
            <RowDefinition Height="Auto"/>
            <!-- Menu Bar -->
            <RowDefinition Height="*"/>
            <!-- CONTENT VIEWPORT -->
            <RowDefinition Height="Auto"/>
            <!-- Status Line -->
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Primary}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <!-- icon -->
                    <ColumnDefinition Width="*"/>
                    <!-- title / drag area -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- caption buttons -->
                </Grid.ColumnDefinitions>

                <!-- App icon -->
                <Image Grid.Column="0"
                       Width="16" Height="16"
                       Margin="6,0,6,0"
                       VerticalAlignment="Center"
                       Source="/Assets/Icons/MWPV.ico"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       shell:WindowChrome.IsHitTestVisibleInChrome="False"/>

                <!-- Drag area + window title -->
                <Grid Grid.Column="1"
                      MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown"
                      MouseRightButtonUp="TitleBar_OnMouseRightButtonUp">
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>

                <!-- Caption buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Minimize -->
                    <Button Width="46" Height="36" Background="Transparent" BorderThickness="0"
                            Click="Minimize_Click" ToolTip="Minimize"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"
                                   Text="&#xE921;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <!-- Max/Restore -->
                    <Button x:Name="MaxRestoreButton" Width="46" Height="36" Background="Transparent" BorderThickness="0"
                            Click="MaxRestore_Click" ToolTip="Maximize"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock x:Name="TbMaxGlyph" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"
                                   Text="&#xE922;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <!-- Close -->
                    <Button Width="46" Height="36" Background="Transparent" BorderThickness="0"
                            Click="Close_Click" ToolTip="Close"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"
                                   Text="&#xE8BB;" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MENU (Auto) -->
        <userControls:MenuBar Grid.Row="1"/>

        <!-- CONTENT VIEWPORT (row *) — Panel hosts its own outer ScrollViewer -->
        <userControls:Panel x:Name="Panel" Grid.Row="2"/>

        <!-- STATUS (Auto) -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="3"
                   Margin="8,2,8,4"
                   TextWrapping="Wrap"
                   FontSize="12"
                   FontWeight="Bold"
                   Foreground="#CC0000"
                   HorizontalAlignment="Stretch"
                   TextAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</Window>
