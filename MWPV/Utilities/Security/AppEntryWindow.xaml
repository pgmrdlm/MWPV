<!-- File: Utilities/Security/AppEntryWindow.xaml
     FULL REWRITE

     Purpose (hotfix/UpperCaseNotify prep):
     - Adds Caps Lock ON notifications for the two PasswordBox controls only:
         pbPassword, pbVerifyPassword
     - Notifications are UI placeholders (TextBlocks) that code-behind will toggle.

     Critical compatibility:
     - Reintroduces the named RowDefinition: x:Name="VerifyPasswordRow"
       because AppEntryWindow.xaml.cs uses:
           VerifyPasswordRow.Height = new GridLength(0);

     Notes:
     - No CapsLock logic in XAML; code-behind handles:
         GotKeyboardFocus, LostKeyboardFocus, PreviewKeyDown
     - Strength meter UI remains as-is, just re-rowed to accommodate the Caps warnings.
-->

<Window x:Class="Utilities.Security.AppEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Icon="/Assets/Icons/MWPV.ico"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="640"
        SizeToContent="Height"
        MinHeight="340"
        MaxHeight="560"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <!-- Brushes for password-strength meter -->
    <Window.Resources>
        <SolidColorBrush x:Key="PwWeak"       Color="#D32F2F"/>
        <SolidColorBrush x:Key="PwFair"       Color="#FBC02D"/>
        <SolidColorBrush x:Key="PwStrong"     Color="#388E3C"/>
        <SolidColorBrush x:Key="PwVeryStrong" Color="#2E7D32"/>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="DarkSlateGray"
            BorderThickness="3"
            Background="White"
            Padding="0"
            SnapsToDevicePixels="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar (brand) -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Brush.Primary}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Padding="10,0,8,0">
                <DockPanel LastChildFill="True">
                    <Image Width="16" Height="16"
                           Margin="0,0,8,0"
                           Source="{Binding Icon, RelativeSource={RelativeSource AncestorType=Window}}"/>

                    <TextBlock VerticalAlignment="Center"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Text="MWPV Password and Key File Entry"/>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                Margin="8,0,0,0">

                        <!-- Minimize -->
                        <Button Style="{StaticResource TitleButton}"
                                ToolTip="Minimize"
                                Click="MinButton_Click"
                                Margin="0,0,4,0">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="White"
                                       Text="&#xE921;"/>
                        </Button>

                        <!-- Max/Restore -->
                        <Button Style="{StaticResource TitleButton}"
                                ToolTip="Maximize/Restore"
                                Click="MaxRestoreButton_Click"
                                Margin="0,0,4,0">
                            <TextBlock x:Name="TbMaxGlyph"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="White"
                                       Text="&#xE922;"/>
                        </Button>

                        <!-- Close -->
                        <Button Style="{StaticResource TitleButton}"
                                ToolTip="Close"
                                Click="CloseButton_Click">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="White"
                                       Text="&#xE8BB;"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content (surface) -->
            <Border Grid.Row="1"
                    Background="{DynamicResource Brush.Secondary}"
                    Padding="18">

                <!-- 3 columns: labels/button | gutter | inputs -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Rows (structured to add Caps Lock warnings + keep VerifyPasswordRow name) -->
                    <Grid.RowDefinitions>
                        <!-- 0: Password input -->
                        <RowDefinition Height="Auto"/>
                        <!-- 1: Caps warn (Password) -->
                        <RowDefinition Height="Auto"/>

                        <!-- 2: Strength meter -->
                        <RowDefinition Height="Auto"/>

                        <!-- 3: Verify input (NAMED for code-behind compatibility) -->
                        <RowDefinition x:Name="VerifyPasswordRow" Height="Auto"/>
                        <!-- 4: Caps warn (Verify) -->
                        <RowDefinition Height="Auto"/>

                        <!-- 5: Spacer -->
                        <RowDefinition Height="16"/>

                        <!-- 6: Key file -->
                        <RowDefinition Height="Auto"/>
                        <!-- 7: Spacer -->
                        <RowDefinition Height="20"/>

                        <!-- 8: Submit/Cancel -->
                        <RowDefinition Height="Auto"/>
                        <!-- 9: Spacer -->
                        <RowDefinition Height="10"/>

                        <!-- 10: Error -->
                        <RowDefinition Height="Auto"/>

                        <!-- 11: Advisory banner -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Enter Password -->
                    <Label Grid.Row="0" Grid.Column="0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,10,0"
                           Content="_Enter Password"
                           Target="{Binding ElementName=pbPassword}"/>

                    <PasswordBox x:Name="pbPassword"
                                 Grid.Row="0" Grid.Column="2"
                                 Height="30"
                                 VerticalAlignment="Center"
                                 Background="White"
                                 Foreground="Black"
                                 PasswordChar="*"
                                 Padding="6,2"
                                 GotKeyboardFocus="PasswordBox_GotKeyboardFocus"
                                 LostKeyboardFocus="PasswordBox_LostKeyboardFocus"
                                 PreviewKeyDown="PasswordBox_PreviewKeyDown"/>

                    <!-- Caps Lock warning (Password) -->
                    <TextBlock x:Name="tbCapsWarnPassword"
                               Grid.Row="1" Grid.Column="2"
                               Margin="0,4,0,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#B91C1C"
                               Visibility="Collapsed"
                               Text="Caps Lock is ON"/>

                    <!-- Password strength (advisory only) -->
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,6,0,0">
                        <ProgressBar x:Name="PwStrengthBar"
                                     Height="8"
                                     Minimum="0"
                                     Maximum="1"
                                     Value="0"
                                     Background="#22000000"/>
                        <TextBlock x:Name="PwStrengthText"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="Black"
                                   Text="Password strength: n/a"/>
                        <ItemsControl x:Name="PwTipsList" Margin="0,2,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="• "/>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Verify Password -->
                    <Label x:Name="lblVerifyPassword"
                           Grid.Row="3" Grid.Column="0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,10,0"
                           Content="_Verify Password"
                           Target="{Binding ElementName=pbVerifyPassword}"/>

                    <PasswordBox x:Name="pbVerifyPassword"
                                 Grid.Row="3" Grid.Column="2"
                                 Height="30"
                                 VerticalAlignment="Center"
                                 Background="White"
                                 Foreground="Black"
                                 PasswordChar="*"
                                 Padding="6,2"
                                 GotKeyboardFocus="PasswordBox_GotKeyboardFocus"
                                 LostKeyboardFocus="PasswordBox_LostKeyboardFocus"
                                 PreviewKeyDown="PasswordBox_PreviewKeyDown"/>

                    <!-- Caps Lock warning (Verify) -->
                    <TextBlock x:Name="tbCapsWarnVerify"
                               Grid.Row="4" Grid.Column="2"
                               Margin="0,4,0,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#B91C1C"
                               Visibility="Collapsed"
                               Text="Caps Lock is ON"/>

                    <!-- Key file selection -->
                    <Button x:Name="btnCreateKeyFile"
                            Grid.Row="6" Grid.Column="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource DialogPrimary}"
                            Click="btnCreateKeyFile_Click"
                            ToolTip="Create/Choose the encrypted key archive"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72E;" Margin="0,0,8,0"/>
                            <TextBlock x:Name="tbKeyButtonText" Text="Create Key File"/>
                        </StackPanel>
                    </Button>

                    <TextBox x:Name="tbKeyFile"
                             Grid.Row="6" Grid.Column="2"
                             Height="30"
                             VerticalAlignment="Center"
                             IsReadOnly="True"
                             Background="White"
                             Foreground="Black"
                             Padding="6,2"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Disabled"
                             ToolTip="{Binding Text, ElementName=tbKeyFile}"/>

                    <!-- Submit / Cancel -->
                    <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <Button x:Name="btnSubmit"
                                Style="{StaticResource DialogPrimary}"
                                Click="btnSubmit_Click"
                                ToolTip="Submit the entered password and key file."
                                Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FB;" Margin="0,0,8,0"/>
                                <TextBlock Text="Submit"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnCancel"
                                Style="{StaticResource DialogSecondary}"
                                ToolTip="Cancel and close this window."
                                Click="btnCancel_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" Margin="0,0,8,0"/>
                                <TextBlock Text="Cancel"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Error message -->
                    <TextBox x:Name="tbErrorMessage"
                             Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="3"
                             Visibility="Collapsed"
                             Height="100"
                             Margin="0,6,0,0"
                             VerticalAlignment="Top"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             TextAlignment="Center"
                             VerticalContentAlignment="Top"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="Red"
                             FontWeight="Bold"
                             BorderThickness="0"/>

                    <!-- Advisory banner (left as-is) -->
                    <Border x:Name="InfoBanner"
                            Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="3"
                            Visibility="Visible"
                            Margin="0,10,0,0"
                            Padding="10"
                            Background="#1E40AF"
                            BorderBrush="#1D4ED8"
                            BorderThickness="1"
                            CornerRadius="6">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="White"
                                   FontSize="13">
                            Choose a safe location and file name for your encrypted key archive. The name and extension don’t affect encryption, but storing it in a secure, backed-up location does.
                        </TextBlock>
                    </Border>

                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
