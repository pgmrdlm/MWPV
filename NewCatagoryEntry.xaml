<Window x:Class="MWPV.NewCategoryEntry"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Category Entry"
        Height="360"
        Width="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <!-- Ensure the app's button styles are available here -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Explicit pack URI to the MWPV assembly -->
                <ResourceDictionary Source="pack://application:,,,/MWPV;component/Themes/Buttons/Buttons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Bisque" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Name -->
            <RowDefinition Height="Auto"/>
            <!-- Description -->
            <RowDefinition Height="24"/>
            <!-- Error (fixed height so layout doesn't jump) -->
            <RowDefinition Height="Auto"/>
            <!-- Actions -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <Label Grid.Row="0"
               Content="Add New Category"
               FontSize="16"
               FontWeight="DemiBold"
               Foreground="Black"
               HorizontalAlignment="Center"
               Margin="0,0,0,12"/>

        <!-- Category Name -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8">
            <Label Content="Category Name:" Width="130" VerticalAlignment="Center"/>
            <TextBox x:Name="tbCategoryName"
                     Width="300"
                     Height="24"
                     MaxLength="17"
                     Background="White"
                     Foreground="Black"/>
        </StackPanel>

        <!-- Category Description -->
        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center"
                    Width="460"
                    Margin="0,0,0,8">
            <Label Content="Category Description:"/>
            <TextBox x:Name="tbCategoryDescription"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Height="120"
                     MaxLength="512"
                     Background="White"
                     Foreground="Black"/>
        </StackPanel>

        <!-- Error line (reserved space so the button doesn't jump) -->
        <TextBlock x:Name="txtErrorMessage"
                   Grid.Row="3"
                   Text=""
                   Foreground="Red"
                   FontWeight="Bold"
                   Visibility="Collapsed"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <!-- Actions (picks up implicit Button style from Buttons.xaml) -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,6,0,0">
            <Button x:Name="btnAddCategory"
                    Content="Save New Category"
                    IsDefault="True"
                    Click="btnAddCategory_Click"
                    Margin="2"/>
            <!--
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    IsCancel="True"
                    Click="btnCancel_Click"
                    Margin="2"/>
            -->
        </StackPanel>
    </Grid>
</Window>
