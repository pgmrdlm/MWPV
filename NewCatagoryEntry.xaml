<Window x:Class="MWPV.NewCategoryEntry"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Height="480"
        Width="860"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <!-- Match password dialog chrome -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                        CornerRadius="0"
                        GlassFrameThickness="0"
                        ResizeBorderThickness="6"
                        UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <!-- Outer frame -->
    <Border BorderBrush="DarkSlateGray"
          BorderThickness="3"
          Background="White"
          Padding="0"
          SnapsToDevicePixels="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <!-- Title bar -->
                <RowDefinition Height="*"/>
                <!-- Body -->
            </Grid.RowDefinitions>

            <!-- Title Bar (draggable; X flush-right) -->
            <Border Grid.Row="0"
              Background="#810000"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
              Padding="12,0,6,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                     VerticalAlignment="Center"
                     Foreground="White"
                     FontWeight="SemiBold"
                     FontSize="16"
                     Text="Add New Category"/>

                    <Button Grid.Column="1"
                  Style="{StaticResource TitleButton}"
                  HorizontalAlignment="Right"
                  ToolTip="Close"
                  Click="CloseButton_Click"
                  Margin="8,0,0,0">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                       FontSize="12"
                       Foreground="White"
                       Text="&#xE8BB;"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <Border Grid.Row="1" Background="Bisque" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- form -->
                        <RowDefinition Height="10"/>
                        <!-- gap -->
                        <RowDefinition Height="Auto"/>
                        <!-- error line -->
                        <RowDefinition Height="16"/>
                        <!-- gap -->
                        <RowDefinition Height="Auto"/>
                        <!-- buttons -->
                        <RowDefinition Height="*"/>
                        <!-- filler -->
                    </Grid.RowDefinitions>

                    <!-- FORM -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Name -->
                            <RowDefinition Height="Auto"/>
                            <!-- Description -->
                        </Grid.RowDefinitions>

                        <!-- Name -->
                        <Label Grid.Row="0" Grid.Column="0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   FontWeight="Bold"
                   Content="Category Name:"/>
                        <TextBox x:Name="tbCategoryName"
                     Grid.Row="0" Grid.Column="2"
                     Height="28"
                     MaxLength="17"
                     Background="White"
                     Foreground="Black"
                     Margin="0,0,0,10"
                     TextChanged="tbCategoryName_TextChanged"/>

                        <!-- Description -->
                        <Label Grid.Row="1" Grid.Column="0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   FontWeight="Bold"
                   Content="Category Description:"/>
                        <TextBox x:Name="tbCategoryDescription"
                     Grid.Row="1" Grid.Column="2"
                     Height="220"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     MaxLength="512"
                     Background="White"
                     Foreground="Black"
                     TextChanged="tbCategoryDescription_TextChanged"/>
                    </Grid>

                    <!-- Error line -->
                    <TextBlock x:Name="txtErrorMessage"
                     Grid.Row="2"
                     Foreground="Red"
                     FontWeight="Bold"
                     Visibility="Collapsed"
                     HorizontalAlignment="Center"
                     TextWrapping="Wrap"/>

                    <!-- Buttons (same style keys as password dialog) -->
                    <StackPanel Grid.Row="4"
                      Orientation="Horizontal"
                      HorizontalAlignment="Center">
                        <Button x:Name="btnAddCategory"
                    Style="{StaticResource DialogPrimary}"
                    IsDefault="True"
                    Click="btnAddCategory_Click"
                    Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8FB;" Margin="0,0,8,0"/>
                                <TextBlock Text="Submit"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource DialogSecondary}"
                    IsCancel="True"
                    Click="CloseButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE711;" Margin="0,0,8,0"/>
                                <TextBlock Text="Cancel"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>